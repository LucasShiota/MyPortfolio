---
import { LINKS } from "../../config/links.ts";

interface Props {
  isHamburger?: boolean;
}

const { isHamburger = false } = Astro.props;
---

<div class={`lets-talk-wrapper ${isHamburger ? 'hmbrgr-lets-talk-wrapper' : ''}`}>
  <button 
    class={isHamburger ? 'hmbrgr-contact-btn' : 'contact-btn'} 
    aria-haspopup="true"
    aria-expanded="false"
    aria-label="Open contact options"
  > 
    <i class="contact-icon fa-solid fa-comments"></i> Let's Talk 
  </button>

  <div class="lets-talk-panel">
    <!-- Section 1: Action -->
    <div class="panel-section">
      <a href={`mailto:${LINKS.contact.email}`} class="panel-btn"> 
        <i class="fa-solid fa-paper-plane"></i> 
        <span>Start Email Draft</span> 
      </a>
    </div>

    <!-- Section 2: Email -->
    <div class="panel-section">
      <span class="section-label"><i class="fa-solid fa-envelope"></i> Email Address</span>
      <button class="panel-btn copy-btn" data-copy={LINKS.contact.email}> 
        <span class="icon-swap">
          <i class="fa-solid fa-copy main-icon"></i>
          <i class="fa-solid fa-check check-icon"></i>
        </span>
        <span class="btn-text">{LINKS.contact.email}</span> 
      </button>
    </div>

    <!-- Section 3: Discord -->
    <div class="panel-section">
      <span class="section-label"><i class="fa-brands fa-discord"></i> Discord Username</span>
      <button class="panel-btn copy-btn" data-copy={LINKS.contact.discord}> 
        <span class="icon-swap">
          <i class="fa-solid fa-copy main-icon"></i>
          <i class="fa-solid fa-check check-icon"></i>
        </span>
        <span class="btn-text">{LINKS.contact.discord}</span> 
      </button>
    </div>
  </div>
</div>

<script>
  function setupLetsTalk() {
    const letsTalkWrappers = document.querySelectorAll('.lets-talk-wrapper');
    
    letsTalkWrappers.forEach(wrapper => {
      // Find the trigger button (either desktop or hamburger version)
      const btn = wrapper.querySelector('.contact-btn') || wrapper.querySelector('.hmbrgr-contact-btn');
      
      btn?.addEventListener('click', (e) => {
        if (!btn) return;
        const isExpanded = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', (!isExpanded).toString());

        // Toggle on mobile/touch only
        if (window.matchMedia('(pointer: coarse)').matches) {
          e.stopPropagation();
          // Close others
          document.querySelectorAll('.lets-talk-wrapper').forEach(w => {
            if (w !== wrapper) {
              w.classList.remove('active');
              w.querySelector('[aria-haspopup="true"]')?.setAttribute('aria-expanded', 'false');
            }
          });
          wrapper.classList.toggle('active');
        }
      });
      
      const panel = wrapper.querySelector('.lets-talk-panel');
      panel?.addEventListener('click', (e) => {
        e.stopPropagation();
      });

      // Hover handling for aria-expanded (Desktop)
      wrapper.addEventListener('mouseenter', () => {
        if (!window.matchMedia('(pointer: coarse)').matches) {
          btn?.setAttribute('aria-expanded', 'true');
        }
      });
      wrapper.addEventListener('mouseleave', () => {
        if (!window.matchMedia('(pointer: coarse)').matches) {
          btn?.setAttribute('aria-expanded', 'false');
        }
      });
    });

    // Global click-to-close
    document.addEventListener('click', () => {
      document.querySelectorAll('.lets-talk-wrapper').forEach(w => {
        w.classList.remove('active');
        w.querySelector('[aria-haspopup="true"]')?.setAttribute('aria-expanded', 'false');
      });
    });

    // Copy logic
    const copyBtns = document.querySelectorAll('.copy-btn');
    copyBtns.forEach(btn => {
      btn.addEventListener('click', async (e) => {
        e.preventDefault();
        const text = btn.getAttribute('data-copy');
        if (text) {
          try {
            await navigator.clipboard.writeText(text);
            
            // Visual feedback
            btn.classList.add('copied');
            const textSpan = btn.querySelector('.btn-text');
            const originalText = textSpan ? textSpan.textContent : '';
            
            if (textSpan) textSpan.textContent = 'Copied!';
            
            setTimeout(() => {
              btn.classList.remove('copied');
              if (textSpan) textSpan.textContent = originalText;
            }, 2000);
          } catch (err) {
            console.error('Failed to copy', err);
          }
        }
      });
    });
  }

  // Runs on initial load
  setupLetsTalk();
  // Support for view transitions if needed
  document.addEventListener('astro:after-swap', setupLetsTalk);
</script>

<style>
  @reference "../../styles/global.css";

  .lets-talk-wrapper {
    position: relative;
    display: flex; align-items: center;
  }

  .lets-talk-panel {
    position: absolute; z-index: 100;
    top: calc(100% + 4px); left: 50%;
    transform: translateX(-50%) translateY(-10px);
    background: var(--bg-color); box-shadow: var(--box-shadow);
    border: 1px solid rgba(var(--gray), 0.2); border-radius: 1.5rem;
    display: flex; flex-direction: column;
    padding: 0.4rem;
    opacity: 0; visibility: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    
    /* SYNC: Set a min-width to prevent shifting when text becomes "Copied!" */
    min-width: 220px; 
  }

  /* Bridge to keep hover active */
  .lets-talk-panel::before {
    content: '';
    position: absolute;
    top: -15px;left: 0; right: 0;
    height: 15px;
    background: transparent;
  }

  .lets-talk-wrapper:hover .lets-talk-panel,
  .lets-talk-wrapper.active .lets-talk-panel {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .lets-talk-wrapper:hover .contact-btn,
  .lets-talk-wrapper.active .contact-btn,
  .lets-talk-wrapper:hover .hmbrgr-contact-btn,
  .lets-talk-wrapper.active .hmbrgr-contact-btn {
    transform: translateY(-2px) scale(1.03);
    box-shadow: var(--box-shadow);
  }

  .panel-section {
    display: flex; flex-direction: column;
    gap: 0.2rem; padding: 0.5rem;
    width: 100%;
  }

  /* 90% width separator logic */
  .panel-section:not(:last-child) {
    position: relative;
    padding-bottom: 0.7rem;
  }

  .panel-section:not(:last-child)::after {
    content: '';
    position: absolute;
    bottom: 0; left: 5%;
    height: 1px; width: 90%;
    background: rgba(var(--gray), 0.15);
  }

  .section-label {
    font-size: 0.7rem; @apply font-bold; @apply uppercase;
    padding-left: 0.6rem; margin-bottom: 0.1rem; letter-spacing: 0.05em;
    color: var(--text-color); opacity: 0.5;
  }

  .hmbrgr-lets-talk-wrapper { justify-content: center; }

  .panel-btn {
    @apply btn-fx-txtcolor;
    width: 100%;
    white-space: nowrap;
    padding: 0.5rem 0.8rem; gap: 0.75rem;
    display: flex; justify-content: flex-start; align-items: center;
    border: none; border-radius: 0.8rem;
    background: transparent;
    color: var(--text-color); @apply txt-body-sm;
    @apply font-medium;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .panel-btn:hover { background-color: var(--bg-color-tinted); }

  /* Specific style for copy buttons */
  .copy-btn {

    justify-content: flex-start;
    @apply font-mono;
  }

  /* Icon Swap Logic */
  .icon-swap {
    position: relative;
    width: 1rem; height: 1rem;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }

  .icon-swap i { position: absolute; transition: all 0.3s ease; }
  .check-icon { opacity: 0; transform: scale(0.5); color: var(--accent-reverse);  }
  .copy-btn.copied .main-icon { opacity: 0; transform: scale(0.5); }
  .copy-btn.copied .check-icon { opacity: 1; transform: scale(1); }
  .copy-btn.copied .btn-text { color: var(--accent-reverse); }
  .contact-btn, .hmbrgr-contact-btn { @apply btn-type-main-reverse; }
  .contact-icon { display: none; }
  .hmbrgr-lets-talk-wrapper .contact-icon { display: inline-block; margin-right: 0.5rem; }

  @media (min-width: 768px) {
    .contact-icon { display: inline-block; margin-right: 0.5rem; }
  }

</style>
