---
import { LINKS } from "../../config/site.ts";
---

<div class="header-brand">
    <img src="/logo/crazyblender-sm.webp" alt="CrazyBlender icon" class="header-icon" />
    <a href={LINKS.homepage.url} aria-label={LINKS.homepage.label} title={LINKS.homepage.title} class="header-brand-link">
        <div class="name-path flx-clmn justify-start"> 
            <div class="name font-bold">Lucas Shiota</div>
            <div class="path font-light">Game Designer</div>
        </div>
    </a>
</div>

<script>
    const icon = document.querySelector<HTMLElement>('.header-icon');
    const animations = ['rock', 'spin', 'tilt-pop', 'flip-horizontal', 'pop-jump'];

    if (icon) {
        icon.addEventListener('mouseenter', () => {
            if (window.matchMedia('(pointer: fine)').matches) {
                const random = animations[Math.floor(Math.random() * animations.length)];
                icon.style.animation = `${random} 0.6s ease`;
            }
        });

        icon.addEventListener('animationend', () => {
            icon.style.animation = '';
        });
    }
</script>

<style>
    @reference "../../styles/global.css";

    .header-brand {
        @apply flx-algncntr-rw;
        height: 80%; gap: 1rem;
        justify-content: flex-start;
        justify-self: flex-start;
    }

    .header-brand-link {
        text-decoration: none;
        color: var(--text-color);
        display: flex;
        flex-direction: column;
        justify-content: center;
    }
    .header-brand-link:hover { color: var(--text-color); }

    .name, .path { @apply leading-tight txt-h6; }
    
    .header-icon {
        width: 50px; height: 50px;
        object-fit: contain; display: block; margin-left: 1rem;
        user-select: none;
        transform-origin: center; transform-style: preserve-3d;
    }

    /* Logo Animations */
    @keyframes rock {
        0%   { transform: rotate(0deg); }
        20%  { transform: rotate(30deg); }
        40%  { transform: rotate(-25deg); }
        60%  { transform: rotate(20deg); }
        80%  { transform: rotate(-10deg); }
        100% { transform: rotate(0deg); }
    }
    @keyframes spin {
        0%   { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }
    @keyframes tilt-pop {
        0%   { transform: rotate(0) scale(1); }
        25%  { transform: rotateY(40deg) rotateX(18deg) scale(1.2); }
        55%  { transform: rotateY(-30deg) rotateX(-12deg) scale(1.08); }
        75%  { transform: rotateY(15deg) rotateX(6deg) scale(1.04); }
        100% { transform: rotate(0) scale(1); }
    }
    @keyframes flip-horizontal {
        0%   { transform: rotateY(0deg); }
        50%  { transform: rotateY(180deg); }
        100% { transform: rotateY(360deg); }
    }
    @keyframes pop-jump {
        0%   { transform: scale(1); }
        30%  { transform: scale(1.25); }
        55%  { transform: scale(0.95); }
        75%  { transform: scale(1.05); }
        100% { transform: scale(1); }
    }
</style>
