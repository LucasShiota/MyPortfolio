---
const today = new Date();
---
<div class="source-grid">
    <div class="site-signature txt-h6 font-bold"> Designed & Developed by me </div>
    
    <div class="source-item"> <span class="label">Stack</span> <span class="value">Astro, Tailwind, GSAP</span> </div>
    <div class="source-item"> <span class="label">Logic</span> <span class="value">Matter.js, Vanta.js</span> </div>
    <div class="source-item"> <span class="label">External</span> <span class="value">Cloudflare, Google Antigravity</span> </div>
    <div class="source-item"> <span class="label">Assets</span> <span class="value">Font Awesome, TextureLabs</span> </div>
    <div class="source-item"> <span class="label">Fonts</span> <span class="value">Atkinson Hyperlegible Next, Notable</span> </div>

    <div class="copyright txt-h6"> &copy; {today.getFullYear()} Lucas Shiota </div>
</div>

<style>
    @reference "../../styles/global.css";

    .source-grid {
        width: 90%; max-width: 400px;
        @apply text-xs; @apply leading-loose;
        display: flex; flex-direction: column; gap: 0.4rem;
        padding: 1rem; border-top: 1px solid rgba(var(--gray), 0.1);
    }
    .site-signature {
        @apply text-left;
        color: var(--accent-reverse); 
        margin-bottom: 0.4rem;
        @apply uppercase; letter-spacing: 0.1em;
    }
    .source-item {
        display: flex; justify-content: space-between;
        border-bottom: 1px solid rgba(var(--gray), 0.05);
        padding-bottom: 0.1rem;
    }
    .source-item .label { opacity: 0.5; @apply font-bold; @apply uppercase; font-size: 0.65rem; }
    .source-item .value { @apply font-medium; color: var(--text-color); }
    
    .copyright { 
        @apply text-center font-bold;
        width: 100%;
        padding-top: 1.2rem; 
        opacity: 0.75;
        font-size: 0.65rem;
        letter-spacing: 0.05em;
    }
</style>
