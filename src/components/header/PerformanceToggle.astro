---
import HeaderIconButton from './HeaderIconButton.astro';

interface Window {
  togglePerformanceMode?: () => void;
}

const { id = "performance-toggle", class: className = "" } = Astro.props;
---

<HeaderIconButton 
  id={id} 
  class:list={["performance-toggle", className]} 
  title="Toggle performance mode"
  data-delay-toggle
>
  <i class="fa-solid fa-wand-magic icon-magic"></i>
  <i class="fa-solid fa-wand-magic-sparkles icon-sparkles"></i>
</HeaderIconButton>

<script>
  document.addEventListener('click', (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;

    const btn = target.closest('.performance-toggle');
    if (!btn) return;

    // stopPropagation to manage the toggle manually via animationend
    event.stopPropagation();

    // Reset and trigger fling
    btn.classList.remove('fling');
    void (btn as HTMLElement).offsetWidth; 
    btn.classList.add('fling');
  });

  document.addEventListener('animationend', (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;

    // Check if the animation that ended was the fling on our performance toggle
    const btn = target.closest('.performance-toggle.fling');
    if (btn) {
      btn.classList.remove('fling');
      // Now finally trigger the state switch
      (window as any).togglePerformanceMode?.();
    }
  }, { capture: true });
</script>

<style>
  @reference "../../styles/global.css";

  :global(html.mobile-device) :global(.performance-toggle) { display: none !important; }

  /* 
     Performance Toggles use an instant swap (no fade) + a Fling animation.
     We hide the inactive icon with display: none to avoid conflict.
  */
  :global(.performance-toggle i) {
    display: none;
    transition: none !important; /* "No fade" per request */
  }

  /* Show the icon corresponding to the current state */
  :global(html:not(.performance-mode)) :global(.performance-toggle .icon-sparkles) {
    display: block !important;
    pointer-events: auto !important;
  }
  :global(html.performance-mode) :global(.performance-toggle .icon-magic) {
    display: block !important;
    pointer-events: auto !important;
  }

  /* Wand Fling Animation */
  @keyframes wand-fling {
    0% { transform: scale(1) rotate(0deg); }
    30% { transform: scale(1.2) rotate(-15deg) translateX(-3px); }
    60% { transform: scale(1.1) rotate(15deg) translateX(3px); }
    100% { transform: scale(1) rotate(0deg); }
  }

  /* Trigger animation on whichever icon is currently visible */
  :global(.performance-toggle.fling) i {
    animation: wand-fling 0.5s cubic-bezier(0.2, 0.8, 0.2, 1) !important;
    z-index: 100;
  }

  /* Specific to hamburger menu context */
  :global(#hmbrgr-menu) :global(.performance-toggle i) {
    @apply text-3xl;
  }
</style>
