---
const { quote } = Astro.props;
---

<section class="mb-12">
  <h4
    class="txt-micro-label txt-color-accent border-rgba(var(--gray), 0.1) mb-6 border-b font-black uppercase"
  >
    Design Philosophy
  </h4>
  <div class="relative pl-8">
    <div class="absolute top-0 bottom-0 left-0 w-1 bg-(--brand-secondary) opacity-30"></div>
    <p class="text-2xl leading-tight font-black tracking-tight italic opacity-90">
      "{quote}"
    </p>
  </div>
</section>
