---
import SectionTitle from "../SectionTitle.astro";
const { trees } = Astro.props;
---

<div class="sheet-grid-3">
  {
    Object.entries(trees).map(([category, items]: [string, any]) => (
      <div class="sheet-section">
        <SectionTitle title={`${category} Tree`} />
        <div class="talent-nodes flx-clmn relative gap-8 pb-8">
          {items.map((item: any, i: number) => (
            <div class="talent-node flx-rw items-center gap-5">
              <div class="sheet-icon-box">
                <span class="text-sm font-black opacity-30">{i + 1}</span>
              </div>
              <div class="talent-info">
                <h5 class="mb-2 text-base leading-none font-black">{item.label}</h5>
                <span
                  class={`rounded-md px-2 py-1 text-[0.65rem] font-black uppercase ${
                    item.val === "Expert"
                      ? "bg-(--brand-secondary) text-(--bg-panel)"
                      : "sheet-badge border opacity-60"
                  }`}
                >
                  {item.val}
                </span>
              </div>
            </div>
          ))}
          <div class="sheet-line-v left-6" />
        </div>
      </div>
    ))
  }
</div>
