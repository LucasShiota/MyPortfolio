---
const { milestones } = Astro.props;
---

<section class="mb-10">
  <h4
    class="txt-micro-label txt-color-accent border-rgba(var(--gray), 0.1) mb-6 border-b font-black uppercase"
  >
    Campaign Milestones
  </h4>
  <ul class="space-y-6">
    {
      milestones.map((m: string) => (
        <li class="flx-rw group gap-6">
          <div class="mt-2 h-2 w-2 shrink-0 rounded-full bg-(--brand-secondary) transition-transform group-hover:scale-150" />
          <p class="text-base leading-normal font-bold opacity-80 transition-opacity group-hover:opacity-100">
            {m}
          </p>
        </li>
      ))
    }
  </ul>
</section>
