---
import SectionTitle from "../SectionTitle.astro";
const { title, entries = [], listStyle = "bullet", options } = Astro.props;
const finalTitle = title !== undefined ? title : options?.title;

// Normalize entries to { header?, text }
const normalizedEntries = entries.map((entry: any) => {
  if (typeof entry === "string") return { text: entry };
  if (Array.isArray(entry)) return { header: entry[0], text: entry[1] };
  return entry; // Assume object { header, text }
});
---

<div class="sheet-section mb-0!">
  <SectionTitle title={finalTitle} />

  <ul class="flx-clmn gap-2.5">
    {
      normalizedEntries.map((entry: any, i: number) => (
        <li class="flx-clmn">
          <div class={`flx-rw gap-3 ${listStyle === "number" ? "items-baseline" : "items-start"}`}>
            {/* Marker */}
            {listStyle === "number" ? (
              <span class="sheet-txt-meta txt-color-accent w-5 shrink-0 text-right">{i + 1}.</span>
            ) : (
              <div class="mt-[0.45rem] h-1.5 w-1.5 shrink-0 rounded-full bg-(--brand-secondary)" />
            )}

            {/* Content Container */}
            <div class="flex-1">
              {entry.header ? (
                <>
                  <span class="sheet-txt-meta" set:html={entry.header} />
                  {entry.text && (
                    <div
                      class="sheet-txt-body mt-1 leading-relaxed opacity-70"
                      set:html={entry.text}
                    />
                  )}
                </>
              ) : (
                <div class="sheet-txt-body leading-snug opacity-90" set:html={entry.text} />
              )}
            </div>
          </div>
        </li>
      ))
    }
  </ul>
</div>
