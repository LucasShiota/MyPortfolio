---
import SectionTitle from "../SectionTitle.astro";
const { title, traits, options } = Astro.props;
const finalTitle = title !== undefined ? title : options?.title;
---

<div class="sheet-section">
  <SectionTitle title={finalTitle} />
  {
    traits.map((trait: any) => (
      <div class="sheet-box mb-6 p-5">
        <h5 class="txt-color-accent mb-2 text-sm font-black tracking-wide uppercase">
          {trait.title}
        </h5>
        <p class="text-xs leading-relaxed font-medium opacity-70">{trait.description}</p>
      </div>
    ))
  }
</div>
