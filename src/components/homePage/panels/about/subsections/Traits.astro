---
const { traits } = Astro.props;
---

<div class="traits-summary">
  <h4 class="txt-micro-label txt-color-accent mb-6 font-black uppercase opacity-40">
    Passive Features & Traits
  </h4>
  {
    traits.map((trait: any) => (
      <div class="trait-item border-rgba(var(--gray), 0.1) bg-rgba(var(--gray), 0.02) mb-6 rounded-2xl border p-5">
        <h5 class="txt-color-accent mb-2 text-sm font-black tracking-wide uppercase">
          {trait.title}
        </h5>
        <p class="text-xs leading-relaxed font-medium opacity-70">{trait.description}</p>
      </div>
    ))
  }
</div>
