---
/**
 * ══════════════════════════════════════════════
 *  STAT BLOCK (StatBlock.astro)
 * ══════════════════════════════════════════════
 */
const { label, value } = Astro.props;
---

<div
  class="status-node flx-cntr-clmn bg-rgba(var(--brand-secondary), 0.03) rounded-xl border-2 border-(--brand-secondary) p-2 px-5"
>
  <span class="text-[0.6rem] font-black uppercase opacity-60">{label}</span>
  <span class="text-2xl font-black">{value}</span>
</div>
