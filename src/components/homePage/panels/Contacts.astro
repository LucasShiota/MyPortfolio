<section id="contacts" class="panel contacts-panel">
	<div id="matter-container"></div>
</section>

<style>
  @reference "../../../styles/global.css";


	.contacts-panel{
		height: var(--panel-height);
		position: relative;
		flex-direction: column; display: flex;
	}
	#matter-container {
		width: 100%;
		height: 100%;
		display: flex; flex-direction: column;
		touch-action: auto;
	}
	.copyright {
		position: absolute; bottom: 1%; right: -15%;
		@apply txt-body;
		pointer-events: none;
		opacity: 0.8;
	}
</style>

<script>
	import { initMatterController } from '../../features/matterjs/matterController';

	initMatterController();
</script>
