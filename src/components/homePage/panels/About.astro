---
/**
 * ══════════════════════════════════════════════
 *  ABOUT SECTION (About.astro)
 * ══════════════════════════════════════════════
 *
 * PURPOSE: "Character Sheet" bio with 3 interactive tabs (Stats, Skill Tree, Quest Log).
 */
import AboutSheet from "./AboutSheet";
---

<section id="about" class="panel about-panel flx-cntr">
  <AboutSheet client:load />
</section>

<style>
  @reference "../../../styles/global.css";

  .about-panel {
    padding: 3rem 2rem;
    height: 100vh; /* Ensure the panel occupies full height for the landscape sheet */
  }

  /* Ensure the sheet (from AboutSheet.tsx) fills the space correctly */
  :global(.trpg-sheet) {
    width: 98%;
    height: 90%;
    max-width: 1400px;
    padding: clamp(1.5rem, 3vw, 2.5rem);
    font-family: var(--font-accent);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* Responsive Adjustments */
  @media (max-width: 768px) {
    .about-panel {
      height: auto;
      padding-top: 5rem;
    }
    :global(.trpg-sheet) {
      height: auto;
      min-height: 80vh;
      overflow: visible;
    }
  }
</style>
