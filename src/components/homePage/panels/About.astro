---
/**
 * ══════════════════════════════════════════════
 *  ABOUT SECTION (About.astro)
 * ══════════════════════════════════════════════
 *
 * PURPOSE: "Character Sheet" bio built on Astro Content Collections.
 * Renders tabs driven by Markdown + YAML frontmatter.
 */
import { getCollection } from "astro:content";
import AboutHeader from "./about/AboutHeader.astro";
import AboutSectionRenderer from "./about/AboutSectionRenderer.astro";

// Fetch Content Collection
const aboutEntries = await getCollection("about");

// Separate Header global data from Tab content
const rawHeader = aboutEntries.find((e) => e.data.entryType === "header");
const rawTabs = aboutEntries
  .filter((e) => e.data.entryType === "tab")
  .sort((a, b) => (a.data.order || 0) - (b.data.order || 0));

if (!rawHeader) {
  throw new Error("About section requires a 'header' entry in the about collection.");
}
---

<section id="about" class="panel about-panel flx-cntr" data-panel="about">
  <div class="trpg-sheet surface-panel animate-fade-in">
    <!-- 🛡️ PERSISTENT GLOBAL HEADER -->
    <AboutHeader data={rawHeader.data} />

    <!-- 🧭 NAVIGATION TABS -->
    <nav class="sheet-tabs flx-rw relative z-10 mb-6 gap-8">
      {
        rawTabs.map((tab, i) => (
          <button
            data-tab-target={tab.id}
            class={`about-tab-btn txt-micro-label border-b-2 px-6 py-2 transition-all duration-300 ${
              i === 0
                ? "txt-color-accent is-active border-(--brand-secondary) opacity-100"
                : "border-transparent opacity-40 hover:opacity-70"
            }`}
          >
            {tab.data.label}
          </button>
        ))
      }
    </nav>

    <!-- 🖼️ UNIFIED "MASTER SYSTEM" VIEWPORT -->
    <div class="sheet-viewport relative min-h-0 flex-1 overflow-hidden">
      {
        rawTabs.map((tab, i) => (
          <div
            id={`tab-content-${tab.id}`}
            class={`tab-content absolute inset-0 h-full w-full overflow-y-auto transition-opacity duration-300 ${i === 0 ? "pointer-events-auto z-10 opacity-100" : "pointer-events-none z-0 opacity-0"}`}
          >
            {/* Unified 4x3 Grid Layout */}
            <div class="sheet-main-grid">
              {tab.data.sections?.map((section) => (
                <AboutSectionRenderer section={section} />
              ))}
            </div>
          </div>
        ))
      }
    </div>

    <!-- ⚡ VANILLA JS TAB LOGIC -->
    <script>
      function initAboutTabs() {
        const buttons = document.querySelectorAll(".about-tab-btn");
        const contents = document.querySelectorAll(".tab-content");

        if (!buttons.length) return;

        buttons.forEach((btn) => {
          btn.addEventListener("click", (e) => {
            const targetId = (e.currentTarget as HTMLButtonElement).dataset.tabTarget;

            // Reset all
            buttons.forEach((b) => {
              b.classList.remove(
                "border-(--brand-secondary)",
                "txt-color-accent",
                "opacity-100",
                "is-active"
              );
              b.classList.add("border-transparent", "opacity-40");
            });
            contents.forEach((c) => {
              c.classList.remove("opacity-100", "pointer-events-auto", "z-10");
              c.classList.add("opacity-0", "pointer-events-none", "z-0");
            });

            // Activate Target
            (e.currentTarget as HTMLButtonElement).classList.remove(
              "border-transparent",
              "opacity-40"
            );
            (e.currentTarget as HTMLButtonElement).classList.add(
              "border-(--brand-secondary)",
              "txt-color-accent",
              "opacity-100",
              "is-active"
            );

            const targetContent = document.getElementById(`tab-content-${targetId}`);
            if (targetContent) {
              targetContent.classList.remove("opacity-0", "pointer-events-none", "z-0");
              targetContent.classList.add("opacity-100", "pointer-events-auto", "z-10");
            }
          });
        });
      }

      // Initialize on load and on Astro view transitions
      document.addEventListener("astro:page-load", initAboutTabs);
      if (document.readyState === "complete") {
        initAboutTabs();
      } else {
        document.addEventListener("DOMContentLoaded", initAboutTabs);
      }
    </script>
  </div>
</section>

<style>
  @reference "../../../styles/global.css";

  .about-panel {
    padding-top: var(--header-height);
    padding-left: 1rem;
    padding-right: 1rem;
    height: 100vh;
    overflow: hidden;
  }

  .trpg-sheet {
    /* Specific overrides if any */
  }

  .animate-fade-in {
  }
</style>
