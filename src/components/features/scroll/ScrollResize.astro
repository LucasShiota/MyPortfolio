<script>
	interface Window {
		performanceModeScroll?: any;
		__performanceModeEnabled?: boolean;
	}

	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";
	import { ScrollToPlugin } from "gsap/ScrollToPlugin";
	gsap.registerPlugin(ScrollTrigger, ScrollToPlugin);

	const panels = gsap.utils.toArray<HTMLElement>(".panel");
	const totalSteps = panels.length - 1;
	const step = totalSteps > 0 ? 1 / totalSteps : 1;
	
	let isResizing = false;
	let resizeTimeout: number | null = null;
	let preResizeActiveIndex = 0;

	/* ------- PAGE REFRESH CORRECTIONS --------- */
  window.addEventListener("load", () => {
    // Give the layout a heartbeat to settle before refreshing triggers
    setTimeout(() => {
	  ScrollTrigger.refresh();
    }, 100);
  });

	/* ------- RESIZE LOGIC --------- */
	window.addEventListener("resize", () => {
		if (!isResizing) {
			isResizing = true;
			// Store current panel progress
			const currentProgress = ScrollTrigger.getAll()[0]?.progress || 0; // Guessing the first trigger is fine, but more robust to calculate from scrollY
			const scrollY = window.scrollY;
			const maxScroll = document.body.scrollHeight - window.innerHeight;
			const progressRatio = maxScroll > 0 ? scrollY / maxScroll : 0;
			preResizeActiveIndex = Math.round(progressRatio / step);
			
			// Disable snapping if bridge exists
			window.performanceModeScroll?.disableSnap?.();
		}

		if (resizeTimeout) window.clearTimeout(resizeTimeout);
		
		resizeTimeout = window.setTimeout(() => {
			isResizing = false;
			ScrollTrigger.refresh();
			
			// Force back to the correct panel position
			const targetProgress = preResizeActiveIndex * step;
			const targetY = targetProgress * (document.body.scrollHeight - window.innerHeight);
			gsap.set(window, { scrollTo: { y: targetY } });
			
			// Re-enable snapping if bridge exists
			if (!window.__performanceModeEnabled) {
				window.performanceModeScroll?.enableSnap?.();
			}
		}, 150);
	});

    /* ------- GLOBAL CLEANUP --------- */
	window.addEventListener("beforeunload", () => {
		ScrollTrigger.getAll().forEach(t => t.kill());
		window.performanceModeScroll = undefined;
	}, { once: true });
</script>
