---
/**
 * ══════════════════════════════════════════════
 *  VANTA FOG BACKGROUND (VantaFogBG.astro)
 * ══════════════════════════════════════════════
 *
 * PURPOSE: Implements the interactive fog background using Three.js and Vanta.js.
 *
 * CRITICAL RULES:
 * - Uses Three.js v0.134.0 (pinned) for legacy Vanta shader compatibility.
 * - Passes bundled THREE instance to Vanta to avoid global collisions.
 * - Handles performance mode by destroying/resuming the effect.
 */
---

<div id="vanta-bg"></div>
<style>
  #vanta-bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    background-color: var(--wallpaper);
    transition: background-color 0.5s ease;
  }
  html.performance-mode #vanta-bg {
    background-image: none !important;
    background-color: var(--wallpaper);
  }
</style>

<script>
  import * as THREE from "three";
  import FOG from "vanta/dist/vanta.fog.min.js";

  const vantaBgSelector = "#vanta-bg";

  function initVanta() {
    // Check if performance mode is enabled or if an effect already exists
    const isPerformanceMode =
      document.documentElement.classList.contains("performance-mode") ||
      window.__performanceModeEnabled;

    if (isPerformanceMode || window.vantaEffect) return;

    const css = getComputedStyle(document.documentElement);
    const hexToNumber = (hex: string) => Number(hex.trim().replace("#", "0x"));

    try {
      (window as any).THREE = THREE; // Ensure global availability for older Vanta builds
      window.vantaEffect = FOG({
        el: vantaBgSelector,
        THREE: THREE, // Pass the bundled Three.js instance
        mouseControls: true,
        touchControls: true,
        gyroControls: false,
        minHeight: 200.0,
        minWidth: 200.0,
        highlightColor: hexToNumber(css.getPropertyValue("--vanta-highlight")),
        midtoneColor: hexToNumber(css.getPropertyValue("--vanta-midtone")),
        lowlightColor: hexToNumber(css.getPropertyValue("--vanta-lowlight")),
        baseColor: hexToNumber(css.getPropertyValue("--vanta-base")),
        blurFactor: 0.9,
        speed: 0.7,
        zoom: 0.8,
        scale: 1,
        scaleMobile: 0.6,
      });
    } catch (err) {
      console.error("[VANTA] Failed to initialize:", err);
    }
  }

  function stopVanta() {
    if (window.vantaEffect?.destroy) {
      window.vantaEffect.destroy();
    }
    delete window.vantaEffect;
  }

  function startVanta() {
    stopVanta();
    initVanta();
  }

  window.performanceModeVanta = {
    freeze: stopVanta,
    resume: startVanta,
  };

  window.addEventListener("startup:vanta", () => {
    startVanta();
  });
</script>
