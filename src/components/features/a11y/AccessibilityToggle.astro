---
import HeaderIconButton from "../../site/HeaderIconButton.astro";
import PopUpPanel from "../../site/PopUpPanel.astro";

interface Props {
  id?: string;
  class?: string;
  isHamburger?: boolean;
}

const { id = "accessibility-toggle", class: className = "", isHamburger = false } = Astro.props;
---

<PopUpPanel isHamburger={isHamburger} wrapperClass="accessibility-wrapper">
  <HeaderIconButton
    slot="trigger"
    id={id}
    class:list={["accessibility-btn", className]}
    title="Accessibility Options"
    aria-haspopup="true"
    aria-expanded="false"
  >
    <i class="fa-solid fa-universal-access"></i>
  </HeaderIconButton>

  <!-- Section 1: Auto Scroll Explanation -->
  <div class="panel-section">
    <span class="section-label"><i class="fa-solid fa-arrows-up-down"></i> Quick Navigation</span>
    <div class="panel-btn info-item">
      <i class="fa-solid fa-keyboard"></i>
      <span><b class="key">Space</b> scrolls down, <b class="key">Shift + Space</b> up.</span>
    </div>
  </div>

  <!-- Section 2: Adjustments -->
  <div class="panel-section">
    <span class="section-label"><i class="fa-solid fa-sliders"></i> Adjustments</span>

    <div class="a11y-adjustment-row">
      <div class="adjustment-info">
        <i class="fa-solid fa-person-running"></i>
        <span>Reduced Motion</span>
      </div>
      <button
        class="reduced-motion-toggle btn-type-toggle"
        role="switch"
        aria-checked="false"
        aria-label="Toggle reduced motion"
      >
        <span class="toggle-thumb"></span>
      </button>
    </div>

    <div class="a11y-adjustment-row">
      <div class="adjustment-info">
        <i class="fa-solid fa-circle-half-stroke"></i>
        <span>Clarity Mode</span>
      </div>
      <button
        class="clarity-toggle btn-type-toggle"
        role="switch"
        aria-checked="false"
        aria-label="Toggle clarity mode"
      >
        <span class="toggle-thumb"></span>
      </button>
    </div>
  </div>
</PopUpPanel>

<style>
  @reference "../../../styles/global.css";

  .key {
    background: rgba(var(--gray), 0.15);
    padding: 0.1rem 0.3rem;
    border-radius: 0.3rem;
    border-bottom: 2px solid rgba(var(--gray), 0.3);
    font-size: 0.85em;
    @apply font-mono;
  }

  .info-item {
    cursor: help;
  }

  .a11y-adjustment-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.6rem 0.8rem;
    gap: 1rem;
    color: var(--text-color);
  }

  .adjustment-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.95rem;
    @apply font-medium;
  }

  /* Specific to hamburger menu context */
  :global(#hmbrgr-menu) :global(.accessibility-btn i) {
    @apply text-3xl;
  }
</style>
