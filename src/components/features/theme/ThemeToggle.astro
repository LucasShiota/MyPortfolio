---
import HeaderIconButton from '../../site/HeaderIconButton.astro';

interface Props {
  id?: string;
  class?: string;
}

const { id = "theme-toggle", class: className = "" } = Astro.props;
---

<HeaderIconButton id={id} class:list={["theme-toggle", className]} title="Toggle theme">
  <i class="fa-solid fa-sun icon-sun hidden-icon"></i>
  <i class="fa-solid fa-moon icon-moon hidden-icon"></i>
</HeaderIconButton>

<style>
  @reference "../../../styles/global.css";

  /* 
     Visibility logic: tie it to the HTML data-theme state.
     The icons use the 'hidden-icon' base from HeaderIconButton for the fade effect.
  */
  :global(html:not([data-theme="dark"])) :global(.theme-toggle .icon-sun),
  :global(html[data-theme="dark"]) :global(.theme-toggle .icon-moon) {
    opacity: 1 !important;
    transform: scale(1) rotate(0deg) !important;
    pointer-events: auto !important;
  }

  /* Specific to hamburger menu context */
  :global(#hmbrgr-menu) :global(.theme-toggle i) {
    @apply text-3xl;
  }
</style>
