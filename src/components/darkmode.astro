---
<button id="theme-toggle">
  <i class="fa-solid fa-moon"></i>
</button>
<script is:inline>
  const root = document.documentElement;
  const toggleBtn = document.getElementById('theme-toggle');
  const icon = toggleBtn.querySelector('i');

  let vantaEffect; // make sure this is assigned when you init Vanta

  function getHex(varName) {
    return getComputedStyle(root)
      .getPropertyValue(varName)
      .trim();
  }

  function hexToRgb(hex) {
    const bigint = parseInt(hex.replace('#', ''), 16);
    return [
      (bigint >> 16) & 255,
      (bigint >> 8) & 255,
      bigint & 255
    ];
  }

  function rgbToHex(r, g, b) {
    return (Math.round(r) << 16) | (Math.round(g) << 8) | Math.round(b);
  }

  function lerp(a, b, t) {
    return a + (b - a) * t;
  }

  function animateVanta(duration = 800) {
    if (!vantaEffect) return;

    const start = performance.now();

    const fromHighlight = hexToRgb(getHex('--vanta-highlight'));
    const fromMid = hexToRgb(getHex('--vanta-midtone'));
    const fromLow = hexToRgb(getHex('--vanta-lowlight'));
    const fromBase = hexToRgb(getHex('--vanta-base'));

    function step(time) {
      const t = Math.min((time - start) / duration, 1);
      const eased = 1 - Math.pow(1 - t, 3);

      const toHighlight = hexToRgb(getHex('--vanta-highlight'));
      const toMid = hexToRgb(getHex('--vanta-midtone'));
      const toLow = hexToRgb(getHex('--vanta-lowlight'));
      const toBase = hexToRgb(getHex('--vanta-base'));

      const h = fromHighlight.map((c,i)=>lerp(c,toHighlight[i],eased));
      const m = fromMid.map((c,i)=>lerp(c,toMid[i],eased));
      const l = fromLow.map((c,i)=>lerp(c,toLow[i],eased));
      const b = fromBase.map((c,i)=>lerp(c,toBase[i],eased));

      vantaEffect.setOptions({
        highlightColor: rgbToHex(...h),
        midtoneColor: rgbToHex(...m),
        lowlightColor: rgbToHex(...l),
        baseColor: rgbToHex(...b)
      });

      if (t < 1) requestAnimationFrame(step);
    }

    requestAnimationFrame(step);
  }

  toggleBtn.addEventListener('click', () => {

    // 1️⃣ Toggle theme FIRST (CSS handles UI colors)
    const isDark = root.getAttribute('data-theme') === 'dark';

    if (isDark) {
      root.removeAttribute('data-theme');
    } else {
      root.setAttribute('data-theme', 'dark');
    }

    // 2️⃣ Update icon
    if (isDark) {
      icon.classList.remove('fa-moon');
      icon.classList.add('fa-sun');
    } else {
      icon.classList.remove('fa-sun');
      icon.classList.add('fa-moon');
    }

    // 3️⃣ Animate Vanta separately
    animateVanta(800);
  });
</script>


<style>
  /* -------- BUTTON STYLES -------- */
  #theme-toggle {
    position: fixed;
    width: 50px; height: 50px;
    top: 10px; right: 15px;
    border-radius: 50%;
    background: transparent; border: transparent;
    
    display: flex;
    align-items: center; justify-content: center;
    
    cursor: pointer;
    transition: background 0.3s;
    z-index: 30;
  }

  /* optional hover effect */
  #theme-toggle:hover {
    background: rgba(var(--gray), 0.3);
  }

  /* -------- ICON STYLES -------- */
  #theme-toggle i {
    color: var(--text-color);
    font-size: 1.5rem;
    transition: color 0.3s, transform 0.3s;
  }
</style>