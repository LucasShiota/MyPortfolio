---
interface Props {
  sections: {
    id: string;
    label: string;
  }[];
}

const { sections } = Astro.props;
---

<div class="jump-to-container">
  <!-- Mobile Toggle Button -->
  <button id="jump-toggle" class="jump-toggle" aria-expanded="false" aria-label="Toggle section navigation">
    <i class="fa-solid fa-list-ul"></i>
    <span> Sections </span>
    <i class="fa-solid fa-chevron-up chevron"></i>
  </button>

  <a href="/#projects" class="standalone-back-btn btn-fx-txtcolor">
    <i class="fa-solid fa-arrow-left"></i> All Projects
  </a>

  <!-- Navigation Menu -->
  <nav id="jump-nav" class="jump-nav">
    <div class="nav-header">
      <i class="fa-solid fa-list-ul"></i>
      <span>Sections</span>
    </div>
    <ul class="nav-list" id="nav-list">
      {sections.map(({ id, label }, index) => (
        <li>
          <a href={`#${id}`} class="nav-link" data-section={id}>
            <i class="fa-solid fa-location-arrow fa-rotate-by active-arrow" style="--fa-rotate-angle: 45deg;"></i>
            <span class="nav-label">
              {index === 0 ? label : `${index}. ${label}`}
            </span>
          </a>
        </li>
      ))}
    </ul>
  </nav>
</div>

<script>
  import { initJumpToController } from "../../scripts/ui/jumpToController";
  import { initSectionTracker } from "../../scripts/ui/sectionTracker";
  
  initJumpToController();
  initSectionTracker();
</script>

<style>
  @reference "../../styles/global.css";

  /* Desktop layout: Fixed on the left */
  @media (min-width: 1024px) {
    .jump-to-container {
      position: fixed;
      /* Keep it pinned to the edge of the 1400px max-width container */
      left: max(2rem, calc(50vw - 700px + 2rem));
      top: calc(var(--header-height) + 2rem);

      width: clamp(150px, 12vw, 220px);
      display: flex;
      flex-direction: column;
      gap: 1rem;
      
    }

    .jump-toggle {
      display: none; /* Hide toggle button on desktop */
    }

    .jump-nav {
      @apply surface-panel;
      padding: 1.5rem 1rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .nav-header {
      @apply txt-color-accent font-bold txt-body;
      letter-spacing: 0.05em;
      padding-bottom: 0.5rem;
      border-bottom: var(--border);
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
  }

  /* Mobile/Tablet Layout: Bottom centered pill */  
  @media (max-width: 1023px) {
    .jump-to-container {
      position: fixed;
      bottom: 2rem;
      left: 50%;
      transform: translateX(-50%);
      z-index: 15; /* Render below hamburger menu (z-index: 20) */
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
    }

    .jump-toggle {
      @apply btn-type-main;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding-right: clamp(1.5rem, 2vw, 2.5rem); padding-left: clamp(1.5rem, 2vw, 2.5rem);
      @apply font-semibold;
      @apply txt-body;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
      transition: transform 0.3s ease, background 0.3s ease;
      z-index: 2;
    }

    .jump-toggle:active {
      transform: scale(0.95);
    }

    .jump-toggle .chevron {
      transition: transform 0.3s ease;
    }

    .jump-toggle[aria-expanded="true"] .chevron {
      transform: rotate(180deg);
    }

    .jump-nav {
      @apply surface-panel;
      position: absolute;
      bottom: calc(100% + 1rem); /* Pop upwards */
      padding: 1rem;
      width: max-content;
      min-width: 200px;
      opacity: 0;
      visibility: hidden;
      transform: translateY(20px);
      transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      z-index: 1;
    }

    .jump-nav.is-open {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }

    .nav-header {
      display: none; /* Hide header on mobile, toggle button serves this role */
    }
  }

  /* Shared List Styles */
  .nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .nav-link {
    text-decoration: none;
    color: var(--text-color);
    @apply txt-body-sm;
    @apply font-medium;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.75rem;
    border-radius: 8px;
    transition: all 0.2s ease;
    opacity: 0.7;
    position: relative;
    overflow: hidden;
  }

  .nav-label {

    font-size: 0.85em;
    transition: transform 0.2s ease;
  }

  .nav-link:hover, .nav-link.active {
    background: rgba(var(--gray), 0.1);
    color: var(--accent-reverse);
    opacity: 1;
  }

  /* Active Indicator Arrow */
  .active-arrow {
    display: inline-block;
    width: 0;
    overflow: hidden;
    white-space: nowrap;
    opacity: 0;
    transform: translateX(-10px) rotate(45deg) scale(0.3); 
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    color: var(--accent-reverse);
  }

  .nav-link.active .active-arrow {
    width: 0.8rem;
    margin-right: 0.4rem;
    opacity: 1;
    transform: translateX(0) rotate(45deg) scale(0.7); /* Smaller scale when active */
  }

  .nav-link.active .nav-label {
    font-weight: bold;
  }

  .standalone-back-btn {
    color: var(--text-color);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    @apply font-semibold;
    text-decoration: none;
    transition: transform 0.3s ease, color 0.3s ease;
  }

  .standalone-back-btn:hover {
    transform: translateX(-5px);
  }

  @media (max-width: 1023px) {
    .standalone-back-btn {
      display: none; /* Hide standard standalone back button on mobile since nav acts differently */
    }
  }
</style>
