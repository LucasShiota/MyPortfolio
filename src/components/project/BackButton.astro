---
interface Props {
  href?: string;
  label?: string;
}

const { href = "/", label = "Back to Portfolio" } = Astro.props;
---

<nav class="back-nav">
  <a href={href} class="back-btn btn-fx-txtcolor">
    <i class="fa-solid fa-arrow-left"></i> {label}
  </a>
</nav>

<style>
  @reference "../../styles/global.css";

  .back-nav {
    margin-bottom: -2rem;
    position: relative;
    z-index: 10;
  }

  .back-btn {
    
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;  
    @apply font-semibold;
    @apply txt-body-lg;
    transition: transform 0.3s ease, color 0.3s ease;
  }

  .back-btn:hover {
    transform: translateX(-5px);
  }
</style>
