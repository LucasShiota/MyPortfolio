---
import ProjectSection from './ProjectSection.astro';

interface Props {
  projectTitle: string;
  id?: string;
  order?: number;
  total?: number;
}

const { projectTitle, id = "coming-soon", order, total } = Astro.props;
---

<ProjectSection title="More Details Coming Soon" id={id} order={order} total={total}>
  <p class="coming-soon-text">
    I am currently compiling the full documentation for {projectTitle}. This section will eventually include deeper dives into the system design, mechanics, and process.
  </p>
</ProjectSection>

<style>
  @reference "../../styles/global.css";
  
  .coming-soon-text {
    @apply text-center leading-loose;
    max-width: 800px;
    margin: 0 auto;
    opacity: 0.9;
  }
</style>
