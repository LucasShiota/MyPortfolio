---
interface Props {
  title: string;
  subtitle: string;
  tags?: string[];
  heroImage: string;
  logo?: string;
  id?: string;
}

const { title, subtitle, tags = [], heroImage, logo, id = "intro" } = Astro.props;
---

<section class="hero-section" id={id}>
  <div class="hero-content">
    <header class="project-header">
      {logo && (
        <div class="logo-container">
          <img src={logo} alt={`${title} Logo`} class="project-logo" />
        </div>
      )}
      <h1 class="project-title">{title}</h1>
      <p class="project-subtitle">{subtitle}</p>
      {tags.length > 0 && (
        <div class="tags-container">
          {tags.map(tag => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>
  </div>
  <div class="hero-image-container">
    <img src={heroImage} alt={title} class="hero-image" />
  </div>
</section>

<style>
  @reference "../../styles/global.css";

  .hero-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    min-height: 60vh;
    scroll-margin-top: calc(var(--header-height) + 2rem);
  }

  @media (max-width: 1024px) {
    .hero-section {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 2rem;
    }
  }

  .project-header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  @media (max-width: 1024px) {
    .project-header {
      align-items: center;
    }
  }

  .logo-container {
    width: 120px;
    height: 120px;
    margin-bottom: 1rem;
  }

  .project-logo {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .project-title {
    font-family: "Notable", sans-serif;
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    line-height: 1.1;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    color: var(--accent-reverse);
  }

  .project-subtitle {
    font-size: 1.5rem;
    opacity: 0.8;
    font-weight: 300;
    margin: 0;
  }

  .tags-container {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .tag {
    @apply descriptor-tag;
  }

  .hero-image-container {
    width: 100%;
    height: 100%;
    max-height: 500px;
    border-radius: 40px;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
    transform: perspective(1000px) rotateY(-5deg);
    /* Hover removed per request */
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 768px) {
    .hero-image-container {
      transform: none;
    }
    
    .tags-container {
      justify-content: center; /* Center tags on mobile */
    }
  }
</style>
