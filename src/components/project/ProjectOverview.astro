---
import ProjectSection from './ProjectSection.astro';

interface Props {
  description: string;
  id?: string;
  order?: number;
  total?: number;
}

const { description, id = "overview", order, total } = Astro.props;
---

<ProjectSection title="Overview" icon="fa-solid fa-circle-info" id={id} order={order} total={total}>
  <p class="main-description">{description}</p>
</ProjectSection>

<style>
  @reference "../../styles/global.css";

  .main-description {
    @apply text-center leading-loose;
    max-width: 800px;
    margin: 0 auto;
  }
</style>
