---
import ProjectSection from './ProjectSection.astro';

interface Props {
  description: string;
  id?: string;
  order?: number;
  isSubsection?: boolean;
  parentOrder?: number;
}

const { 
  description, 
  id = "overview", 
  order, 
  isSubsection = false,
  parentOrder
} = Astro.props;
---

<ProjectSection 
  title="Overview" 
  icon="fa-solid fa-circle-info" 
  id={id} 
  order={order} 
  isSubsection={isSubsection}
  parentOrder={parentOrder}
>
  <p class="main-description">{description}</p>
</ProjectSection>

<style>
  @reference "../../styles/global.css";

  .main-description {
    @apply text-center leading-loose;
    max-width: 800px;
    margin: 0 auto;
  }
</style>
