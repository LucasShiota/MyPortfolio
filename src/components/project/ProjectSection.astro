---
interface Props {
  title: string;
  icon?: string;
  id?: string;
  order?: number;
  isSubsection?: boolean;
  parentOrder?: number;
}

const { 
  title, 
  icon, 
  id, 
  order, 
  isSubsection = false, 
  parentOrder 
} = Astro.props;
---

<section class={`project-section ${isSubsection ? 'subsection' : ''}`} id={id}>
  <div class="panel-card">
    <div class="section-title">
      <div class="title-left">
        {icon && <i class={`${icon} title-icon ${isSubsection ? 'sub-icon' : ''}`}></i>}
        <h2>{title}</h2>
      </div>
      {order && (
        <div class="section-counter">
          {isSubsection ? `${parentOrder}.${order}` : `${order}`}
        </div>
      )}
    </div>
    <div class="content-wrapper">
      <slot />
    </div>
  </div>
</section>

<style>
  @reference "../../styles/global.css";

  .project-section {
    scroll-margin-top: calc(var(--header-height) + 2.5rem);
    width: 100%;
  }

  .project-section.subsection {
    padding-left: 2rem;
  }

  .project-section.subsection .panel-card {
    padding: 1.5rem;
    padding-bottom: 0.5rem;
    position: relative;
  }

  /* Hierarchical Left Bar as a pseudo-element for height control */
  .project-section.subsection .panel-card::before {
    content: "";
    position: absolute;
    left: 0;
    top: 5%; /* Start at 5% */
    height: 90%; /* End at 95% (total 90% height) */
    width: 4px;
    background: color-mix(in srgb, var(--accent-reverse) 40%, transparent); /* Lighter accent */
    border-radius: 99px;
  }

  .subsection .section-title {
    margin-bottom: 0.75rem;
  }

  .subsection .section-title h2 {
    @apply txt-body font-bold;
    opacity: 1; /* Reset to full opacity */
  }

  .sub-icon {
    font-size: 0.9em;
    opacity: 1; /* Reset to full opacity */
    color: var(--accent-reverse);
  }

  .panel-card {
    @apply surface-panel;
    padding: 2rem; 
    display: flex; flex-direction: column;
    position: relative;
  }

  .section-title {
    @apply txt-h4;
    display: flex; justify-content: space-between; align-items: baseline;
    width: 100%;
    margin-bottom: 1rem;
    position: relative;
  }

  .title-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .title-icon {
    color: var(--accent-reverse);
  }

  .section-title h2 {
    @apply uppercase txt-color-accent font-bold; 
    margin: 0;
    letter-spacing: 0.02em;
  }

  .section-counter {
    @apply font-mono txt-body-sm font-bold;
    opacity: 0.4;
    letter-spacing: 0.1em;
    position: absolute;
    top: 0;
    right: 0;
  }

  .content-wrapper {
    width: 100%;
  }

  @media (max-width: 768px) {
    .panel-card {
      padding: 1.5rem;
    }
    
    .section-title {
      align-items: center;
    }

    .section-title h2 {
      @apply txt-body;
    }
  }
</style>
