---
interface Props {
  title: string;
  icon?: string;
  id?: string;
}

const { title, icon, id } = Astro.props;
---

<section class="project-section" id={id}>
  <div class="panel-card">
    <div class="section-title">
      {icon && <i class={icon}></i>}
      <h2>{title}</h2>
    </div>
    <div class="content-wrapper">
      <slot />
    </div>
  </div>
</section>

<style>
  @reference "../../styles/global.css";

  .project-section {
    scroll-margin-top: calc(var(--header-height) + 2rem);
    width: 100%;
  }

  .panel-card {
    @apply surface-panel;
    padding: 2rem; gap: 1rem;
    display: flex; flex-direction: column;
  }

  .section-title {
    @apply txt-h4;
    display: flex; justify-content: center; align-items: center;
    width: 100%;
    border-bottom: var(--border);
    padding-bottom: 1rem;
  }

  .section-title h2 {
    @apply uppercase txt-color-accent font-bold; 
    margin: 0;
  }

  .content-wrapper {
    width: 100%;
  }

  @media (max-width: 768px) {
    .panel-card {
      padding: 1.5rem;
    }
    
    .section-title {
      flex-direction: column;
      @apply text-center;
      gap: 0.5rem;
    }
  }
</style>
