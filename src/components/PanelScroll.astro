<script>
	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";
	import { ScrollToPlugin } from "gsap/ScrollToPlugin";

	gsap.registerPlugin(ScrollTrigger, ScrollToPlugin);

	const upArrow = document.querySelector<HTMLElement>(".fa-angle-up");
	const downArrow = document.querySelector<HTMLElement>(".fa-angle-down");
	const sidebarElements = document.querySelectorAll<HTMLElement>(".nav-section, .nav-circle");
	const panels = gsap.utils.toArray<HTMLElement>(".panel");

	const totalSteps = panels.length - 1;
	const step = 1 / totalSteps;

	let currentIndex = 0;

	/* ------- PAGE REFRESH CORRECTIONS --------- */

  window.addEventListener("load", () => {
    window.scrollTo(0, 0);
		// Force ScrollTrigger to recalc and update immediately
		ScrollTrigger.refresh();
		mainTrigger.update();
  });
	function updateUI(progress: number) {
		const scrollPercent = progress * 100;

		currentIndex = Math.round(progress / step);

		updateArrowVisibility();

		sidebarElements.forEach((el, i) => {
			const delta = Math.abs(scrollPercent - elementPercentages[i]);
			const scale = 1.5 - Math.min(delta / 30, 1) * 0.5;
			el.style.transform = `scale(${scale})`;
		});
	}
	/* ------- SIDEBAR SETUP --------- */

	const totalItems = sidebarElements.length;
	const elementPercentages = Array.from(sidebarElements).map(
		(_, i) => (i / (totalItems - 1)) * 100
	);

	/* ------- MASTER SCROLLTRIGGER --------- */

	const mainTrigger = ScrollTrigger.create({
		id: "mainpage",
		trigger: document.body,
		start: "top top",
		end: "bottom bottom",
		scrub: 1,
		onUpdate: (self) => {
			updateUI(self.progress);
		},
		snap: {
			directional: false,
			snapTo: (progress) => {
				const closestIndex = Math.round(progress / step);
				const delta = (progress - closestIndex * step) / step;
				const threshold = 0.1;

				const targetIndex =
					Math.abs(delta) > threshold
						? closestIndex + (delta > 0 ? 1 : -1)
						: closestIndex;

				return gsap.utils.clamp(0, 1, targetIndex * step);
			},
			duration: { min: 0.2, max: 0.4 },
			delay: 0.03,
			ease: "power1.inOut"
		}
	});

	/* ------- CENTRAL SCROLL FUNCTION --------- */

	function scrollToIndex(index: number) {
		const clamped = gsap.utils.clamp(0, totalSteps, index);
		const targetProgress = clamped * step;

		gsap.to(window, {
			duration: 0.8,
			scrollTo: {
				y:
					targetProgress *
					(document.body.scrollHeight - window.innerHeight)
			},
			ease: "power2.inOut"
		});
	}

	/* ------- NAV CLICK --------- */

	document.querySelectorAll<HTMLElement>(".nav-section").forEach(
		(section) => {
			section.style.cursor = "pointer";

			section.addEventListener("click", () => {
				const index = Number(section.dataset.index) / 2;
				scrollToIndex(index);
			});
		}
	);

	/* ------- ARROWS --------- */

	upArrow?.addEventListener("click", () => { scrollToIndex(currentIndex - 1); });
	downArrow?.addEventListener("click", () => { scrollToIndex(currentIndex + 1); });

	function updateArrowVisibility() {
		if (!upArrow || !downArrow) return;

		const atTop = currentIndex === 0;
		const atBottom = currentIndex === totalSteps;

		gsap.to(upArrow, { autoAlpha: atTop ? 0 : 0.6, duration: 0.3 });
		gsap.to(downArrow, { autoAlpha: atBottom ? 0 : 0.6, duration: 0.3 });
	}

	updateArrowVisibility();
	updateUI(mainTrigger.progress);
</script>
