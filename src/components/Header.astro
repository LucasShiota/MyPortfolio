---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import DarkMode from './DarkMode.astro';
---
<header>
	<div class="header-left">
		<div class="name">Lucas Shiota</div>
			<img src="/crazyblender-sm.webp" alt="CrazyBlender icon" class="header-icon" />
		<div class="path">Designer</div>
	</div>
	<button id="theme-toggle">
		<i class="fa-solid fa-moon"></i>
	</button>
	<DarkMode />

</header>

<style>
	/* Header Container */
	:root{
		--header-height: 4rem;
	}
	header {
		position: fixed; z-index: 20;
		height: var(--header-height); width: 100%;
		margin: 0; padding: 0 1em;
		background: var(--bg-color); box-shadow: var(--box-shadow);
		display: flex; flex-direction: row;
 		align-items: center; justify-content: space-between;
		font-weight: bold;
	}

	.header-icon {
		width: 50px;
		height: 50px;
		object-fit: contain;
		display: block;
	}
	/* Header Text */
	.header-left {
		width: 30%;
		display: flex; flex-direction: row;
  	gap: 2em;
  	align-items: center;
	}
	.name {
		font-size: 1rem;
		white-space: nowrap;
	}
	.path {
		font-size: 1rem;
	}

	#theme-toggle {
    width: 50px; height: 50px;
    border-radius: 50%;
    background: transparent; border: transparent;
    margin: 0 2em 0 2em;
    display: flex;
    align-items: center; justify-content: center;
    cursor: pointer;
    transition: background 0.3s;
    z-index: 30;
  }
	  #theme-toggle:hover {
    background: rgba(var(--gray), 0.3);
  }
  #theme-toggle i {
    color: var(--text-color);
    font-size: 1.5rem;
    transition: color 0.3s, transform 0.3s;
  }
</style>
