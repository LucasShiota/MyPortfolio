---
/**
 * ══════════════════════════════════════════════
 *  HEADER COMPONENT
 * ══════════════════════════════════════════════
 *
 * PURPOSE: Main navigation header for the site, containing branding, contact links, actions, and UI toggles.
 *
 * CRITICAL RULES:
 * - Layout depends on var(--header-height)
 * - Toggles are hidden on smaller screens and visible on larger screens
 */
import DarkMode from "../../features/theme/DarkMode.astro";
import PerformanceMode from "../../features/performance/PerformanceMode.astro";
import LetsTalk from "./LetsTalk.astro";
import HeaderHamburger from "./HeaderHamburger.astro";
import HeaderLogo from "./HeaderLogo.astro";
import ThemeToggle from "../../features/theme/ThemeToggle.astro";
import PerformanceToggle from "../../features/performance/PerformanceToggle.astro";
import AccessibilityToggle from "../../features/a11y/AccessibilityToggle.astro";
import ReducedMotion from "../../features/a11y/ReducedMotion.astro";
import { LINKS } from "../../../config/site";

const pathname = Astro.url.pathname;
const isHome = pathname === "/" || pathname === "";
---

<header class="flx-cntr-rw surface-panel">
  <HeaderLogo />
  <div class="header-contacts">
    <div class="contact-btn">
      <i class="contact-icon fa-solid fa-file-lines"></i>CV
    </div>
    <a
      href={LINKS.linkedin.url}
      target="_blank"
      rel="noopener noreferrer"
      class="contact-btn"
      aria-label={LINKS.linkedin.label}
      title={LINKS.linkedin.title}
    >
      <i class="contact-icon fa-brands fa-linkedin-in"></i>LinkedIn
    </a>
    <LetsTalk />
    <a href="/#about" class="contact-btn">
      <i class="contact-icon fa-solid fa-user"></i> About
    </a>
  </div>
  <div class="header-actions">
    <div class="header-toggles">
      <AccessibilityToggle />
      <ThemeToggle />
      <PerformanceToggle />
    </div>
    <HeaderHamburger isHome={isHome} />
  </div>
  <DarkMode />
  <PerformanceMode />
  <ReducedMotion />
</header>

<style>
  @reference "../../../styles/global.css";

  /* ---------------------------------------------------------------- */
  /* HEADER */
  /* ---------------------------------------------------------------- */
  /* #region Header */
  header {
    @apply justify-between;
    position: fixed;
    height: var(--header-height);
    width: 100%;
    z-index: var(--z-header);

    /* Overrides for surface-panel to make it a header */
    background: var(--bg-base);
    box-shadow: var(--box-shadow-small);
    border-radius: 0;
    border-bottom: var(--border);
    border-top: none;
    border-left: none;
    border-right: none;
  }

  header.menu-open {
    box-shadow: var(--box-shadow-small);
  }
  .header-actions,
  .header-contacts {
    @apply flx-algncntr-rw;
    gap: 0.25rem; /* Gap between the toggle-group and the hamburger */
  }

  .header-contacts {
    height: 80%;
  }
  .header-actions {
    height: 100%;
  }

  .header-toggles {
    @apply flx-algncntr-rw;
    gap: 0.5rem; /* Increased gap between toggles */
    margin-right: 1.25rem;
  }

  .header-contacts,
  .header-toggles {
    display: none;
  }
  .header-contacts {
    justify-content: center;
    justify-self: center;
    flex: 1;
    @apply font-bold;
    gap: clamp(0.75rem, 1.5vw, 1.25rem); /* Increased gap between contact buttons */
  }
  .header-actions {
    justify-content: flex-end;
    justify-self: flex-end;
    margin-right: 0;
    padding-right: var(--header-height);
  }

  /* #endregion */

  /* ---------------------------------------------------------------- */
  /* ----- CONTACTS ----- */
  /* ---------------------------------------------------------------- */
  /* #region Contacts */

  .contact-btn {
    @apply btn-type-main;
  }
  .contact-icon {
    display: none;
  }

  /* #endregion */

  /* ---------------------------------------------------------------- */
  /* ----- QUERY ----- */
  /* ---------------------------------------------------------------- */
  /* #region Query */

  @media (min-width: 640px) {
    /* #2: Large Phone - Shrink, Hide, Remove Some Elements */
    .header-contacts {
      display: flex;
    } /* Show */
  }
  @media (min-width: 768px) {
    /* #3: Tablet - Start Shrink, Remove Elements */
    .contact-icon {
      display: flex;
    } /* Show */
  }
  @media (min-width: 1200px) {
    /* #4: Laptop */
    .header-toggles,
    .contact-icon {
      display: flex;
    } /* Show */
  }

  /* #endregion */
</style>
