---
/**
 * ══════════════════════════════════════════════
 *  HEADER HAMBURGER COMPONENT
 * ══════════════════════════════════════════════
 *
 * PURPOSE: Hamburger menu toggle button and mobile navigation menu container.
 *
 * CRITICAL RULES:
 * - Menu display behavior controlled by HeaderHamburger's internal styling and media queries.
 * - Hamburger wrapper uses fixed header height and contrast styling.
 */
import LetsTalk from "./LetsTalk.astro";
import { LINKS } from "../../../config/site";
import HeaderQR from "./HeaderQR.astro";
import HeaderCredit from "./HeaderCredit.astro";
import ThemeToggle from "../../features/theme/ThemeToggle.astro";
import PerformanceToggle from "../../features/performance/PerformanceToggle.astro";
import AccessibilityToggle from "../../features/a11y/AccessibilityToggle.astro";
import HeaderIconButton from "../HeaderIconButton.astro";
import ContactButton from "../ContactButton.astro";

interface Props {
  isHome: boolean;
}

const { isHome } = Astro.props;
---

<div class="hmbrgr-menu-toggle-wrapper">
  <HeaderIconButton id="hmbrgr-menu-toggle" title="Open Menu">
    <i class="fa-solid fa-bars icon-bars"></i>
    <i class="fa-solid fa-xmark icon-xmark hidden-icon"></i>
  </HeaderIconButton>
</div>

<div id="hmbrgr-menu">
  <div class="hmbrgr-scroll-container">
    <div class="hmbrgr-section hmbrgr-connect-section" class:list={{ "is-not-home": !isHome }}>
      <span class="hmbrgr-section-label">Quick Links</span>
      <div class="hmbrgr-contact-list">
        <ContactButton
          isHamburger={true}
          href="/cv.pdf"
          target="_blank"
          label="CV"
          icon="fa-solid fa-file-lines"
          class="desktop-hide"
        />
        <ContactButton
          isHamburger={true}
          href={LINKS.linkedin.url}
          target="_blank"
          rel="noopener noreferrer"
          label="LinkedIn"
          icon="fa-brands fa-linkedin-in"
          class="desktop-hide"
        />
        <div class="hmbrgr-talk-wrapper desktop-hide">
          <LetsTalk isHamburger={true} />
        </div>
        {
          !isHome && (
            <>
              <ContactButton isHamburger={true} href="/#projects" label="Projects">
                <svg slot="icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path d="M2.591 2.921C2.591 2.4 2.171 1.98 1.65 1.98C1.129 1.98 0.709 2.4 0.709 2.921L0.709 17.348C0.709 18.56 1.693 19.544 2.905 19.544L10.118 19.544L10.118 17.662L2.905 17.662C2.732 17.662 2.591 17.521 2.591 17.348L2.591 8.253L10.118 8.253L10.118 6.371L2.591 6.371L2.591 2.921ZM13.882 10.762L21.409 10.762C22.448 10.762 23.291 9.919 23.291 8.88L23.291 5.117C23.291 4.078 22.448 3.235 21.409 3.235L18.167 3.235C17.834 3.235 17.516 3.102 17.281 2.866L16.944 2.529C16.591 2.176 16.113 1.976 15.615 1.976L13.882 1.98C12.843 1.98 12 2.823 12 3.862L12 8.88C12 9.919 12.843 10.762 13.882 10.762ZM13.882 22.053L21.409 22.053C22.448 22.053 23.291 21.21 23.291 20.171L23.291 16.408C23.291 15.369 22.448 14.526 21.409 14.526L18.167 14.526C17.834 14.526 17.516 14.392 17.281 14.157L16.944 13.82C16.591 13.467 16.113 13.267 15.615 13.267L13.882 13.271C12.843 13.271 12 14.114 12 15.153L12 20.171C12 21.21 12.843 22.053 13.882 22.053Z" />
                </svg>
              </ContactButton>
              <ContactButton isHamburger={true} href="/#contacts" label="Contacts">
                <svg slot="icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path d="M11.991,3.376C7.244,3.376 3.393,7.229 3.393,11.979C3.393,16.729 7.244,20.583 11.991,20.583C12.783,20.583 13.424,21.223 13.424,22.017C13.424,22.81 12.783,23.451 11.991,23.451C5.658,23.451 0.526,18.315 0.526,11.979C0.526,5.643 5.658,0.508 11.991,0.508C18.323,0.508 23.455,5.643 23.455,11.979L23.455,13.413C23.455,15.788 21.529,17.715 19.156,17.715C17.844,17.715 16.666,17.123 15.878,16.196C14.857,17.137 13.491,17.715 11.991,17.715C8.825,17.715 6.259,15.147 6.259,11.979C6.259,8.811 8.825,6.244 11.991,6.244C13.24,6.244 14.395,6.642 15.336,7.324C15.591,7.099 15.923,6.961 16.29,6.961C17.082,6.961 17.723,7.601 17.723,8.394L17.723,13.413C17.723,14.206 18.363,14.847 19.156,14.847C19.948,14.847 20.589,14.206 20.589,13.413L20.589,11.979C20.589,7.229 16.738,3.376 11.991,3.376ZM14.857,11.979C14.857,10.397 13.571,9.111 11.991,9.111C10.41,9.111 9.125,10.397 9.125,11.979C9.125,13.561 10.41,14.847 11.991,14.847C13.571,14.847 14.857,13.561 14.857,11.979Z" />
                </svg>
              </ContactButton>
            </>
          )
        }
        <ContactButton
          isHamburger={true}
          href="/#about"
          label="About"
          icon="fa-solid fa-user"
          class="desktop-hide"
        />
      </div>
    </div>

    <div class="hmbrgr-section hmbrgr-toggles-section">
      <span class="hmbrgr-section-label"></span>
      <div class="hmbrgr-toggles">
        <PerformanceToggle id="hmbrgr-performance-toggle" />
        <AccessibilityToggle isHamburger={true} id="hmbrgr-accessibility-toggle" />
        <ThemeToggle id="hmbrgr-theme-toggle" />
      </div>
    </div>

    <div class="hmbrgr-section">
      <span class="hmbrgr-section-label"></span>
      <div class="hmbrgr-resources-grid">
        <HeaderQR />
        <HeaderCredit />
      </div>
    </div>
  </div>
</div>

<script>
  import { initMenuController } from "./menuController";
  initMenuController();
</script>

<style>
  @reference "../../../styles/global.css";

  /* Icon Fading Logic */
  :global(header:not(.menu-open)) .icon-bars {
    opacity: 1 !important;
    transform: scale(1) rotate(0) !important;
  }
  :global(header:not(.menu-open)) .icon-xmark {
    opacity: 0 !important;
    transform: scale(0.6) rotate(-90deg) !important;
  }
  :global(header.menu-open) .icon-bars {
    opacity: 0 !important;
    transform: scale(0.6) rotate(90deg) !important;
  }
  :global(header.menu-open) .icon-xmark {
    opacity: 1 !important;
    transform: scale(1) rotate(0) !important;
  }

  /* --- Reduced Motion Icon Overrides --- */
  html[data-reduced-motion="true"] :global(header:not(.menu-open)) .icon-xmark {
    display: none !important;
  }
  html[data-reduced-motion="true"] :global(header.menu-open) .icon-bars {
    display: none !important;
  }

  /* ---------------------------------------------------------------- */
  /* ----- hmbrgr MENU TOGGLE ----- */
  /* ---------------------------------------------------------------- */

  .hmbrgr-menu-toggle-wrapper {
    @apply flx-cntr-rw;
    height: calc(var(--header-height) - var(--border-width));
    width: var(--header-height);
    background: transparent;
    position: absolute;
    right: 0;
    top: 0;
    z-index: 40;
  }

  .hmbrgr-menu-toggle-wrapper :global(.header-icon-btn) {
    width: 100% !important;
    height: 100% !important;
    border-radius: 0 !important;
    background: var(--brand-secondary) !important;
    border: none !important;
    color: var(--bg-base) !important;
  }

  .fa-solid {
    color: var(--bg-base);
  }

  /* ---------------------------------------------------------------- */
  /* ----- hmbrgr MENU PANEL ----- */
  /* ---------------------------------------------------------------- */

  #hmbrgr-menu {
    @apply flx-cntr-clmn surface-panel;
    border-radius: 0;
    display: none;
    position: fixed;
    width: 100%;
    height: calc(100vh - var(--header-height));
    left: 0;
    top: var(--header-height);
    z-index: var(--z-menu);
    border: none;
    border-bottom: var(--border);
    overflow: hidden;
    transition: width var(--transition-fast) ease;
  }

  /* Gradual Width Transitions */
  @media (min-width: 640px) {
    #hmbrgr-menu {
      width: 70%;
      left: auto;
      right: 0;
      border-left: var(--border);
    }
  }

  @media (min-width: 900px) {
    #hmbrgr-menu {
      width: 50%;
    }
  }

  /* Desktop Flyout Style */
  @media (min-width: 1200px) {
    #hmbrgr-menu {
      width: 400px;
    }
  }

  #hmbrgr-menu.open {
    display: flex;
    animation: slideDown var(--transition-fast) ease-out;
  }

  @media (min-width: 640px) {
    #hmbrgr-menu.open {
      animation: slideLeft var(--transition-fast) ease-out;
    }
  }

  #hmbrgr-menu.closing {
    animation: slideUp var(--transition-fast) ease-in forwards;
  }

  @media (min-width: 640px) {
    #hmbrgr-menu.closing {
      animation: slideRight var(--transition-fast) ease-in forwards;
    }
  }

  .hmbrgr-scroll-container {
    width: 100%;
    height: 100%;
    overflow-y: auto;
    padding: 2rem 1.5rem;
    @apply flx-clmn;
    gap: 2.5rem;
  }

  /* Animations */
  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes slideUp {
    from {
      opacity: 1;
      transform: translateY(0);
    }
    to {
      opacity: 0;
      transform: translateY(-10px);
    }
  }
  @keyframes slideLeft {
    from {
      opacity: 0;
      transform: translateX(20px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }
  @keyframes slideRight {
    from {
      opacity: 1;
      transform: translateX(0);
    }
    to {
      opacity: 0;
      transform: translateX(20px);
    }
  }

  /* ---------------------------------------------------------------- */
  /* ----- SECTIONS ----- */
  /* ---------------------------------------------------------------- */

  .hmbrgr-section {
    @apply flx-clmn;
    gap: 1rem;
    width: 100%;
  }

  .hmbrgr-section-label {
    @apply txt-body-sm font-bold uppercase;
    color: var(--brand-secondary);
    letter-spacing: 0.1em;
    padding-bottom: 0.2rem;
    position: relative;
    display: block;
    margin-bottom: 0.2rem;
  }

  .hmbrgr-section-label::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: var(--border-width);
    background: color-mix(in srgb, var(--brand-secondary) 30%, transparent);
    border-radius: var(--border-radius-full);
  }

  .hmbrgr-connect-section {
    display: flex;
  }

  @media (min-width: 640px) {
    .hmbrgr-connect-section:not(.is-not-home) {
      display: none;
    }
    :global(.hmbrgr-contact-list .desktop-hide) {
      display: none !important;
    }
  }

  /* Navigation Links */
  .hmbrgr-nav-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem 0.75rem;
    justify-items: center;
  }

  .hmbrgr-nav {
    @apply btn-fx-txtcolor focus-visible font-bold;
    transition: all var(--transition-fast);
    padding: 0.75rem 1rem;
    background: color-mix(in srgb, var(--bg-panel) 100%, var(--brand-secondary));
    border-radius: 12px;
    border: 1px solid transparent;
    cursor: pointer;
    @apply text-lg;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 200px;
    justify-self: center;
    height: 3.5rem;
  }

  .hmbrgr-nav:hover {
    background: var(--brand-secondary);
    color: var(--bg-base);
    transform: translateY(-2px);
  }

  /* Contact Buttons */
  .hmbrgr-contact-list {
    @apply flx-clmn;
    width: 100%;
    gap: 0; /* Handled by list item padding/borders */
  }

  .hmbrgr-talk-wrapper {
    display: flex;
    width: 100%;
  }

  .hmbrgr-resources-grid {
    @apply flx-cntr-clmn;
    gap: 1.5rem;
    width: 100%;
  }

  /* Toggles */
  .hmbrgr-toggles {
    @apply flx-jstfycntr-rw;
    background: transparent;
    padding: 1rem;
    border-radius: 16px;
    gap: 1.5rem;
  }

  .hmbrgr-footer {
    @apply flx-cntr-clmn;
    margin-top: auto;
    padding-top: 2rem;
    gap: 1.5rem;
  }

  /* Media Queries for Layout Balance */
  @media (min-width: 1200px) {
    .hmbrgr-toggles-section {
      display: none; /* Already prominently in header */
    }
    .hmbrgr-scroll-container {
      padding: 3rem 2rem;
    }
  }

  /* Toggle Wrapper Overrides */
  .hmbrgr-menu-toggle-wrapper :global(.header-icon-btn) {
    width: 100%;
    height: 100%;
    border-radius: 0;
    color: var(--bg-base);
    border: none !important;
    transition: background var(--transition-fast) ease;
  }

  .hmbrgr-menu-toggle-wrapper :global(.header-icon-btn[aria-expanded="true"]) {
    background: var(--brand-primary) !important;
  }

  @media (hover: hover) {
    .hmbrgr-menu-toggle-wrapper :global(.header-icon-btn:hover) {
      background: var(--brand-primary) !important;
    }
  }

  .hmbrgr-menu-toggle-wrapper :global(.header-icon-btn i) {
    @apply text-3xl;
  }

  /* Clarity Mode */
  html[data-clarity="true"] .hmbrgr-menu-toggle-wrapper :global(.header-icon-btn) {
    background: var(--brand-primary) !important;
  }

  html[data-clarity="true"]
    .hmbrgr-menu-toggle-wrapper
    :global(.header-icon-btn[aria-expanded="true"]) {
    background: color-mix(in srgb, var(--brand-secondary), white 10%) !important;
  }

  html[data-theme="dark"][data-clarity="true"]
    .hmbrgr-menu-toggle-wrapper
    :global(.header-icon-btn[aria-expanded="true"]) {
    background: color-mix(in srgb, var(--brand-secondary), black 10%) !important;
  }

  @media (hover: hover) {
    html[data-clarity="true"] .hmbrgr-menu-toggle-wrapper :global(.header-icon-btn:hover) {
      background: color-mix(in srgb, var(--brand-secondary), white 10%) !important;
    }

    html[data-theme="dark"][data-clarity="true"]
      .hmbrgr-menu-toggle-wrapper
      :global(.header-icon-btn:hover) {
      background: color-mix(in srgb, var(--brand-secondary), black 10%) !important;
    }
  }
  html[data-clarity="true"] .hmbrgr-nav {
    border: var(--border-width) solid var(--brand-secondary);
  }
</style>
