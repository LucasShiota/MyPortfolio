---
/**
 * ══════════════════════════════════════════════
 *  HEADER HAMBURGER COMPONENT
 * ══════════════════════════════════════════════
 *
 * PURPOSE: Hamburger menu toggle button and mobile navigation menu container.
 *
 * CRITICAL RULES:
 * - Menu display behavior controlled by HeaderHamburger's internal styling and media queries.
 * - Hamburger wrapper uses fixed header height and contrast styling.
 */
import LetsTalk from "./LetsTalk.astro";
import { LINKS } from "../../../config/site";
import HeaderQR from "./HeaderQR.astro";
import HeaderCredit from "./HeaderCredit.astro";
import ThemeToggle from "../../features/theme/ThemeToggle.astro";
import PerformanceToggle from "../../features/performance/PerformanceToggle.astro";
import AccessibilityToggle from "../../features/a11y/AccessibilityToggle.astro";
import HeaderIconButton from "../HeaderIconButton.astro";

interface Props {
  isHome: boolean;
}

const { isHome } = Astro.props;
---

<div class="hmbrgr-menu-toggle-wrapper">
  <HeaderIconButton id="hmbrgr-menu-toggle" title="Open Menu">
    <i class="fa-solid fa-bars icon-bars"></i>
    <i class="fa-solid fa-xmark icon-xmark hidden-icon"></i>
  </HeaderIconButton>
</div>

<div id="hmbrgr-menu">
  <div class="hmbrgr-row">
    <div class:list={["hmbrgr-contacts", { "hmbrgr-contacts-full": !isHome }]}>
      <div class="hmbrgr-contact-btn" tabindex="0" role="button" aria-label="View CV">
        <i class="fa-solid fa-file-lines"></i>&#8194;CV
      </div>
      <a
        href={LINKS.linkedin.url}
        target="_blank"
        rel="noopener noreferrer"
        class="hmbrgr-contact-btn"
        aria-label={LINKS.linkedin.label}
        title={LINKS.linkedin.title}
      >
        <i class="fa-brands fa-linkedin-in"></i>&#8194;LinkedIn
      </a>
      <LetsTalk isHamburger={true} />
      <div class="hmbrgr-contact-btn" tabindex="0" role="button" aria-label="View About me">
        <i class="fa-solid fa-user"></i>&#8194;About
      </div>
    </div>
    {
      isHome && (
        <div class="hmbrgr-nav-parent">
          <div
            class="hmbrgr-nav"
            data-index="0"
            tabindex="0"
            role="link"
            aria-label="Scroll to Hey section"
          >
            {" "}
            Hey{" "}
          </div>
          <div
            class="hmbrgr-nav"
            data-index="1"
            tabindex="0"
            role="link"
            aria-label="Scroll to Projects section"
          >
            {" "}
            Projects{" "}
          </div>
          <div
            class="hmbrgr-nav"
            data-index="2"
            tabindex="0"
            role="link"
            aria-label="Scroll to About Me section"
          >
            {" "}
            About Me{" "}
          </div>
          <div
            class="hmbrgr-nav"
            data-index="3"
            tabindex="0"
            role="link"
            aria-label="Scroll to Contacts section"
          >
            {" "}
            Contacts{" "}
          </div>
        </div>
      )
    }
  </div>
  <div class="hmbrgr-toggles">
    <AccessibilityToggle isHamburger={true} id="hmbrgr-accessibility-toggle" />
    <ThemeToggle id="hmbrgr-theme-toggle" />
    <PerformanceToggle id="hmbrgr-performance-toggle" />
  </div>
  <HeaderQR />
  <HeaderCredit />
</div>

<script>
  import { initMenuController } from "./menuController";
  initMenuController();
</script>

<style>
  @reference "../../../styles/global.css";

  /* Icon Fading Logic */
  :global(header:not(.menu-open)) .icon-bars {
    opacity: 1 !important;
    transform: scale(1) rotate(0) !important;
  }
  :global(header:not(.menu-open)) .icon-xmark {
    opacity: 0 !important;
    transform: scale(0.6) rotate(-90deg) !important;
  }
  :global(header.menu-open) .icon-bars {
    opacity: 0 !important;
    transform: scale(0.6) rotate(90deg) !important;
  }
  :global(header.menu-open) .icon-xmark {
    opacity: 1 !important;
    transform: scale(1) rotate(0) !important;
  }

  /* --- Reduced Motion Icon Overrides --- */
  html[data-reduced-motion="true"] :global(header:not(.menu-open)) .icon-xmark {
    display: none !important;
  }
  html[data-reduced-motion="true"] :global(header.menu-open) .icon-bars {
    display: none !important;
  }

  /* ---------------------------------------------------------------- */
  /* ----- hmbrgr MENU ----- */
  /* ---------------------------------------------------------------- */

  .hmbrgr-menu-toggle-wrapper {
    @apply flx-cntr-rw;
    height: var(--header-height);
    width: var(--header-height);
    background: var(--brand-secondary);

    /* MIMIC HEADER: Bottom border only. No Top, Right, or Left borders. */
    border-bottom: var(--border-width) solid color-mix(in srgb, var(--brand-secondary) 80%, black);
    border-top: none;
    border-right: none;
    border-left: none;

    box-sizing: border-box;
    transition: background var(--transition-speed) ease;

    position: absolute;
    right: 0;
    top: 0;
  }

  #hmbrgr-menu {
    @apply flx-cntr-clmn surface-panel;
    display: none;
    position: fixed;
    width: 100%;
    left: 0;
    top: var(--header-height);
    padding: 1rem 0;
    gap: 1rem;
    opacity: 1;
    z-index: var(--z-menu);

    /* Overrides since it attaches to the header */
    border-bottom: var(--border); /* Maintain border for layout stability */
    border-top: var(--border-width) solid transparent;
    border-left: var(--border-width) solid transparent;
    border-right: var(--border-width) solid transparent;
  }
  #hmbrgr-menu.open {
    display: flex;
    animation: slideDown 0.3s ease-out;
  }
  #hmbrgr-menu.closing {
    animation: slideUp 0.3s ease-in forwards;
  }

  /* --- Reduced Motion Menu Overrides --- */
  html[data-reduced-motion="true"] #hmbrgr-menu {
    animation: none !important;
    transform: none !important;
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes slideUp {
    from {
      opacity: 1;
      transform: translateY(0);
    }
    to {
      opacity: 0;
      transform: translateY(-10px);
    }
  }

  /* Override button to cover the wrapper and set contrast colors */
  .hmbrgr-menu-toggle-wrapper :global(.header-icon-btn) {
    width: 100%;
    height: 100%;
    border-radius: 0;
    color: var(--bg-base);
    /* Remove internal border to ensure icon stays perfectly centered in the wrapper */
    border: none !important;
  }

  @media (hover: hover) {
    .hmbrgr-menu-toggle-wrapper :global(.header-icon-btn:hover),
    .hmbrgr-menu-toggle-wrapper :global(.header-icon-btn[aria-expanded="true"]) {
      background: rgba(0, 0, 0, 0.15);
    }
  }

  /* Override icon size for hamburger menu specifically */
  .hmbrgr-menu-toggle-wrapper :global(.header-icon-btn i) {
    @apply text-3xl;
  }

  /* --- High Contrast Overrides --- */
  html[data-high-contrast="true"] .hmbrgr-menu-toggle-wrapper {
    background: var(--brand-primary);
    border-top: none;
    border-bottom: var(--border-primary);
  }

  html[data-high-contrast="true"] .hmbrgr-menu-toggle-wrapper :global(.header-icon-btn:hover),
  html[data-high-contrast="true"]
    .hmbrgr-menu-toggle-wrapper
    :global(.header-icon-btn[aria-expanded="true"]) {
    background: var(--brand-secondary) !important;
    outline: var(--border-width) solid var(--brand-secondary);
    outline-offset: calc(var(--border-width) * -1);
  }

  html[data-high-contrast="true"] #hmbrgr-menu {
    border-bottom: var(--border-primary);
  }

  .hmbrgr-row {
    display: flex;
    flex-direction: row;
    justify-content: center;
    width: 100%;
    padding: 0.5rem 0;
  }

  .hmbrgr-toggles {
    @apply flx-jstfycntr-rw;
    width: 70%;
    gap: 1rem;
    padding: 0.5rem 0;
    border-bottom: var(--border);
    border-top: var(--border);
  }

  .hmbrgr-contacts {
    border-right: var(--border);
  }

  .hmbrgr-nav {
    @apply btn-fx-txtcolor focus-visible;
    transition: color 0.3s;
    @apply text-xl;
    line-height: 0.9;
    @apply font-bold;
    padding: 0.7rem;
    border-radius: 8px;
    outline-offset: 4px !important;
  }

  .hmbrgr-nav-parent,
  .hmbrgr-contacts {
    @apply flx-cntr-clmn;
    gap: 0.5rem;
    width: 40%;
  }
  .hmbrgr-contacts.hmbrgr-contacts-full {
    width: 100%;
    border-right: none;
  }

  /* Media query specific for toggles visibility within header */
  @media (min-width: 640px) {
    .hmbrgr-contacts {
      display: none;
    }
  }
  @media (min-width: 768px) {
    .hmbrgr-nav-parent,
    .hmbrgr-row {
      display: none;
    }
    .hmbrgr-toggles {
      border-top: none;
    }
  }
  @media (min-width: 1200px) {
    .hmbrgr-toggles {
      display: none;
    }
  }
</style>
