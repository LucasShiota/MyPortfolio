---
import { LINKS } from "../../../config/site";
import PopUpPanel from "../PopUpPanel.astro";

interface Props {
  isHamburger?: boolean;
}

const { isHamburger = false } = Astro.props;
---

<PopUpPanel isHamburger={isHamburger} wrapperClass="lets-talk-wrapper">
  <button
    slot="trigger"
    class={isHamburger ? "hmbrgr-contact-btn" : "contact-btn"}
    aria-haspopup="true"
    aria-expanded="false"
    aria-label="Open contact options"
  >
    <i class="contact-icon fa-solid fa-comments"></i> Let's Talk
  </button>

  <!-- Section 1: Action -->
  <div class="panel-section">
    <a href={`mailto:${LINKS.contact.email}`} class="panel-btn">
      <i class="fa-solid fa-paper-plane"></i>
      <span>Start Email Draft</span>
    </a>
  </div>

  <!-- Section 2: Email -->
  <div class="panel-section">
    <span class="section-label"><i class="fa-solid fa-envelope"></i> Email Address</span>
    <button class="panel-btn copy-btn" data-copy={LINKS.contact.email}>
      <span class="icon-swap">
        <i class="fa-solid fa-copy main-icon"></i>
        <i class="fa-solid fa-check check-icon"></i>
      </span>
      <span class="btn-text">{LINKS.contact.email}</span>
    </button>
  </div>

  <!-- Section 3: Discord -->
  <div class="panel-section">
    <span class="section-label"><i class="fa-brands fa-discord"></i> Discord Username</span>
    <button class="panel-btn copy-btn" data-copy={LINKS.contact.discord}>
      <span class="icon-swap">
        <i class="fa-solid fa-copy main-icon"></i>
        <i class="fa-solid fa-check check-icon"></i>
      </span>
      <span class="btn-text">{LINKS.contact.discord}</span>
    </button>
  </div>
</PopUpPanel>

<script>
  function setupLetsTalkCopy() {
    const copyBtns = document.querySelectorAll(".lets-talk-wrapper .copy-btn");
    copyBtns.forEach((btn) => {
      // Remove previous listener to avoid duplicates on re-renders
      const newBtn = btn.cloneNode(true) as HTMLElement;
      btn.parentNode?.replaceChild(newBtn, btn);

      newBtn.addEventListener("click", async (e) => {
        e.preventDefault();
        const text = newBtn.getAttribute("data-copy");
        if (text) {
          try {
            await navigator.clipboard.writeText(text);

            // Visual feedback
            newBtn.classList.add("copied");
            const textSpan = newBtn.querySelector(".btn-text");
            const originalText = textSpan ? textSpan.textContent : "";

            if (textSpan) textSpan.textContent = "Copied!";

            setTimeout(() => {
              newBtn.classList.remove("copied");
              if (textSpan) textSpan.textContent = originalText;
            }, 2000);
          } catch (err) {
            console.error("Failed to copy", err);
          }
        }
      });
    });
  }

  setupLetsTalkCopy();
  document.addEventListener("astro:after-swap", setupLetsTalkCopy);
</script>

<style>
  @reference "../../../styles/global.css";

  /* Specific style for copy buttons */
  .copy-btn {
    justify-content: flex-start;
    @apply font-mono;
  }

  /* Icon Swap Logic */
  .icon-swap {
    position: relative;
    width: 1rem;
    height: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .icon-swap i {
    position: absolute;
    transition: all 0.3s ease;
  }
  .check-icon {
    opacity: 0;
    transform: scale(0.5);
    color: var(--accent-reverse);
  }
  .copy-btn.copied .main-icon {
    opacity: 0;
    transform: scale(0.5);
  }
  .copy-btn.copied .check-icon {
    opacity: 1;
    transform: scale(1);
  }
  .copy-btn.copied .btn-text {
    color: var(--accent-reverse);
  }
  .contact-btn,
  .hmbrgr-contact-btn {
    @apply btn-type-main;
  }
  .contact-icon {
    display: none;
  }

  /* Select trigger directly through PopUpPanel slots */
  :global(.hmbrgr-popup-wrapper) .contact-icon {
    display: inline-block;
    margin-right: 0.5rem;
  }

  @media (min-width: 768px) {
    .contact-icon {
      display: inline-block;
      margin-right: 0.5rem;
    }
  }
</style>
