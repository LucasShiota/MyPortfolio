---
interface Props {
  id?: string;
  wrapperClass?: string;
  panelClass?: string;
  isHamburger?: boolean;
}

const { id, wrapperClass = "", panelClass = "", isHamburger = false } = Astro.props;
---

<div id={id} class={`popup-wrapper ${isHamburger ? "hmbrgr-popup-wrapper" : ""} ${wrapperClass}`}>
  <div class="popup-trigger">
    <slot name="trigger" />
  </div>

  <div class={`popup-panel ${panelClass}`}>
    <slot />
  </div>
</div>

<script>
  function setupPopups() {
    const wrappers = document.querySelectorAll(".popup-wrapper");

    wrappers.forEach((wrapper) => {
      // Find the trigger element inside this wrapper
      const triggerContainer = wrapper.querySelector(".popup-trigger");
      const btn = triggerContainer?.firstElementChild;

      if (!btn) return;

      btn.addEventListener("click", (e) => {
        const isExpanded = btn.getAttribute("aria-expanded") === "true";
        btn.setAttribute("aria-expanded", (!isExpanded).toString());

        // Toggle on mobile/touch only
        if (window.matchMedia("(pointer: coarse)").matches) {
          e.stopPropagation();
          // Close others
          document.querySelectorAll(".popup-wrapper").forEach((w) => {
            if (w !== wrapper) {
              w.classList.remove("active");
              const otherBtn = w.querySelector(".popup-trigger")?.firstElementChild;
              otherBtn?.setAttribute("aria-expanded", "false");
            }
          });
          wrapper.classList.toggle("active");
        }
      });

      const panel = wrapper.querySelector(".popup-panel");
      panel?.addEventListener("click", (e) => {
        e.stopPropagation();
      });

      // Hover handling for aria-expanded (Desktop)
      wrapper.addEventListener("mouseenter", () => {
        if (!window.matchMedia("(pointer: coarse)").matches) {
          btn.setAttribute("aria-expanded", "true");
        }
      });
      wrapper.addEventListener("mouseleave", () => {
        if (!window.matchMedia("(pointer: coarse)").matches) {
          btn.setAttribute("aria-expanded", "false");
        }
      });
    });

    // Global click-to-close
    document.addEventListener("click", () => {
      document.querySelectorAll(".popup-wrapper").forEach((w) => {
        w.classList.remove("active");
        const btn = w.querySelector(".popup-trigger")?.firstElementChild;
        btn?.setAttribute("aria-expanded", "false");
      });
    });
  }

  // Runs on initial load
  setupPopups();
  // Support for view transitions if needed
  document.addEventListener("astro:after-swap", setupPopups);
</script>

<style is:global>
  @reference "../../styles/global.css";

  .popup-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .hmbrgr-popup-wrapper {
    justify-content: center;
  }

  .popup-panel {
    position: absolute;
    z-index: 100;
    top: calc(100% + 4px);
    left: 50%;
    transform: translateX(-50%) translateY(-10px);
    background: var(--bg-color);
    box-shadow: var(--box-shadow);
    border: 1px solid rgba(var(--gray), 0.2);
    border-radius: 1.5rem;
    display: flex;
    flex-direction: column;
    padding: 0.4rem;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    min-width: 220px;
  }

  /* Bridge to keep hover active */
  .popup-panel::before {
    content: "";
    position: absolute;
    top: -15px;
    left: 0;
    right: 0;
    height: 15px;
    background: transparent;
  }

  .popup-wrapper:hover .popup-panel,
  .popup-wrapper.active .popup-panel {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  /* Common Panel Styles */
  .panel-section {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.5rem;
    width: 100%;
  }

  /* 90% width separator logic */
  .panel-section:not(:last-child) {
    position: relative;
    padding-bottom: 0.7rem;
  }

  .panel-section:not(:last-child)::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 5%;
    height: 1px;
    width: 90%;
    background: rgba(var(--gray), 0.15);
  }

  .section-label {
    font-size: 0.7rem;
    @apply font-bold;
    @apply uppercase;
    padding-left: 0.6rem;
    margin-bottom: 0.1rem;
    letter-spacing: 0.05em;
    color: var(--text-color);
    opacity: 0.5;
  }

  .panel-btn {
    @apply btn-fx-txtcolor;
    width: 100%;
    white-space: nowrap;
    padding: 0.5rem 0.8rem;
    gap: 0.75rem;
    display: flex;
    justify-content: flex-start;
    align-items: center;
    border: none;
    border-radius: 0.8rem;
    background: transparent;
    color: var(--text-color);
    @apply txt-body-sm;
    @apply font-medium;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .panel-btn:hover {
    background-color: var(--bg-color-tinted);
  }
</style>
