---
/**
 * ══════════════════════════════════════════════
 *  POPUP PANEL COMPONENT
 * ══════════════════════════════════════════════
 *
 * PURPOSE: A generic wrapper for buttons that reveal a panel on hover or click.
 *
 * CRITICAL RULES:
 * - Supports "click to pin" functionality for accessibility.
 */
interface Props {
  id?: string;
  wrapperClass?: string;
  panelClass?: string;
  isHamburger?: boolean;
  fullWidth?: boolean;
}

const {
  id,
  wrapperClass = "",
  panelClass = "",
  isHamburger = false,
  fullWidth = false,
} = Astro.props;
---

<div
  id={id}
  class:list={[
    "popup-wrapper",
    isHamburger ? "hmbrgr-popup-wrapper" : "",
    fullWidth ? "full-width" : "",
    wrapperClass,
  ]}
>
  <div class="popup-trigger">
    <slot name="trigger" />
  </div>

  <div class={`popup-panel ${panelClass}`}>
    <slot />
  </div>
</div>

<script>
  function setupPopups() {
    const wrappers = document.querySelectorAll(".popup-wrapper");

    wrappers.forEach((wrapper) => {
      const triggerContainer = wrapper.querySelector(".popup-trigger");
      const btn = triggerContainer?.firstElementChild as HTMLElement;
      if (!btn) return;

      const updateAria = (expanded: boolean) => {
        btn.setAttribute("aria-expanded", expanded.toString());
      };

      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const isPinned = wrapper.classList.contains("active");

        // Close others first
        document.querySelectorAll(".popup-wrapper").forEach((w) => {
          if (w !== wrapper) {
            w.classList.remove("active");
            w.querySelector(".popup-trigger")?.firstElementChild?.setAttribute(
              "aria-expanded",
              "false"
            );
          }
        });

        wrapper.classList.toggle("active");
        updateAria(!isPinned);
      });

      const panel = wrapper.querySelector(".popup-panel");
      panel?.addEventListener("click", (e) => {
        e.stopPropagation();
      });

      // Hover handling for ARIA state (Visuals handled by CSS :hover)
      wrapper.addEventListener("mouseenter", () => {
        updateAria(true);
      });
      wrapper.addEventListener("mouseleave", () => {
        if (!wrapper.classList.contains("active")) {
          updateAria(false);
        }
      });
    });

    // Global click-to-close
    document.addEventListener("click", () => {
      document.querySelectorAll(".popup-wrapper").forEach((w) => {
        w.classList.remove("active");
        w.querySelector(".popup-trigger")?.firstElementChild?.setAttribute(
          "aria-expanded",
          "false"
        );
      });
    });
  }

  setupPopups();
  document.addEventListener("astro:after-swap", setupPopups);
</script>

<style is:global>
  @reference "../../styles/global.css";

  .popup-wrapper {
    position: relative;
    display: inline-flex;
    align-items: center;
  }

  .hmbrgr-popup-wrapper {
    justify-content: center;
  }

  .popup-wrapper.full-width {
    width: 100%;
  }

  .popup-trigger {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .popup-wrapper.full-width .popup-trigger {
    width: 100%;
  }

  .popup-panel {
    @apply surface-panel;
    position: absolute;
    z-index: var(--z-popup);
    top: calc(100% + 4px);
    left: 50%;
    transform: translateX(-50%) translateY(-10px);
    display: flex;
    flex-direction: column;
    padding: 0.4rem;
    opacity: 0;
    visibility: hidden;
    transition: all var(--transition-fast) var(--transition-cubic);
    min-width: 220px;
  }

  /* Bridge to keep hover active */
  .popup-panel::before {
    content: "";
    position: absolute;
    top: -15px;
    left: 0;
    right: 0;
    height: 15px;
    background: transparent;
  }

  .popup-wrapper:hover .popup-panel,
  .popup-wrapper.active .popup-panel {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  /* --- Reduced Motion Support --- */
  html[data-reduced-motion="true"] .popup-panel {
    transition: none !important;
    /* Remove vertical drift/pop anim */
    transform: translateX(-50%) !important;
  }

  html[data-reduced-motion="true"] .popup-wrapper:hover .popup-panel,
  html[data-reduced-motion="true"] .popup-wrapper.active .popup-panel {
    transform: translateX(-50%) !important;
  }

  /* --- Clarity Mode Support --- */
  html[data-clarity="true"] .popup-panel {
    border: var(--border-secondary) !important;
  }

  /* Common Panel Styles */
  .panel-section {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.5rem;
    width: 100%;
  }

  /* 90% width separator logic */
  .panel-section:not(:last-child) {
    position: relative;
    padding-bottom: 0.7rem;
  }

  .panel-section:not(:last-child)::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 5%;
    height: 1px;
    width: 90%;
    background: rgba(var(--gray), 0.15);
  }

  .section-label {
    font-size: 0.7rem;
    @apply font-bold;
    @apply uppercase;
    padding-left: 0.6rem;
    margin-bottom: 0.1rem;
    letter-spacing: 0.05em;
    color: var(--text-color);
    opacity: 0.5;
  }

  .panel-btn {
    @apply btn-type-panel txt-body-sm font-medium;
    white-space: nowrap;
    padding: 0.5rem 0.8rem;
  }
</style>
