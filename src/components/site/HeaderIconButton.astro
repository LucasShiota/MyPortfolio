---
/**
 * ══════════════════════════════════════════════
 *  HEADER ICON BUTTON COMPONENT
 * ══════════════════════════════════════════════
 *
 * PURPOSE: A standardized button used in the site header for toggles and menus.
 */
interface Props {
  id?: string;
  class?: string;
  title?: string;
  ariaLabel?: string;
  [key: string]: any;
}

const { id, class: className = "", title, ariaLabel, ...restProps } = Astro.props;
---

<button
  id={id}
  class:list={["header-icon-btn", className]}
  title={title}
  aria-label={ariaLabel || title}
  {...restProps}
>
  <slot />
</button>

<style>
  @reference "../../styles/global.css";

  .header-icon-btn {
    @apply focus-visible;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: transparent;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background var(--transition-fast);
    z-index: 30;
    position: relative;
    color: var(--text-color);
  }

  @media (hover: hover) {
    .header-icon-btn:hover,
    .header-icon-btn[aria-expanded="true"] {
      background: rgba(var(--gray), 0.3);
    }
  }

  /* --- CLARITY MODE --- */
  html[data-clarity="true"] .header-icon-btn {
    border: var(--border-width) solid var(--brand-secondary);
    background: transparent;
    color: var(--text-color); /* Black on Light, White on Dark */
    --icon-scale: 1;
  }

  html[data-clarity="true"] .header-icon-btn:hover,
  html[data-clarity="true"] .header-icon-btn[aria-expanded="true"] {
    background: var(--brand-secondary);
    color: var(--bg-base);
    --icon-scale: 1.1; /* Perceptual scale correction */
  }

  :global(.header-icon-btn i) {
    position: absolute;
    @apply text-2xl;
    /* Clean, premium transition for all properties */
    transition:
      opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1),
      transform 0.4s cubic-bezier(0.4, 0, 0.2, 1),
      color var(--transition-fast) ease;

    opacity: 1;
    transform: scale(var(--icon-scale, 1)) rotate(0deg);
  }

  /* 
     Base 'hidden' state for any icon. 
     This provides the smooth "scale-down/rotate" fade-out by default.
  */
  :global(.header-icon-btn i.hidden-icon) {
    opacity: 0;
    pointer-events: none;
    transform: scale(0.6) rotate(-45deg);
  }
</style>
