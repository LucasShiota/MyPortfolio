---
interface Props {
  href?: string;
  label?: string;
}

const { href = "/#projects", label = "All Projects" } = Astro.props;
---

<div class="back-btn-container">
  <a href={href} class="back-btn">
    <i class="fa-solid fa-arrow-left"></i>
    <span class="back-btn-label">{label}</span>
  </a>
</div>

<style>
  @reference "../../styles/global.css";

  .back-btn-container {
    @apply surface-panel;
    padding: 0.75rem 1rem;
    background: var(--bg-color); /* Lighter in light theme */
    display: flex;
    transition: background-color 0.6s var(--transition-cubic);
  }

  :global([data-theme="dark"]) .back-btn-container {
    background: color-mix(in srgb, var(--bg-color-tinted), black 40%); /* Darker in dark theme */
  }

  .back-btn {
    text-decoration: none;
    color: var(--text-color);
    @apply txt-body;
    @apply font-bold;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1rem;
    border-radius: 8px;
    transition: all 0.3s ease;
    opacity: 0.7;
    width: 100%;
  }

  .back-btn-label {
    font-size: 0.95em;
  }

  .back-btn:hover {
    background: rgba(var(--gray), 0.1);
    color: var(--accent-reverse);
    opacity: 1;
    transform: translateX(-5px);
  }

  @media (max-width: 1023px) {
    .back-btn-container {
      /* Shared visibility logic will be handled by parent or context */
    }
  }
</style>
