---
import ProjectSection from './SectionBase.astro';

interface Props {
  title?: string;
  buttons: {
    text: string;
    href: string;
    icon?: string;
    target?: string;
  }[];
  icon?: string;
  id?: string;
  order?: number;
  isSubsection?: boolean;
  parentOrder?: number;
  options?: {
    excludeFromOrder?: boolean;
    barColor?: string;
    compact?: boolean;
  };
}

const { 
  title, 
  buttons = [], 
  icon, 
  id, 
  order, 
  isSubsection = false,
  parentOrder,
  options
} = Astro.props;
---

<ProjectSection 
  title={title} 
  icon={icon} 
  id={id} 
  order={order} 
  isSubsection={isSubsection}
  parentOrder={parentOrder}
  options={options}
  class="button-section"
>
  <div class="buttons-container">
    {buttons.map(btn => (
      <a 
        href={btn.href} 
        class="button" 
        target={btn.target || "_blank"}
        rel={btn.target === "_blank" ? "noopener noreferrer" : ""}
      >
        {btn.icon && <i class={btn.icon}></i>}
        <span>{btn.text}</span>
      </a>
    ))}
  </div>
</ProjectSection>

<style>
  @reference "../../styles/global.css";

  .button {
    @apply btn-type-main;
    gap: 0.75rem;
  }

  /* The :global wrapper ensures these styles punch through component boundaries */
  :global(.button-section) :global(.panel-card) {
    display: flex !important;
    flex-direction: row !important;
    align-items: center !important;
    justify-content: flex-start !important;
    gap: 3rem !important;
    padding-top: var(--section-pad-y) !important;
    padding-bottom: var(--section-pad-bottom, var(--section-pad-y)) !important;
  }

  :global(.button-section) :global(.section-title) {
    margin-bottom: 0 !important;
    width: auto !important;
    flex-shrink: 0;
  }

  :global(.button-section) :global(.content-wrapper) {
    width: auto !important;
    flex-grow: 1;
    display: flex;
    align-items: center;
  }

  .buttons-container {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  /* Desktop/Tablet */
  @media (max-width: 1024px) {
    :global(.button-section) :global(.panel-card) {
      gap: 1.5rem !important;
    }
  }

  /* Mobile - vertical stack */
  @media (max-width: 768px) {
    :global(.button-section) :global(.panel-card) {
      flex-direction: column !important;
      align-items: flex-start !important;
      gap: 0.75rem !important;
      padding-top: var(--section-pad-y) !important;
      padding-bottom: var(--section-pad-bottom, var(--section-pad-y)) !important;
    }

    :global(.button-section) :global(.section-title) {
      width: 100% !important;
    }

    :global(.button-section) :global(.section-counter) {
      top: 0;
      right: 0;
    }

    :global(.button-section) :global(.content-wrapper) {
      width: 100% !important;
    }

    .buttons-container {
      width: 100% !important;
      flex-direction: column;
      align-items: stretch;
      gap: 1rem;
    }
  }
</style>
