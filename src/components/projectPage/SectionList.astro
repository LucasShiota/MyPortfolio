---
import ProjectSection from "./SectionBase.astro";

interface ListEntry {
  primary: string;
  secondary?: string;
}

interface Props {
  entries: (string | ListEntry | [string, string?])[];
  title?: string;
  icon?: string;
  id?: string;
  order?: number;
  isSubsection?: boolean;
  parentOrder?: number;
  options?: {
    excludeFromOrder?: boolean;
    barColor?: string;
    compact?: boolean;
  };
}

const {
  entries = [],
  title,
  icon,
  id,
  order,
  isSubsection = false,
  parentOrder,
  options,
} = Astro.props;

// Normalize entries to ListEntry objects
const normalizedEntries: ListEntry[] = entries.map((entry) => {
  if (typeof entry === "string") {
    return { primary: entry };
  } else if (Array.isArray(entry)) {
    return { primary: entry[0], secondary: entry[1] };
  } else {
    return entry;
  }
});
---

<ProjectSection
  title={title}
  icon={icon}
  id={id}
  order={order}
  isSubsection={isSubsection}
  parentOrder={parentOrder}
  options={options}
>
  <div class="list-container">
    <ul class="section-list">
      {
        normalizedEntries.map((entry, index) => (
          <li class="list-entry" style={`--index: ${index}`}>
            <div class="entry-header">
              <span class="entry-number" aria-hidden="true">
                {index + 1}.
              </span>
              <h3 class="entry-primary">{entry.primary}</h3>
            </div>
            {entry.secondary && <div class="entry-secondary">{entry.secondary}</div>}
          </li>
        ))
      }
    </ul>
  </div>
</ProjectSection>

<style>
  @reference "../../styles/global.css";

  .list-container {
    width: 100%;
    opacity: 0.9;
  }

  .section-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .list-entry {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    position: relative;
  }

  .entry-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem; /* Matched to SectionBase's title-left gap */
  }

  .entry-number {
    @apply font-bold;
    font-size: 1.25rem;
    color: var(--brand-secondary);
    width: 1.5rem; /* Precisely matched to section/subsection icon width */
    display: flex;
    justify-content: center;
    flex-shrink: 0;
    opacity: 0.8;
    user-select: none;
    line-height: inherit;
  }

  .entry-primary {
    @apply txt-h6 font-bold;
    color: var(--text-color);
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .entry-secondary {
    @apply txt-body;
    padding-left: 2.25rem; /* Exact calculation: width (1.5) + gap (0.75) */
    opacity: 0.65;
    line-height: 1.5;
    max-width: 850px;
  }

  @media (max-width: 768px) {
    .section-list {
      gap: 1.25rem;
    }

    .entry-header {
      gap: 0.65rem; /* Slightly reduced gap on mobile */
    }

    .entry-primary {
      @apply txt-body-lg font-bold;
      line-height: 1.3;
    }

    .entry-number {
      font-size: 1.1rem;
      width: 1.3rem; /* Slightly reduced icon/number column on mobile */
    }

    .entry-secondary {
      padding-left: 1.95rem; /* Calculation: 1.3 + 0.65 */
      max-width: 100%;
      font-size: 0.95rem;
    }
  }
</style>
