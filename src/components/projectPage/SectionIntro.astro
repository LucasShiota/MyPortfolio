---
/**
 * ══════════════════════════════════════════════
 *  PROJECT INTRODUCTION (SectionIntro.astro)
 * ══════════════════════════════════════════════
 *
 * PURPOSE: Hero section for detailed project pages.
 *
 * CRITICAL RULES:
 * - Accepts ImageMetadata or strings for hero/logo assets.
 * - Uses <Image /> for optimized delivery.
 */
import { Image } from "astro:assets";

interface Props {
  title: string;
  subtitle: string;
  heroImage: any;
  logo?: any;
  id?: string;
  order?: number;
  total?: number;
}

const { title, subtitle, heroImage, logo, id = "intro", order, total } = Astro.props;
---

<section class="hero-section" id={id}>
  <div class="hero-content">
    <header class="project-header">
      {
        order && total && (
          <div class="section-counter">
            {order}/{total}
          </div>
        )
      }
      {
        logo && (
          <div class="logo-container">
            <Image src={logo} alt={`${title} Logo`} class="project-logo" width={200} height={200} />
          </div>
        )
      }
      <h1 class="project-title txt-h1 leading-tight">{title}</h1>
      <p class="project-subtitle txt-h4 font-light">{subtitle}</p>
    </header>
  </div>
  <div class="hero-image-container">
    <Image src={heroImage} alt={title} class="hero-image" width={1200} height={800} />
  </div>
</section>

<style>
  @reference "../../styles/global.css";

  .hero-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    min-height: 60vh;
    scroll-margin-top: calc(var(--header-height) + 2rem);
  }

  @media (max-width: 1024px) {
    .hero-section {
      grid-template-columns: 1fr;
      @apply text-center;
      gap: 2rem;
    }
  }

  .project-header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
  }

  @media (max-width: 1024px) {
    .project-header {
      align-items: center;
    }
  }

  .logo-container {
    width: 120px;
    height: 120px;
    margin-bottom: 1rem;
  }

  .project-logo {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .project-title {
    font-family: var(--font-display);
    margin: 0;
    color: var(--brand-secondary);
  }

  .section-counter {
    @apply txt-body-sm font-mono font-bold;
    opacity: 0.4;
    letter-spacing: 0.15em;
    position: absolute;
    top: 0;
    right: 0;
  }

  .project-subtitle {
    opacity: 0.8;
    margin: 0;
  }

  .hero-image-container {
    width: 100%;
    height: 100%;
    max-height: 500px;
    border-radius: 40px;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
    /* Hover removed per request */
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
