---
import BackButton from "./SectionBackButton.astro";

interface Props {
  sections: {
    id?: string;
    label?: string;
    options?: {
      excludeFromOrder?: boolean;
    };
    subsections?: {
      id?: string;
      label?: string;
      options?: {
        excludeFromOrder?: boolean;
      };
    }[];
  }[];
}

const { sections } = Astro.props;
---

<div class="jump-to-container">
  <!-- Mobile Bottom Bar -->
  <div class="bottom-bar">
    <button id="snap-next" class="snap-btn" aria-label="Next main section">
      <i class="fa-solid fa-chevron-down"></i>
    </button>

    <!-- Mobile Toggle Button -->
    <button id="jump-toggle" class="jump-toggle" aria-expanded="false" aria-label="Toggle section navigation">
      <i class="fa-solid fa-list-ul"></i>
      <span> Sections </span>
      <i class="fa-solid fa-chevron-up toggle-chevron"></i>
    </button>

    <button id="snap-prev" class="snap-btn" aria-label="Previous main section">
      <i class="fa-solid fa-chevron-up"></i>
    </button>
  </div>

  <!-- Navigation Menu -->
  <nav id="jump-nav" class="jump-nav">
    <BackButton href="/#projects" label="All Projects" />

    <div class="nav-sections">
      <div class="nav-header">
        <i class="fa-solid fa-list-ul"></i>
        <span>Sections</span>
      </div>
      <ul class="nav-list" id="nav-list">
        {(() => {
          let visibleIndex = 0;
          return sections.map((section) => {
            const isExcluded = section.options?.excludeFromOrder || !section.label;
            if (isExcluded) return null;
            
            visibleIndex++;
            
            return (
              <li class="nav-item-group">
                <div class="nav-link-wrapper">
                  <a href={`#${section.id}`} class="nav-link" data-section={section.id}>
                    <i class="fa-solid fa-location-arrow active-arrow"></i>
                    <span class="nav-label">
                      <span class="nav-counter">{visibleIndex}. </span>
                      {section.label}
                    </span>
                  </a>
                  {section.subsections && section.subsections.some(sub => !sub.options?.excludeFromOrder && sub.label) && (
                    <button class="sub-toggle" aria-expanded="true" aria-label="Toggle subsections">
                      <i class="fa-solid fa-chevron-down chevron-icon"></i>
                    </button>
                  )}
                </div>
                
                {section.subsections && section.subsections.some(sub => !sub.options?.excludeFromOrder && sub.label) && (
                  <ul class="sub-nav-list">
                    {(() => {
                      let visibleSubIndex = 0;
                      return section.subsections.map((sub) => {
                        const isSubExcluded = sub.options?.excludeFromOrder || !sub.label;
                        if (isSubExcluded) return null;
                        
                        visibleSubIndex++;

                        return (
                          <li>
                            <a href={`#${sub.id}`} class="nav-link sub-link" data-section={sub.id}>
                              <i class="fa-solid fa-location-arrow active-arrow"></i>
                              <span class="nav-label">
                                <span class="nav-counter">{visibleIndex}.{visibleSubIndex} </span>
                                {sub.label}
                              </span>
                            </a>
                          </li>
                        );
                      });
                    })()}
                  </ul>
                )}
              </li>
            );
          });
        })()}
      </ul>
    </div>
  </nav>
</div>

<script>
  import { initJumpToController } from "../../scripts/ui/jumpToController";
  import { initSectionTracker } from "../../scripts/ui/sectionTracker";
  
  initJumpToController();
  initSectionTracker();

  // Snapping Logic
  const initSnapControls = () => {
    const prevBtn = document.getElementById('snap-prev');
    const nextBtn = document.getElementById('snap-next');
    
    if (!prevBtn || !nextBtn) return;

    const getMainSections = () => {
      // Find all top-level section links to identify main sections
      const links = document.querySelectorAll('.nav-link:not(.sub-link)');
      const ids = ['intro']; // Always start with intro
      links.forEach(link => {
        const id = link.getAttribute('data-section');
        if (id) ids.push(id);
      });
      return ids;
    };

    const snap = (direction: 'prev' | 'next') => {
      const sectionIds = getMainSections();
      const activeLink = document.querySelector('.nav-link.active');
      
      let currentId = 'intro';
      if (activeLink) {
        // If we are in a sub-section, find the parent main section ID
        if (activeLink.classList.contains('sub-link')) {
          const mainLink = activeLink.closest('.nav-item-group')?.querySelector('.nav-link:not(.sub-link)');
          currentId = mainLink?.getAttribute('data-section') || 'intro';
        } else {
          currentId = activeLink.getAttribute('data-section') || 'intro';
        }
      }

      const currentIndex = sectionIds.indexOf(currentId);
      let targetIndex = currentIndex;

      if (direction === 'next') {
        targetIndex = Math.min(currentIndex + 1, sectionIds.length - 1);
      } else {
        targetIndex = Math.max(currentIndex - 1, 0);
      }

      if (targetIndex !== currentIndex) {
        const targetEl = document.getElementById(sectionIds[targetIndex]);
        if (targetEl) {
          targetEl.scrollIntoView({ behavior: 'auto' });
        }
      }
    };

    prevBtn.addEventListener('click', () => snap('prev'));
    nextBtn.addEventListener('click', () => snap('next'));
  };

  initSnapControls();

  // Handle Subsection Toggles
  const subToggles = document.querySelectorAll('.sub-toggle');
  subToggles.forEach(toggle => {
    toggle.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      
      const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', (!isExpanded).toString());
      
      const subList = toggle.parentElement?.nextElementSibling;
      if (subList && subList.classList.contains('sub-nav-list')) {
        subList.classList.toggle('is-collapsed', isExpanded);
      }
    });
  });
</script>

<style>
  @reference "../../styles/global.css";

  /* Subsection Collapsible Logic */
  .sub-nav-list {
    transition: all 0.3s ease;
    max-height: 500px;
    opacity: 1;
    overflow: hidden;
  }

  .sub-nav-list.is-collapsed {
    max-height: 0;
    opacity: 0;
    margin-top: 0;
    margin-bottom: 0;
    pointer-events: none;
  }

  .sub-toggle {
    background: transparent;
    border: none;
    color: var(--text-color);
    padding: 0.25rem;
    cursor: pointer;
    opacity: 0.4;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    margin-right: 0.5rem;
  }

  .sub-toggle:hover {
    opacity: 1;
    background: rgba(var(--gray), 0.1);
    color: var(--accent-reverse);
  }

  .chevron-icon {
    font-size: 0.7em;
    transition: transform 0.3s ease;
  }

  .sub-toggle[aria-expanded="false"] .chevron-icon {
    transform: rotate(-90deg);
  }

  .nav-link-wrapper {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  .nav-link-wrapper .nav-link {
    flex-grow: 1;
  }

  /* Desktop layout: Fixed on the left */
  @media (min-width: 1024px) {
    .jump-to-container {
      position: fixed;
      /* Keep it pinned to the edge of the 1400px max-width container */
      left: max(2rem, calc(48vw - 700px + 2rem));
      top: calc(var(--header-height) + 2rem);

      width: clamp(150px, 14vw, 240px); /* Slightly wider for toggle buttons */
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .bottom-bar {
      display: none;
    }

    .jump-toggle {
      display: none; /* Hide toggle button on desktop */
    }

    .jump-nav {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .nav-sections {
      @apply surface-panel;
      padding: 1.5rem 0.75rem; /* Reduced horizontal padding for better fit */
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .nav-header {
      @apply txt-color-accent font-bold txt-body;
      letter-spacing: 0.05em;
      padding-bottom: 0.5rem;
      border-bottom: var(--border);
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-right: 0.5rem;
      margin-left: 0.5rem;
    }
  }

  /* Mobile/Tablet Layout: Bottom centered bar */  
  @media (max-width: 1023px) {
    .jump-to-container {
      position: fixed;
      bottom: 1.5rem;
      left: 50%;
      transform: translateX(-50%);
      z-index: 15;
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 100%;
      padding: 0 1.5rem;
      pointer-events: none; /* Allow clicks through container but not buttons */
    }

    .bottom-bar {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      background: color-mix(in srgb, var(--text-color) 80%, transparent);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      padding: 0.5rem;
      border-radius: 999px;
      border: 1px solid rgba(var(--gray), 0.2);
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
      pointer-events: auto;
    }

    .snap-btn {
      @apply flx-cntr;
      width: 2.5rem;
      height: 2.5rem;
      border-radius: 50%;
      border: none;
      background: rgba(var(--gray), 0.1);
      color: var(--bg-color);
      cursor: pointer;
      transition: all 0.2s ease;
      opacity: 0.6;
    }

    .snap-btn:hover {
      opacity: 1;
      background: rgba(var(--gray), 0.2);
      color: var(--accent-reverse);
    }

    .snap-btn:active {
      transform: scale(0.9);
    }

    .jump-toggle {
      @apply btn-type-main;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding-right: 1.5rem;
      padding-left: 1.5rem;
      @apply font-semibold;
      @apply txt-body-sm;
      box-shadow: none;
      transition: transform 0.3s ease, background 0.3s ease;
    }

    .jump-toggle:active {
      transform: scale(0.95);
    }

    .toggle-chevron {
      transition: transform 0.3s ease;
      font-size: 0.8em;
    }

    .jump-toggle[aria-expanded="true"] .toggle-chevron {
      transform: rotate(180deg);
    }

    .jump-nav {
      position: absolute;
      bottom: calc(100% + 1rem);
      width: max-content;
      max-width: 90vw;
      opacity: 0;
      visibility: hidden;
      transform: translateY(20px);
      transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      z-index: 1;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      pointer-events: auto;
    }

    .nav-sections {
      @apply surface-panel;
      padding: 1rem;
      min-width: 200px;
    }

    .jump-nav.is-open {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }

    .nav-header {
      display: none; /* Hide header on mobile, toggle button serves this role */
    }
  }

  .sub-nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
    margin-left: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    border-left: 1px solid rgba(var(--gray), 0.2);
    margin-top: 0.25rem;
    margin-bottom: 0.5rem;
  }

  .nav-item-group {
    display: flex;
    flex-direction: column;
  }

  /* Shared List Styles */
  .nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .nav-link {
    text-decoration: none;
    color: var(--text-color);
    @apply txt-body-sm;
    @apply font-medium;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.75rem;
    border-radius: 8px;
    transition: all 0.2s ease;
    opacity: 0.7;
    position: relative;
    overflow: hidden;
  }

  .sub-link {
    @apply py-1;
    opacity: 0.5;
  }

  .sub-link .nav-label {
    font-size: 0.8em;
  }

  .nav-label {

    font-size: 0.85em;
    transition: transform 0.2s ease;
  }

  .nav-link:hover, .nav-link.active {
    background: rgba(var(--gray), 0.1);
    color: var(--accent-reverse);
    opacity: 1;
  }

  /* Active Indicator Arrow */
  .active-arrow {
    @apply text-[0.65rem]; /* Specific small size for the arrow */
    display: inline-block;
    width: 0;
    overflow: hidden;
    white-space: nowrap;
    opacity: 0;
    /* Base rotation of 45deg to point top-right cursor towards 3 o'clock */
    transform: translateX(-10px) rotate(45deg) scale(0.3); 
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    color: var(--accent-reverse);
  }

  /* Standard Active State */
  .nav-link.active .active-arrow {
    width: 0.8rem;
    margin-right: 0.4rem;
    opacity: 1;
    transform: translateX(0) rotate(45deg) scale(0.85); 
  }

  /* Active Proxy: Parent link inherits arrow if active child is collapsed */
  .nav-item-group:has(.sub-nav-list.is-collapsed .sub-link.active) .nav-link-wrapper .nav-link .active-arrow {
    width: 0.8rem;
    margin-right: 0.4rem;
    opacity: 0.6; /* Slightly dimmer to indicate it's a proxy */
    transform: translateX(0) rotate(45deg) scale(0.85);
  }

  .nav-link.active .nav-label {
    font-weight: bold;
    color: var(--accent-reverse);
  }

  /* Make sure the text on parent also glows if it's housing an active child via proxy */
  .nav-item-group:has(.sub-nav-list.is-collapsed .sub-link.active) .nav-link-wrapper .nav-link .nav-label {
    color: var(--accent-reverse);
    opacity: 1;
  }

</style>
