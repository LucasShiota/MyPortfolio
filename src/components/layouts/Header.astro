<style>
	@reference "../../styles/global.css";

/* ---------------------------------------------------------------- */
/* HEADER */
/* ---------------------------------------------------------------- */
/* #region Header */
	header {
		position: fixed; height: var(--header-height); width: 100%;
		@apply justify-between;
		opacity: var(--headfoot-opacity);
		background: var(--bg-color); box-shadow: var(--box-shadow-small);
	}

	header.menu-open { box-shadow: var(--box-shadow-small); }
	.header-brand, .header-toggles, .header-contacts, .hmbrgr-menu-toggle-wrapper {
		@apply flx-algncntr-rw;
		height: 80%; gap: 1rem;
	}
	.header-contacts, .header-toggles { display: none; }
	.header-brand { justify-content: flex-start; justify-self: flex-start; }
	.header-contacts { 
		justify-content: center; justify-self: center;
		flex: 1; font-weight: bold; 
		gap: clamp(0.5rem, 1vw, 1rem);
	}
	.header-toggles, .hmbrgr-menu-toggle-wrapper { justify-content: flex-end; justify-self: flex-end;}

/* #endregion */

/* ---------------------------------------------------------------- */
/* ----- BRAND ----- */
/* ---------------------------------------------------------------- */
/* #region Brand */

	.header-brand-link {
		text-decoration: none;
		color: var(--text-color);
		display: flex;
		flex-direction: column;
		justify-content: center;
	}
	.header-brand-link:hover { color: var(--text-color); }

	.name, .path { font-size: 1.3; line-height: 1.2; }
	.header-icon {
		width: 50px; height: 50px;
		object-fit: contain; display: block; margin-left: 1rem;
		user-select: none;
		transform-origin: center; transform-style: preserve-3d; /* Anim */
	}
 
/* #endregion */

/* ---------------------------------------------------------------- */
/* -----LOGO ANIMATIONS ----- */
/* ---------------------------------------------------------------- */
/* #region Logo  */

	/* Rock */
	@keyframes rock {
		0%   { transform: rotate(0deg); }
		20%  { transform: rotate(30deg); }
		40%  { transform: rotate(-25deg); }
		60%  { transform: rotate(20deg); }
		80%  { transform: rotate(-10deg); }
		100% { transform: rotate(0deg); }
	}
	/* Spin */
	@keyframes spin {
		0%   { transform: rotate(0deg); }
		100% { transform: rotate(360deg); }
	}
	/* 3D Tilt Pop */
	@keyframes tilt-pop {
		0%   { transform: rotate(0) scale(1); }
		25%  { transform: rotateY(40deg) rotateX(18deg) scale(1.2); }
		55%  { transform: rotateY(-30deg) rotateX(-12deg) scale(1.08); }
		75%  { transform: rotateY(15deg) rotateX(6deg) scale(1.04); }
		100% { transform: rotate(0) scale(1); }
	}
	/* Horizontal Flip */
	@keyframes flip-horizontal {
		0%   { transform: rotateY(0deg); }
		50%  { transform: rotateY(180deg); }
		100% { transform: rotateY(360deg); }
	}

	/* Pop Jump Scale */
	@keyframes pop-jump {
		0%   { transform: scale(1); }
		30%  { transform: scale(1.25); }  /* fast punch */
		55%  { transform: scale(0.95); }  /* gravity dip */
		75%  { transform: scale(1.05); }  /* small rebound */
		100% { transform: scale(1); }
	}

/* #endregion */

/* ---------------------------------------------------------------- */
/* ----- CONTACTS ----- */
/* ---------------------------------------------------------------- */
/* #region Contacts */

	.contact-btn { @apply btn-accent; }
	.contact-icon { display: none; }

/* #endregion */

/* ---------------------------------------------------------------- */
/* ----- TOGGLES ----- */
/* ---------------------------------------------------------------- */
/* #region Toggles */
	#theme-toggle, #hmbrgr-theme-toggle {
		width: 50px; height: 50px;
		border-radius: 50%;
		background: transparent; border: transparent;

		display: flex;
		align-items: center; justify-content: center;
		cursor: pointer;
		transition: background 0.3s;
		z-index: 30;
		position: relative;
	}
