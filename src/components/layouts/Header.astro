---
import DarkMode from '../features/DarkMode.astro';
import PerformanceMode from '../features/PerformanceMode.astro';
const today = new Date();
---
<header class="flx-cntr-rw">
	<div class="header-brand">
		<img src="/logo/crazyblender-sm.webp" alt="CrazyBlender icon" class="header-icon" />
		<div class="name-path flx-clmn justify-start">
			<div class="name">Lucas Shiota</div>
		<div class="path">Game Designer</div>
		</div>
	</div>
	<div class="header-contacts">
		<div class="contact-btn"> <i class="contact-icon fa-solid fa-file-lines"></i></i>CV </div>
		<div class="contact-btn"> <i class="contact-icon fa-brands fa-linkedin-in"></i>LinkedIn </div>
		<div class="contact-btn"> <i class="contact-icon fa-solid fa-envelope"></i>Let's Talk <a href="mailto:lucasshiota@protonmail.com"></a></div>
		<div class="contact-btn"> <i class="contact-icon fa-solid fa-user"></i>About </div>
	</div>
	<div class="header-toggles">
		<button id="theme-toggle" class="theme-toggle" title="Toggle theme" aria-label="Toggle theme">
			<i class="fa-solid fa-sun icon-sun"></i>
			<i class="fa-solid fa-moon icon-moon"></i>
		</button>
		<button class="performance-toggle" id="performance-toggle" title="Toggle performance mode" aria-label="Toggle performance mode">
			<i class="fa-solid fa-wand-magic icon-magic"></i>
			<i class="fa-solid fa-wand-magic-sparkles icon-sparkles"></i>
		</button>
	</div>
	<div class="hmbrgr-menu-toggle-wrapper">
		<button id="hmbrgr-menu-toggle" title="Open Menu" aria-label="Open Menu">
			<i class="fa-solid fa-bars fa-xl" style="color: color-mix(in srgb, var(--accent-reverse) 100%, transparent);"></i>
		</button>
	</div>
	<DarkMode />
	<PerformanceMode />
	<script>
		const icon = document.querySelector<HTMLElement>('.header-icon');

		const animations = ['rock', 'spin', 'tilt-pop', 'flip-horizontal', 'pop-jump'];

		if (icon) {
			icon.addEventListener('mouseenter', () => {
				if (window.matchMedia('(pointer: fine)').matches) {
					const random = animations[Math.floor(Math.random() * animations.length)];
					icon.style.animation = `${random} 0.6s ease`;
				}
			});

			icon.addEventListener('animationend', () => {
				icon.style.animation = '';
			});
		}
	</script>
	<script>
		const menuToggle = document.getElementById('hmbrgr-menu-toggle');
		const mobileMenu = document.getElementById('hmbrgr-menu');
		const header = document.querySelector('header');

		if (menuToggle && mobileMenu && header) {
			menuToggle.addEventListener('click', () => {
				if (mobileMenu.classList.contains('closing')) {
					mobileMenu.classList.remove('closing');
					header.classList.add('menu-open');
					const icon = menuToggle.querySelector('i');
					if (icon) {
						icon.classList.remove('fa-bars');
						icon.classList.add('fa-xmark');
					}
				} else if (mobileMenu.classList.contains('open')) {
					mobileMenu.classList.add('closing');
					header.classList.remove('menu-open');
					const icon = menuToggle.querySelector('i');
					if (icon) {
						icon.classList.remove('fa-xmark');
						icon.classList.add('fa-bars');
					}
				} else {
					mobileMenu.classList.add('open');
					header.classList.add('menu-open');
					const icon = menuToggle.querySelector('i');
					if (icon) {
						icon.classList.remove('fa-bars');
						icon.classList.add('fa-xmark');
					}
				}
			});

			mobileMenu.addEventListener('animationend', (e) => {
				if (e.target === mobileMenu && mobileMenu.classList.contains('closing')) {
					mobileMenu.classList.remove('open');
					mobileMenu.classList.remove('closing');
				}
			});

			window.addEventListener('resize', () => {
				if (window.innerWidth > 900 && mobileMenu.classList.contains('open')) {
					mobileMenu.classList.remove('open');
					mobileMenu.classList.remove('closing');
					header.classList.remove('menu-open');
					const icon = menuToggle.querySelector('i');
					if (icon) {
						icon.classList.remove('fa-xmark');
						icon.classList.add('fa-bars');
					}
				}
			});

			// Proxy clicks for mobile toggles to original desktop toggles
			const mobileTheme = document.getElementById('hmbrgr-theme-toggle');
			const desktopTheme = document.getElementById('theme-toggle');
			if (mobileTheme && desktopTheme) {
				mobileTheme.addEventListener('click', () => {
					desktopTheme.click();
					// Sync icon state after click
					setTimeout(() => {
						const dIcon = desktopTheme.querySelector('i');
						const mIcon = mobileTheme.querySelector('i');
						if (dIcon && mIcon) mIcon.className = dIcon.className;
					}, 10);
				});
			}

			// hmbrgr Nav Logic
			const navItems = document.querySelectorAll('.hmbrgr-nav');
			navItems.forEach(item => {
				item.addEventListener('click', () => {
					const index = parseInt(item.getAttribute('data-index') || '0');
					const panels = document.querySelectorAll<HTMLElement>('.panel');
					if (panels[index]) {
						if (menuToggle) menuToggle.click();
						const top = panels[index].offsetTop - header.offsetHeight;
						window.scrollTo({ top, behavior: 'smooth' });
					}
				});
			});

			// Close menu when clicking outside (e.g., below the menu)
			document.addEventListener('click', (event) => {
				const target = event.target as HTMLElement;
				const isMenuOpen = mobileMenu.classList.contains('open');
				const isClickInsideMenu = mobileMenu.contains(target);
				const isClickOnToggle = menuToggle.contains(target);

				if (isMenuOpen && !isClickInsideMenu && !isClickOnToggle) {
					menuToggle.click();
				}
			});
		}
	</script>
</header>
	<div id="hmbrgr-menu">
		<div class="hmbrgr-row">
			<div class="hmbrgr-contacts">
				<div class="hmbrgr-contact-btn"> <i class="fa-solid fa-file-lines"></i></i>&#8194;CV </div>
				<div class="hmbrgr-contact-btn"> <i class="fa-brands fa-linkedin-in"></i>&#8194;LinkedIn </div>
				<div class="hmbrgr-contact-btn"> <i class="fa-solid fa-envelope"></i>&#8194;Let's Talk <a href="mailto:lucasshiota@protonmail.com"></a></div>
				<div class="hmbrgr-contact-btn"> <i class="fa-solid fa-user"></i>&#8194;About </div>
			</div>
			<div class="hmbrgr-nav-parent">
				<div class="hmbrgr-nav" data-index="0"> Hey </div>
				<div class="hmbrgr-nav" data-index="1"> Projects </div>
				<div class="hmbrgr-nav" data-index="2"> About Me </div>
				<div class="hmbrgr-nav" data-index="3"> Contacts </div>
			</div>
		</div>
		<div class="hmbrgr-toggles">
			<button id="hmbrgr-theme-toggle" class="theme-toggle" title="Toggle theme" aria-label="Toggle theme">
				<i class="fa-solid fa-sun icon-sun"></i>
				<i class="fa-solid fa-moon icon-moon"></i>
			</button>
			<button id="hmbrgr-performance-toggle" class="performance-toggle" title="Toggle performance mode" aria-label="Toggle performance mode">
				<i class="fa-solid fa-wand-magic icon-magic"></i>
				<i class="fa-solid fa-wand-magic-sparkles icon-sparkles"></i>
			</button>
		</div>
		<div class="credits-parent">
			<div class="credits-imadethis"> Site coded from scratch by me </div>
			<div class="credits-column-parent">
				<div class="credits-column">
					<div class="credits-set"> <div class="credits-contribution"> Physics </div> <div class="credits-source"> Matter.js </div> </div>
					<div class="credits-set"> <div class="credits-contribution"> Background </div> <div class="credits-source"> Vanta.js </div> </div>
					<div class="credits-set"> <div class="credits-contribution"> Animation </div> <div class="credits-source"> GSAP </div> </div>
				</div>
				<div class="credits-column">
					<div class="credits-set"> <div class="credits-contribution"> Images </div> <div class="credits-source"> TextureLabs </div> </div>
					<div class="credits-set"> <div class="credits-contribution"> Framework </div> <div class="credits-source"> Astro </div> </div>
					<div class="credits-set"> <div class="credits-contribution"> Hosting </div> <div class="credits-source"> Cloudflare </div> </div>
				</div>
			</div>
			<div class="credits-set"> <div class="credits-contribution"> Main Font </div> 
				<div class="credits-source"> Atkinson Hyperlegible Next <br> (Braille Institute of America)</div> </div>
			</div>
			<div class="copyright"> &copy; {today.getFullYear()} Lucas Shiota </div>
		</div>
		
	</div>
<style>
	@reference "../../styles/global.css";

/* ---------------------------------------------------------------- */
/* HEADER */
/* ---------------------------------------------------------------- */
/* #region Header */
	header {
		position: fixed; height: var(--header-height); width: 100%;
		@apply justify-between;
		opacity: var(--headfoot-opacity);
		background: var(--bg-color); box-shadow: var(--box-shadow);
	}

	header.menu-open { box-shadow: var(--box-shadow-small); }
	.header-brand, .header-toggles, .header-contacts, .hmbrgr-menu-toggle-wrapper {
		@apply flx-algncntr-rw;
		height: 80%; gap: 1rem;
	}
	.header-contacts, .header-toggles { display: none; }
	.header-brand { justify-content: flex-start; justify-self: flex-start; }
	.header-contacts { 
		justify-content: center; justify-self: center;
		flex: 1; font-weight: bold; 
		gap: clamp(0.5rem, 1vw, 1rem);
	}
	.header-toggles, .hmbrgr-menu-toggle-wrapper { justify-content: flex-end; justify-self: flex-end;}

/* #endregion */


/* ---------------------------------------------------------------- */
/* ----- BRAND ----- */
/* ---------------------------------------------------------------- */
/* #region Brand */

	.name { font-size: 1.33rem; font-weight: 700; white-space: nowrap; line-height: 1.2; }
	.path { font-size: 1.33rem; font-weight: 300; line-height: 1.2; }

	.header-icon {
		width: 50px; height: 50px;
		object-fit: contain; display: block; margin-left: 1rem;
		user-select: none;
		transform-origin: center; transform-style: preserve-3d; /* Anim */
	}
 
/* #endregion */


/* ---------------------------------------------------------------- */
/* -----LOGO ANIMATIONS ----- */
/* ---------------------------------------------------------------- */
/* #region Logo  */

	/* Rock */
	@keyframes rock {
		0%   { transform: rotate(0deg); }
		20%  { transform: rotate(30deg); }
		40%  { transform: rotate(-25deg); }
		60%  { transform: rotate(20deg); }
		80%  { transform: rotate(-10deg); }
		100% { transform: rotate(0deg); }
	}
	/* Spin */
	@keyframes spin {
		0%   { transform: rotate(0deg); }
		100% { transform: rotate(360deg); }
	}
	/* 3D Tilt Pop */
	@keyframes tilt-pop {
		0%   { transform: rotate(0) scale(1); }
		25%  { transform: rotateY(40deg) rotateX(18deg) scale(1.2); }
		55%  { transform: rotateY(-30deg) rotateX(-12deg) scale(1.08); }
		75%  { transform: rotateY(15deg) rotateX(6deg) scale(1.04); }
		100% { transform: rotate(0) scale(1); }
	}
	/* Horizontal Flip */
	@keyframes flip-horizontal {
		0%   { transform: rotateY(0deg); }
		50%  { transform: rotateY(180deg); }
		100% { transform: rotateY(360deg); }
	}

	/* Pop Jump Scale */
	@keyframes pop-jump {
		0%   { transform: scale(1); }
		30%  { transform: scale(1.25); }  /* fast punch */
		55%  { transform: scale(0.95); }  /* gravity dip */
		75%  { transform: scale(1.05); }  /* small rebound */
		100% { transform: scale(1); }
	}

/* #endregion */


/* ---------------------------------------------------------------- */
/* ----- CONTACTS ----- */
/* ---------------------------------------------------------------- */
/* #region Contacts */

	.contact-btn { @apply btn-accent; }
	.contact-icon { display: none; }

/* #endregion */


/* ---------------------------------------------------------------- */
/* ----- TOGGLES ----- */
/* ---------------------------------------------------------------- */
/* #region Toggles */
	#theme-toggle, #hmbrgr-theme-toggle {
		width: 50px; height: 50px;
		border-radius: 50%;
		background: transparent; border: transparent;

		display: flex;
		align-items: center; justify-content: center;
		cursor: pointer;
		transition: background 0.3s;
		z-index: 30;
		position: relative;
	}
	@media (hover: hover) {
		#theme-toggle:hover, #hmbrgr-theme-toggle:hover {
			background: rgba(var(--gray), 0.3);
		}
	}
	.theme-toggle i {
		position: absolute;
		color: var(--text-color);
		font-size: 1.5rem;
		transition: color 0.3s, transform 0.3s, opacity 0.3s;
	}

	/* Theme Toggle Logic */
	/* Light Mode (Sun Base, Moon Hover) */
	html:not([data-theme="dark"]) .icon-sun { opacity: 1; pointer-events: auto; }
	html:not([data-theme="dark"]) .icon-moon { opacity: 0; pointer-events: none; }
	@media (hover: hover) {
		html:not([data-theme="dark"]) .theme-toggle:hover .icon-sun { opacity: 0; }
		html:not([data-theme="dark"]) .theme-toggle:hover .icon-moon { opacity: 1; }
	}

	/* Dark Mode (Moon Base, Sun Hover) */
	html[data-theme="dark"] .icon-sun { opacity: 0; pointer-events: none; }
	html[data-theme="dark"] .icon-moon { opacity: 1; pointer-events: auto; }
	@media (hover: hover) {
		html[data-theme="dark"] .theme-toggle:hover .icon-sun { opacity: 1; }
		html[data-theme="dark"] .theme-toggle:hover .icon-moon { opacity: 0; }
	}
	.performance-toggle {
		width: 50px; height: 50px;
		border-radius: 50%;
		background: transparent; border: transparent;
		margin: 0 0.75rem 0 0;
		
		display: flex; align-items: center; justify-content: center;
		cursor: pointer;
		transition: background 0.3s;
		z-index: 30;
		position: relative;
	}
	html.mobile-device .performance-toggle { display: none !important; }
	@media (hover: hover) {
		.performance-toggle:hover { background: rgba(var(--gray), 0.3); }
	}
	.performance-toggle i {
		position: absolute;
		color: var(--text-color);
		font-size: 1.2rem;
		transition: color 0.3s, transform 0.3s, opacity 0.3s;
	}

	/* Toggle Logic */
	/* When Performance Mode is OFF (Sparkles Base, Magic Hover) */
	html:not(.performance-mode) .icon-sparkles { opacity: 1; pointer-events: auto; }
	html:not(.performance-mode) .icon-magic { opacity: 0; pointer-events: none; }
	@media (hover: hover) {
		html:not(.performance-mode) .performance-toggle:hover .icon-sparkles { opacity: 0; }
		html:not(.performance-mode) .performance-toggle:hover .icon-magic { opacity: 1; }
	}

	/* When Performance Mode is ON (Magic Base, Sparkles Hover) */
	html.performance-mode .icon-sparkles { opacity: 0; pointer-events: none; }
	html.performance-mode .icon-magic { opacity: 1; pointer-events: auto; }
	@media (hover: hover) {
		html.performance-mode .performance-toggle:hover .icon-sparkles { opacity: 1; }
		html.performance-mode .performance-toggle:hover .icon-magic { opacity: 0; }
	}

/* #endregion */


/* ---------------------------------------------------------------- */
/* ----- hmbrgr MENU ----- */
/* ---------------------------------------------------------------- */
/* #region hmbrgr */

	/* #region Ham Styles */
		#hmbrgr-menu {
			position: fixed; width: 100%; left: 0; top: var(--header-height);
			background: var(--bg-color-tinted); box-shadow: var(--box-shadow); opacity: 1;
			border-top: 1px solid rgba(var(--gray), 0.2);
			display: none; flex-direction: column; justify-content: center; align-items: center;
		}
		#hmbrgr-menu.open { display: flex; animation: slideDown 0.3s ease-out; }
		#hmbrgr-menu.closing { animation: slideUp 0.3s ease-in forwards; }

		@keyframes slideDown {
			from { opacity: 0; transform: translateY(-10px); }
			to { opacity: 1; transform: translateY(0); }
		}
		@keyframes slideUp {
			from { opacity: 1; transform: translateY(0); }
			to { opacity: 0; transform: translateY(-10px); }
		}
		#hmbrgr-menu-toggle {
			width: 50px; height: 50px;
			display: flex; align-items: center; justify-content: center;
			margin-right: 1rem;
			background: transparent; border: transparent; border-radius: 50%;
			cursor: pointer;
			transition: background 0.3s;
		}

		@media (hover: hover) {
			#hmbrgr-menu-toggle:hover { background: rgba(var(--gray), 0.3); }
		}
		#hmbrgr-menu-toggle i { color: var(--text-color); }
		.hmbrgr-row { display: flex; flex-direction: row; justify-content: center;
			width: 100%; padding: 0.5rem 0; }

	/* #endregion */

	/* #region Credits */
		
		.credits-parent {
			display: flex; flex-direction: column;
			align-items: center; justify-content: center;
			width: 70%; padding: 1rem 0; gap: 0.2rem;
			border-bottom: var(--border);
		}
		.credits-imadethis { font-size: 1.1rem; color: var(--accent-reverse); font-weight: bold;}
		.credits-column-parent { display: flex; flex-direction: row; justify-content: center; }
		.credits-column {
			display: flex; flex-direction: column;
			align-items: center; justify-content: center;
 			gap: 0.33rem;
		}
		.credits-contribution{font-weight: 200;}
		.credits-source { font-weight: 500;}
		.credits-contribution, .credits-source { font-size: 0.9rem; line-height: 1.3;}
		.credits-set {
			display: flex; flex-direction: row; gap: 0.4rem;
			align-items: center; justify-content: center;
		}

		.copyright { display: flex; justify-content: center; align-items: center; padding: 1rem 0; }
	/* #endregion */

	/* #region Ham Toggle */
	.hmbrgr-toggles {
		width: 70%;
		display: flex; flex-direction: row; justify-content: center;
		gap: 1rem; padding: 0.5rem 0;
		border-bottom: var(--border); border-top: var(--border);
	}
	#hmbrgr-theme-toggle, #hmbrgr-performance-toggle {
		width: 50px; height: 50px;
		border-radius: 50%;
		background: transparent; border: transparent;
		display: flex; align-items: center; justify-content: center;
		cursor: pointer;
		transition: background 0.3s;
	}
	@media (hover: hover) {
		#hmbrgr-theme-toggle:hover, #hmbrgr-performance-toggle:hover { 
			background: rgba(var(--gray), 0.3); }
	}
	#hmbrgr-theme-toggle i, #hmbrgr-performance-toggle i { 
		color: var(--text-color); font-size: 1.5rem; }

	/* #endregion */

	/* #region Ham Contact + Nav */

	.hmbrgr-contacts { border-right: var(--border) }
	.hmbrgr-contact-btn { @apply btn-accent; }
	
	.hmbrgr-nav { @apply btn-hvracnt btn;
		transition: color 0.3s; font-size: 1.3rem; line-height: 0.9;
		padding: .7rem;
	}

	.hmbrgr-nav-parent, .hmbrgr-contacts { @apply flx-cntr-clmn;
		gap: .5rem; width: 40%; padding: 0.5rem 0;
	}

	/* #endregion */

/* #endregion */
	

/* ---------------------------------------------------------------- */
/* ----- QUERY ----- */
/* ---------------------------------------------------------------- */
/* #region Query */

	@media (min-width: 300px) { /* #1: Default Phone -  Most Elements*/ 	}

	@media (min-width: 640px) { /* #2: Large Phone - Shrink, Hide, Remove Some Elements */
		.header-contacts { display: flex; } /* Show */
		.hmbrgr-contacts { display: none; } /* Hide */
	}
	@media (min-width: 768px) { /* #3: Tablet - Start Shrink, Remove Elements */
		.contact-icon { display: flex; } /* Show */
		.hmbrgr-nav-parent, .hmbrgr-row  { display: none; } /* Hide */
		.hmbrgr-toggles { border-top: none; }
	}
	@media (min-width: 1200px) { /* #4: Laptop */
		.hmbrgr-toggles { display: none; } /* Hide */
		.header-toggles, .contact-icon { display: flex; } /* Show */
	}

/* #endregion */


</style>
