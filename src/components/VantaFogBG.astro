<div id="vanta-bg"></div>
		<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"></script>
		<script is:inline src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.fog.min.js"></script>
    <script>
			
			declare const VANTA: any;
			const css = getComputedStyle(document.documentElement);
			const hexToNumber = (hex: string) =>
				Number(hex.replace('#', '0x'));

    	VANTA.FOG({
        el: '#vanta-bg',
        mouseControls: true,
        touchControls: true,
        gyroControls: false,
        minHeight: 200.00,
        minWidth: 200.00,
				highlightColor: hexToNumber(css.getPropertyValue('--vanta-highlight').trim()),
				midtoneColor: hexToNumber(css.getPropertyValue('--vanta-midtone').trim()),
				lowlightColor: hexToNumber(css.getPropertyValue('--vanta-lowlight').trim()),
				baseColor: hexToNumber(css.getPropertyValue('--vanta-base').trim()),
        blurFactor: 0.90,
				speed: 1.2,
  			zoom: 0.8
    	})
    </script>