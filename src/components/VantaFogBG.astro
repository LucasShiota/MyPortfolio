<div id="vanta-bg"></div>
<style>
  #vanta-bg {
    position: fixed;
    inset: 0;
    z-index: -1;
  }
</style>

<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.fog.min.js"></script>

<script>
  declare const VANTA: any;

  function initVantaWithRetry(retries = 30) {
    if (window.vantaEffect) return;

    if (typeof VANTA === "undefined" || typeof VANTA.FOG !== "function") {
      if (retries > 0) {
        setTimeout(() => initVantaWithRetry(retries - 1), 100);
      }
      return;
    }

    const css = getComputedStyle(document.documentElement);
    const hexToNumber = (hex: string) => Number(hex.replace('#', '0x'));

    window.vantaEffect = VANTA.FOG({
      el: '#vanta-bg',
      mouseControls: true,
      touchControls: true,
      gyroControls: false,
      minHeight: 200.0,
      minWidth: 200.0,
      highlightColor: hexToNumber(css.getPropertyValue('--vanta-highlight').trim()),
      midtoneColor: hexToNumber(css.getPropertyValue('--vanta-midtone').trim()),
      lowlightColor: hexToNumber(css.getPropertyValue('--vanta-lowlight').trim()),
      baseColor: hexToNumber(css.getPropertyValue('--vanta-base').trim()),
      blurFactor: 0.9,
      speed: 1.2,
      zoom: 0.8
    });
  }

  window.addEventListener("startup:vanta", () => {
    initVantaWithRetry();
  }, { once: true });
</script>
