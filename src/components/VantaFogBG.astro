<div id="vanta-bg"></div>
<style>
  #vanta-bg {
    position: fixed;
    inset: 0;
    z-index: -1;
  }
</style>

<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.fog.min.js"></script>

<script>
  declare const VANTA: any;
  const vantaBgSelector = "#vanta-bg";

  function initVantaWithRetry(retries = 30) {
    if (window.__simpleModeEnabled || window.vantaEffect) return;

    if (typeof VANTA === "undefined" || typeof VANTA.FOG !== "function") {
      if (retries > 0) {
        setTimeout(() => initVantaWithRetry(retries - 1), 100);
      }
      return;
    }

    const css = getComputedStyle(document.documentElement);
    const hexToNumber = (hex: string) => Number(hex.replace('#', '0x'));

    window.vantaEffect = VANTA.FOG({
      el: vantaBgSelector,
      mouseControls: true,
      touchControls: true,
      gyroControls: false,
      minHeight: 200.0,
      minWidth: 200.0,
      highlightColor: hexToNumber(css.getPropertyValue('--vanta-highlight').trim()),
      midtoneColor: hexToNumber(css.getPropertyValue('--vanta-midtone').trim()),
      lowlightColor: hexToNumber(css.getPropertyValue('--vanta-lowlight').trim()),
      baseColor: hexToNumber(css.getPropertyValue('--vanta-base').trim()),
      blurFactor: 0.9,
      speed: 0.7,
      zoom: 0.8,
      scale: 1,
      scaleMobile: 0.6
    });
  }

  function freezeVanta() {
    const container = document.querySelector<HTMLElement>(vantaBgSelector);
    const canvas = container?.querySelector<HTMLCanvasElement>("canvas");

    if (container && canvas) {
      try {
        container.style.backgroundImage = `url("${canvas.toDataURL("image/png")}")`;
      } catch {
        container.style.backgroundImage = "";
      }
      container.style.backgroundSize = "cover";
      container.style.backgroundPosition = "center";
      container.style.backgroundRepeat = "no-repeat";
    }

    if (window.vantaEffect?.destroy) {
      window.vantaEffect.destroy();
    }
    delete window.vantaEffect;
  }

  function resumeVanta() {
    const container = document.querySelector<HTMLElement>(vantaBgSelector);
    if (container) {
      container.style.backgroundImage = "";
      container.style.backgroundSize = "";
      container.style.backgroundPosition = "";
      container.style.backgroundRepeat = "";
    }
    initVantaWithRetry();
  }

  window.simpleModeVanta = {
    freeze: freezeVanta,
    resume: resumeVanta
  };

  window.addEventListener("startup:vanta", () => {
    resumeVanta();
  });
</script>
