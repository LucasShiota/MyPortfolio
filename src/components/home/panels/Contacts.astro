---
const today = new Date();
---
<div class="panel contacts-panel">
	<div id="matter-container"></div>
	<div class="matter-tooltip-parent">
		<div class="matter-tooltip-link">Links&#8201;<i class="fa-solid fa-circle"></i></div>
		<div class="matter-tooltip-interactable"></i>Interactable&#8201;<i class="fa-solid fa-circle"></i></div>
	</div>
	<div class="footerino">
		<div class="extra-info">
			<div class="extra-part"> <i class="fa-solid fa-timeline"></i>&#8194;Resume </div>
			<div class="extra-part"> <i class="fa-solid fa-envelope"></i>&#8194;Let's Talk <a href="mailto:lucasshiota@protonmail.com"></a></div>
			<div class="extra-part"> <i class="fa-solid fa-location-dot"></i>&#8201;Tokyo, Japan</div>
		</div>
		<div> &copy; {today.getFullYear()} Lucas Shiota. All rights reserved. </div>
	</div>
</div>

<style>

	.contacts-panel{
		padding-bottom: var(--footer-height);
		height: calc(var(--panel-height) - var(--footer-height));
		flex-direction: column; display: flex;
	}
	#matter-container {
		width: 100%;
		height: 100%;
		display: flex; flex-direction: column;
		touch-action: auto;
	}
	.footerino {
		position: absolute; bottom: -300vh;
    width: 100vw; height: var(--footer-height);
		padding: 0 2em; gap: 0.5em;
		background: var(--bg-color); box-shadow: var(--box-shadow); 
		opacity: var(--headfoot-opacity);
    align-items: center; justify-content: center; display: flex; flex-direction: column;
    box-sizing: border-box;
	}
	.extra-info {
		display: flex; flex-direction: row;
		width: 40%; height: 30%;
		justify-content: space-evenly; align-items: center;
		gap: 0.5em;
	}
	.extra-part {
		width: 25%; height: 100%;
		display: flex; align-items: center; justify-content: center;
    border-radius: 9999px;
		background: color-mix(in srgb, var(--accent-reverse) 20%, transparent);
		border: 1px solid color-mix(in srgb, var(--accent-reverse) 50%, transparent);
		color: var(--accent-reverse);
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.3s ease;
	}
	
	.extra-part:hover {
    transform: translateY(-2px) scale(1.03);
    box-shadow: var(--box-shadow);
  }

	.matter-tooltip-parent {
		position: absolute; right: 2%; bottom: -288%;
		height: 10%; width: 20%;
		display: flex; flex-direction: row; align-items: center; justify-content: center; 
		font-weight: bolder; 
		opacity: 0.6; transition: 0.5s opacity ease;
		user-select: none;
	}
	/*.matter-tooltip-parent:hover { opacity: 0.6; }*/
		
	.matter-tooltip-interactable, .matter-tooltip-link {
		text-align: right;
		width: 100%;
	}
	.matter-tooltip-link { color:#0062F5 ;}
	.matter-tooltip-interactable { color: #F5A300 ;}
</style>
