---
import HeroBGText from "../HeroBGText.astro"
---
<div class="panel hero-panel">
  <div class="hero-foreground">
    <div class="hero-fg-parent">
      <div class="hero-fg-hello"> I'm Lucas </div>
      <div class="hero-fg-tagline"> 
        Eclectic Solo Game Dev. 
        Always fantasizing & experimenting to bring something fresh, new, & different to the table.
        Because thats whats most fun & interesting.
      </div>
    </div>
    <div class="headshot-wrapper">
      <div id="flip-card" class="flip-container">
        <div class="flipper">
          <div class="front">
            <img class="headshot" src="../images/headshot.webp" alt="Headshot" />
          </div>
          <div class="back">
            <img class="headshot" src="/logo/crazyblenderV2.webp" alt="CrazyBlender" />
          </div>
        </div>
      </div>
    </div>
  </div>
  <HeroBGText />
</div>
<style>
  /* Panel */
  /* #region Panel */
  .hero-panel {
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
  }

  .hero-foreground {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    z-index: 2;
    position: absolute;
    inset: 0;
    height: var(--panel-height);
    width: calc(100% - var(--sidebar-width));
    padding: 2rem;
    gap: 1rem;
  }

  .hero-fg-parent, .headshot-wrapper {
    height: 70%; width: 50%;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    user-select: none;
  }

  .hero-fg-hello, .hero-fg-tagline {
    font-family: "AtkinsonNext";
    font-weight: 700;
    text-align: center; justify-content: right;
    
    display: flex;
  }

  .hero-fg-hello {
    font-size: 8vh;
    align-items: flex-end;
  }

  .hero-fgtext-tagline {
    font-size: 4vh;
    align-items: flex-start;
  }
  /* #endregion */

  /* Flip Container */
  /* #region Flip Container */

  .flip-container {
    width: 360px; height: 360px; perspective: 1000px;
    cursor: pointer; user-select: none; -webkit-user-select: none;
    transition: transform 0.3s ease;
    border-radius: 50%;
  }

  @media (hover: hover) {
    .flip-container:hover { transform: scale(1.05); }
  }

  .flipper {
    position: relative; width: 100%; height: 100%;
    user-select: none;
    transition: transform 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    transform-style: preserve-3d;
  }

  .flip-container.flipped .flipper { transform: rotateY(540deg); }

  .front, .back {
    position: absolute; width: 100%; height: 100%;
    -webkit-backface-visibility: hidden; backface-visibility: hidden;
    border-radius: 50%;
    user-select: none;
  }

  .front { z-index: 2; transform: rotateY(0deg); }
  .back { transform: rotateY(180deg); }
  .headshot {
    width: 100%; height: 100%;
    aspect-ratio: 1 / 1; object-fit: cover;
    border-radius: 50%; box-shadow: var(--box-shadow);
    user-select: none; -webkit-user-select: none; -webkit-user-drag: none;
    border: 6px solid transparent;
    border-color: color-mix(in srgb, var(--accent-reverse) 40%, transparent);
    transition: all 0.6s ease;
  }

  @media (hover: hover) {
    .flip-container:hover .headshot { 
      border-color: color-mix(in srgb, var(--accent-reverse) 80%, transparent);
    }
  }
  /* #endregion */
</style>

<script>
  const card = document.getElementById('flip-card');
  if (card) {
    card.addEventListener('click', () => {
      card.classList.toggle('flipped');
    });
  }
</script>
