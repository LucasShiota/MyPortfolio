---
import type { Project } from "./projectsData";

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
---

<div class="projects-preview-parent flx-cntr-clmn">
  {projects.map((project) => (
    <div class="preview-entry" data-project-id={project.id}>
      <header class="preview-header">
        <h3 class="preview-title">
          {project.title.split("\n").map((line, lineIndex, lines) => (
            <>
              {line}
              {lineIndex < lines.length - 1 && <br />}
            </>
          ))}
        </h3>
      </header>

      {project.descriptorTags && project.descriptorTags.length > 0 && (
        <div class="descriptor-tags-container flx-algncntr-rw">
          {project.descriptorTags.map(tag => {
            const color = project.descriptorTagColors?.[tag] || 'blue';
            const colorClass = {
              green: 'btn-tag-green',
              purple: 'btn-tag-purple',
              red: 'btn-tag-red',
              blue: 'btn-tag-blue'
            }[color];
            return <span class={`descriptor-tag btn-type-tag ${colorClass}`}>{tag}</span>
          })}
        </div>
      )}

      <div class="preview-media">
        {project.previewVideo ? (
          <video 
            src={project.previewVideo} 
            autoplay 
            muted 
            loop 
            playsinline 
            poster={project.previewImage}
            class="media-content"
          />
        ) : (
          <img 
            src={project.previewImage} 
            alt={project.thumbnailAlt} 
            class="media-content"
          />
        )}
      </div>

      <div class="preview-body-text">
        <div class="body-content" set:html={project.body} />
      </div>
      
      <footer class="preview-footer">
        <a
          class="preview-link-btn"
          href={project.previewButton.href}
          aria-label={project.previewButton.ariaLabel}
        >
          {project.previewButton.text}
        </a>
      </footer>
    </div>
  ))}
</div>

<style is:global>
  @reference "../../../styles/global.css";
  
  .projects-preview-parent {
    @apply surface-panel;
    position: relative; 
    width: 96%; height: 96%; /* Increased real estate */
    overflow: hidden;

  }

  .preview-entry {
    display: grid;
    /* Mobile/Tablet Template: Cinematic Top, Story Split Below */
    grid-template-areas: 
      "header header"
      "tags   tags"
      "body   media"
      "body   footer";
    grid-template-columns: 1.3fr 1fr; /* Balanced split for smaller screens */
    grid-template-rows: auto auto 1fr auto;
    row-gap: 0.7rem;
    column-gap: 1.2rem;
    
    position: absolute;
    inset: 1rem;
    padding: 0rem;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.4s ease, visibility 0.4s ease, transform 0.4s cubic-bezier(0.2, 0, 0.2, 1);
    transform: translateY(20px);
    z-index: 1;
    box-sizing: border-box;
  }

  /* Desktop/Laptop Template: 'Pro' Dashboard Split */
  @media (min-width: 1024px) {
    .preview-entry {
      grid-template-areas: 
        "header tags"
        "body   media"
        "body   footer";
      grid-template-columns: 1.8fr 1fr;
      grid-template-rows: auto 1fr auto; /* Header/Tag row stays compact */
      row-gap: 1rem;
      column-gap: 3.5rem;
      inset: 1.5rem;
    }

    .preview-media, 
    .descriptor-tags-container {
      justify-content: flex-end;
      @apply text-right;
    }
  }

  .preview-entry.active { 
    opacity: 1; 
    visibility: visible;
    pointer-events: auto;
    transform: translateY(0);
    z-index: 10; 
  }

  /* Assign Areas */
  .preview-header { 
    
    grid-area: header; 
    container-type: inline-size; /* Enable container query units for title scaling */
    width: 100%;
    min-width: 0; /* Prevents flex/grid blowout */
  }
  .descriptor-tags-container { grid-area: tags; }
  .preview-body-text { grid-area: body; }
  .preview-footer { grid-area: footer; }
  /* Media Container: Now a flex wrapper to center/limit the square */
  .preview-media {
    grid-area: media;
    width: 100%;
    height: 100%;
    min-height: 0;
    display: flex;
    justify-content: flex-start;
    align-items: flex-start;
  }

  .media-content {
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: 100%;
    aspect-ratio: 1 / 1;
    object-fit: contain;
    display: block;
    background: rgba(var(--black), 0.08);
    border-radius: 24px;
    overflow: hidden;
    box-shadow: var(--box-shadow-small);
    transition: transform 0.6s ease;
  }

  .preview-entry.active .media-content {
    transform: scale(1.02);
  }

  /* Typography Refinement & Scale-to-Fit Title */
  .preview-title {
    margin: 0;
    @apply leading-snug; @apply font-black; @apply txt-h3;
    
    /* SCALE-TO-FIT LOGIC: */
    white-space: nowrap; /* Force one line */
    overflow: hidden;
    text-overflow: ellipsis; /* Will show "..." if it absolutely can't fit */
    display: block;
    width: 100%;
  }

  .descriptor-tags-container {
    grid-area: tags;
    display: flex !important;
    flex-wrap: wrap; /* Wrap on small screens */
    gap: clamp(0.2rem, 0.5vh, 0.5rem);
    margin-top: 0.2rem;
    margin-bottom: 0.5rem;
  }

  .preview-body-text {
    font-size: clamp(0.9rem, 1.8vh, 1.1rem);
    @apply leading-relaxed;
    opacity: 0.85;
    @apply text-left;
    overflow: hidden;
    position: relative;
    
    /* Premium Fade-out Mask for Overflow */
    mask-image: linear-gradient(to bottom, black 75%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 75%, transparent 100%);
  }

  /* Style HTML content inside the body */
  .body-content ul, .body-content ol {
    margin-top: 0.4rem;
    margin-bottom: 0.6rem;
    padding-left: 1.2rem;
    list-style-position: outside;
  }

  .body-content ul {
    list-style-type: disc;
  }

  .body-content ol {
    list-style-type: decimal;
  }

  .body-content li {
    margin-bottom: 0.3rem;
    @apply txt-body; 
    @apply leading-snug;
    display: list-item;
  }

  .body-content p {
    margin-bottom: 1.25rem; /* Increased significantly for clearer separation */
  }

  /* Reduce spacing for the very last child to avoid double-padding against footer */
  .body-content > *:last-child {
    margin-bottom: 0;
  }

  .body-content strong, .body-content b {
    @apply font-bold;
    color: rgb(var(--text-color));
  }

  /* Footer & Button Positioning (Right Column) */
  .preview-footer {
    display: flex;
    justify-content: flex-end; /* Align with the right-column media/tags */
    align-items: flex-end;
  }

  .preview-link-btn {
    @apply btn-type-main;
    min-width: 140px;
    padding-top: clamp(0.8rem, 2vh, 1.2rem); 
    padding-bottom: clamp(0.8rem, 2vh, 1.2rem);
  }

  /* Ensure filtered out entries are completely removed from layout */
  .project-entry.is-filtered-out, 
  .preview-entry.is-filtered-out { 
    display: none !important; 
  }
</style>
