<script>
	interface Window {
		performanceModeScroll?: any;
		__performanceModeEnabled?: boolean;
	}

	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";
	import { ScrollToPlugin } from "gsap/ScrollToPlugin";

	gsap.registerPlugin(ScrollTrigger, ScrollToPlugin);

	// Archived panel arrow nav (disabled by request)
	// const upArrow = document.querySelector<HTMLElement>('[data-panel-nav="up"]');
	// const downArrow = document.querySelector<HTMLElement>('[data-panel-nav="down"]');
	const sidebar = document.querySelector<HTMLElement>(".sidebar");
	const navSections = document.querySelectorAll<HTMLElement>(".nav-section");
	const panels = gsap.utils.toArray<HTMLElement>(".panel");
	const SECTION_INDEX_STEP = 2;
	const ICON_BASE_SCALE = 1;
	const SIDEBAR_SCALE = {
		min: 1,
		max: 1.45,
		falloffRate: 1,
		falloffPower: 1.7
	} as const;

	const totalSteps = panels.length - 1;
	const step = totalSteps > 0 ? 1 / totalSteps : 1;

	let currentIndex = 0;
	let lastIndex = -1;
	let activeScrollTween: gsap.core.Tween | null = null;
	// let lastArrowState = { atTop: false, atBottom: false };
	const contactsEnterThreshold = gsap.utils.clamp(0, 1, 1 - step * 0.5);

	function updateSidebarFooterSpacing(progress: number) {
		if (!sidebar) return;
		sidebar.classList.toggle("contacts-entering", progress >= contactsEnterThreshold);
	}

	// Curve shape:
	// - steep drop after the active section (peak)
	// - then quickly settles toward min scale (short plateau)
	function getSidebarScaleByDistance(distanceFromActive: number): number {
		const falloff = Math.exp(
			-SIDEBAR_SCALE.falloffRate *
			Math.pow(distanceFromActive, SIDEBAR_SCALE.falloffPower)
		);
		return SIDEBAR_SCALE.min + (SIDEBAR_SCALE.max - SIDEBAR_SCALE.min) * falloff;
	}

	/* ------- PAGE REFRESH CORRECTIONS --------- */

  window.addEventListener("load", () => {
    window.scrollTo(0, 0);
		// Force ScrollTrigger to recalc and update immediately
		ScrollTrigger.refresh();
		uiTrigger.update();
  });
	function updateUI(progress: number) {
		currentIndex = Math.round(progress / step);

		if (currentIndex !== lastIndex) {
			lastIndex = currentIndex;
		}

		const activeSectionPosition = progress * totalSteps;
		navSections.forEach((sectionEl, sectionIndex) => {
			const sectionDistanceFromActive = Math.abs(sectionIndex - activeSectionPosition);
			const sectionScale = getSidebarScaleByDistance(sectionDistanceFromActive);
			sectionEl.style.transform = `scale(${sectionScale})`;

			const iconEl = sectionEl.querySelector<HTMLElement>(".navsec-icon");
			if (iconEl) {
				iconEl.style.transform = `translate(-50%, -50%) scale(${ICON_BASE_SCALE * sectionScale})`;
			}
		});

		updateSidebarFooterSpacing(progress);
	}

	/* ------- MASTER SCROLLTRIGGER --------- */
	let snapTrigger: any = null;

	const uiTrigger = ScrollTrigger.create({
		id: "ui-updates",
		trigger: document.body,
		start: "top top",
		end: "bottom bottom",
		scrub: 0.5,
		onUpdate: (self) => {
			updateUI(self.progress);
		}
	});

	const enableSnapping = () => {
		if (snapTrigger) return;
		snapTrigger = ScrollTrigger.create({
			id: "snapping",
			trigger: document.body,
			start: "top top",
			end: "bottom bottom",
			snap: {
				directional: false,
				snapTo: (progress) => {
					if (totalSteps <= 0) return 0;
					const closestIndex = Math.round(progress / step);
					const delta = (progress - closestIndex * step) / step;
					const threshold = 0.1;

					const targetIndex =
						Math.abs(delta) > threshold
							? closestIndex + (delta > 0 ? 1 : -1)
							: closestIndex;

					return gsap.utils.clamp(0, 1, targetIndex * step);
				},
				duration: { min: 0.2, max: 0.4 },
				delay: 0.03,
				ease: "power1.inOut"
			}
		});
	};

	const disableSnapping = () => {
		if (snapTrigger) {
			snapTrigger.kill();
			snapTrigger = null;
		}
	};

	window.performanceModeScroll = {
		enableSnap: enableSnapping,
		disableSnap: disableSnapping,
		refresh: () => {
			uiTrigger.refresh();
			if (snapTrigger) snapTrigger.refresh();
		}
	};

	// Only init snapping if performance mode is NOT enabled
	if (!window.__performanceModeEnabled) {
		enableSnapping();
	}
	
	// Initial UI update
	updateUI(uiTrigger.progress);


	/* ------- CENTRAL SCROLL FUNCTION --------- */

	function scrollToIndex(index: number) {
		if (totalSteps <= 0) return;
		const clamped = gsap.utils.clamp(0, totalSteps, index);
		const targetProgress = clamped * step;

		activeScrollTween?.kill();
		activeScrollTween = gsap.to(window, {
			duration: 0.8,
			scrollTo: {
				y:
					targetProgress *
					(document.body.scrollHeight - window.innerHeight)
			},
			ease: "power2.inOut"
		});
	}

	/* ------- NAV CLICK --------- */

	navSections.forEach((section) => {
		section.style.cursor = "pointer";

		section.addEventListener("click", () => {
			const navDataIndex = Number(section.dataset.index);
			if (Number.isNaN(navDataIndex)) return;
			const panelIndex = navDataIndex / SECTION_INDEX_STEP;
			scrollToIndex(panelIndex);
		});
	});

	/* ------- ARROWS (ARCHIVED / DISABLED) ---------
	upArrow?.addEventListener("click", () => { scrollToIndex(currentIndex - 1); });
	downArrow?.addEventListener("click", () => { scrollToIndex(currentIndex + 1); });

	function updateArrowVisibility() {
		if (!upArrow || !downArrow) return;

		const atTop = currentIndex === 0;
		const atBottom = currentIndex === totalSteps;

		if (lastArrowState.atTop === atTop && lastArrowState.atBottom === atBottom) {
			return;
		}

		lastArrowState = { atTop, atBottom };
		gsap.set(upArrow, { autoAlpha: atTop ? 0 : 0.2 });
		gsap.set(downArrow, { autoAlpha: atBottom ? 0 : 0.2 });
	}

	updateArrowVisibility();
	*/
	// Removed redundant direct call since createMainTrigger handles it
	// updateUI(mainTrigger.progress);

	window.addEventListener("beforeunload", () => {
		activeScrollTween?.kill();
		uiTrigger.kill();
		if (snapTrigger) snapTrigger.kill();
	}, { once: true });
</script>
