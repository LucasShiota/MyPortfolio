---
import type { Project } from "./projectsData";

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
---

<section class="project-list" aria-label="Project list">
  {projects.map((project) => (
    <button
      type="button"
      class="project-entry"
      data-project-id={project.id}
      data-project-tags={project.tags.join(",")}
      aria-pressed="false"
    >
      <h3 class="project-title">
        {project.title.split("\n").map((line, lineIndex, lines) => (
          <>
            {line}
            {lineIndex < lines.length - 1 && <br />}
          </>
        ))}
      </h3>
    </button>
  ))}
</section>

<style is:global>
  /*-------------------*/
  /* ----- FILTER -----*/
  /*-------------------*/
  /* #region Filter */
  .projects-filter-parent {
    width: 80%; height: 20%; 
    display: flex; flex-direction: row;
    align-items: center; justify-content: flex-end ;
    gap: 2em;
  }

  .project-filters {
    display: flex; flex-direction: row;
    align-items: center; justify-content: flex-start;
    flex-wrap: wrap;
    gap: 0.5rem;
    width: 60%;
    flex: 1;
    z-index: 2;
  }

  .project-filter-btn {
    border-radius: 9999px;
    border: 2px solid color-mix(in srgb, var(--accent-reverse) 80%, transparent);
    background-color: transparent;
    padding: 0.2rem 0.7rem;
    font-size: 1rem;
    color: inherit;
    cursor: pointer;
    pointer-events: auto;
    appearance: none;
    transition: background-color 0.2s ease;
  }

  .project-filter-btn.is-active,
  .project-filter-btn[aria-pressed="true"] {
    background-color: color-mix(in srgb, var(--accent-reverse) 40%, transparent);
  }
  /* #endregion */

  /*-------------------*/
  /* ----- NAV -----*/
  /*-------------------*/
  /* #region Nav */
  .project-list-nav {
    display: flex;
    flex-direction: column;
    height: 70%;
    justify-content: center;
    gap: 1em;
    padding-left: 3%;
    padding-right: 3%;
    flex: 0 0 auto;
  }

  .nav-arrow-button {
    border: none;
    background: transparent;
    font-size: 1.5rem;
    color: inherit;
    cursor: pointer;
  }

  .nav-arrow-button:focus-visible {
    outline: 2px solid rgba(var(--white), 0.8);
    outline-offset: 2px;
  }

  .nav-arrow-button:disabled {
    opacity: 0.3;
    cursor: default;
  }
  /* #endregion */

  /*-------------------*/
  /* ----- LIST -----*/
  /*-------------------*/
  /* #region List */
  .projects-list-parent {
    width: 100%;
    flex: 1;
    min-height: 0;
    display: flex;
    align-items: center;
  }
  .project-list {
    height: 70%; width: 100%;
    display: flex; flex-direction: column;
    padding: 0; gap: 1em;

    overflow-x: visible; overflow-y: auto;
    overscroll-behavior-y: contain; 
    touch-action: pan-y;
    
    box-sizing: border-box;
    scroll-behavior: smooth; scroll-snap-type: y mandatory;
    -ms-overflow-style: none; scrollbar-width: none;

    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 35%, black 65%, transparent 100%);
    -webkit-mask-repeat: no-repeat; -webkit-mask-size: 100% 100%;
    mask-image: linear-gradient(to bottom, transparent 0%, black 35%, black 65%, transparent 100%);
    mask-repeat: no-repeat; mask-size: 100% 100%;
  }

  .project-list::-webkit-scrollbar { display: none; }

  .project-entry {
    border: none;
    background: transparent;
    color: inherit;
    text-align: left;
    width: 100%;
    cursor: pointer;
    scroll-snap-align: center;
    min-height: 12vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    transform-origin: left center;
    transition: 0.5s ease;
    opacity: 0.6;
    transform: scale(0.95);
  }

  .project-entry.is-active {
    opacity: 1;
    transform: scale(1.2) translateX(2%);
  }

  .project-entry.is-hovering {
    opacity: 0.8;
    transform: scale(1);
  }

  .project-entry:focus-visible {
    outline: 2px solid rgba(var(--white), 0.8);
    outline-offset: 2px;
  }

  .project-title {
    font-size: clamp(1.5rem, 3vw, 3rem);
    font-family: "AtkinsonNext", sans-serif;
    line-height: 1.1;
    margin: 0;
  }

  /* #endregion
</style>
