---
import type { Project } from "./projectsData";

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
---

<section class="project-list flx-algncntr-rw" aria-label="Project list">
  <div class="project-entry project-entry-dummy" aria-hidden="true"></div>
  {projects.map((project) => (
    <button
      type="button"
      class="project-entry"
      data-project-id={project.id}
      data-project-tags={project.tags.join(",")}
      data-project-selectable="true"
      aria-pressed="false"
    >
      <img
        class="project-thumbnail"
        src={project.thumbnailSrc}
        alt={project.thumbnailAlt}
        loading="lazy"
        decoding="async"
      />
    </button>
  ))}
  <div class="project-entry project-entry-dummy" aria-hidden="true"></div>
</section>

<style is:global>
  @reference "../../../styles/global.css";

  /*-------------------*/
  /* ----- FILTER -----*/
  /*-------------------*/
  /* #region Filter */
  .projects-filter-parent {
    width: 100%;
    justify-content: flex-start;
    padding: 0 5%; gap: 1rem;
    
    box-sizing: border-box;
  }

  .project-filters {
    flex-wrap: wrap;
    gap: 0.5rem;
    width: 100%; z-index: 2;
    
  }

  .project-filter-btn {
    border-radius: 9999px;
    border: 2px solid color-mix(in srgb, var(--accent-reverse) 80%, transparent);
    background-color: transparent;
    padding: 0.2rem 0.7rem;
    font-size: 1rem;
    color: inherit;
    cursor: pointer; pointer-events: auto; user-select: none;
    
    appearance: none;
    transition: background-color 0.2s ease;
  }

  .project-filter-btn.is-active,
  .project-filter-btn[aria-pressed="true"] {
    background-color: color-mix(in srgb, var(--accent-reverse) 40%, transparent);
  }
  /* #endregion */

  /*-------------------*/
  /* ----- LIST -----*/
  /*-------------------*/
  /* #region List */
  .projects-list-parent {
    width: 90%; height: 20%;
    min-height: 0;
    display: flex; align-items: stretch;
  }
  .project-list {
    height: 100%; width: 100%;
    gap: clamp(0.75rem, 1.5vw, 1.25rem);

    overflow-x: auto; overflow-y: hidden;
    overscroll-behavior-x: contain;
    touch-action: pan-x;
    
    box-sizing: border-box;
    scroll-behavior: smooth; scroll-snap-type: x mandatory;
    -ms-overflow-style: none; scrollbar-width: none;

    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 14%, black 86%, transparent 100%);
    -webkit-mask-repeat: no-repeat; -webkit-mask-size: 100% 100%;
    mask-image: linear-gradient(to right, transparent 0%, black 14%, black 86%, transparent 100%);
    mask-repeat: no-repeat; mask-size: 100% 100%;
  }

  .project-list::-webkit-scrollbar { display: none; }

  .project-entry {
    @apply flx-cntr;
    border: 2px solid color-mix(in srgb, var(--accent-reverse) 20%, transparent);
    background: rgba(var(--black), 0.08);
    color: inherit;
    text-align: left;
    width: clamp(4.9rem, 12vw, 8.5rem);
    min-width: clamp(4.9rem, 12vw, 8.5rem);
    aspect-ratio: 1 / 1;
    cursor: pointer;
    scroll-snap-align: center;
    transform-origin: center center;
    transition: transform 0.35s ease, opacity 0.35s ease, border-color 0.35s ease;
    opacity: 0.55;
    transform: scale(0.95);
    border-radius: 1rem;
    overflow: hidden;
    padding: 0;
  }

  .project-entry-dummy {
    pointer-events: none;
    user-select: none;
    opacity: 0;
    transform: none;
    scroll-snap-align: none;
    border: 0;
    background: transparent;
  }

  .project-entry.is-active {
    opacity: 1;
    transform: scale(1.06);
    border-color: color-mix(in srgb, var(--accent-reverse) 75%, transparent);
  }

  .project-entry.is-hovering {
    opacity: 0.8;
    transform: scale(0.99);
  }

  .project-entry:focus-visible {
    outline: 2px solid rgba(var(--white), 0.8);
    outline-offset: 2px;
  }

  .project-thumbnail {
    width: 100%; height: 100%;
    
    object-fit: cover;
    display: block;
  }

  /* #endregion */
</style>
