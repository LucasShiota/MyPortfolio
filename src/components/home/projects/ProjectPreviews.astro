---
import type { Project } from "./projectsData";

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
---

<div class="projects-preview-parent flx-cntr-clmn">
  {projects.map((project) => (
    <div class="preview-entry flx-algncntr-clmn" data-project-id={project.id}>
      <h2 class="preview-header">
        <h3 class="preview-title">
          {project.title.split("\n").map((line, lineIndex, lines) => (
            <>
              {line}
              {lineIndex < lines.length - 1 && <br />}
            </>
          ))}
        </h3>
        {project.description && <p class="preview-desc">{project.description}</p>}
      </h2>
      <p class="preview-body">{project.preview}</p>
      <a
        class="preview-link-btn"
        href={project.previewButton.href}
        aria-label={project.previewButton.ariaLabel}
      >
        {project.previewButton.text}
      </a>
    </div>
  ))}
</div>
<style is:global>
  @reference "../../../styles/global.css";
  
  .projects-preview-parent {
    position: relative; width: 95%; height: 95%;
    overflow: visible;
    background: rgba(var(--black), 0.05);
    box-shadow: 0 2px 8px rgba(var(--black), 5%);
    border-radius: 50px;
  }

  .project-entry.is-filtered-out, .preview-entry.is-filtered-out { display: none; }

  .preview-entry {
    justify-content: flex-start;
    position: absolute;
    inset: 1rem;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .preview-header {
    width: 100%;
    margin-bottom: 0.6rem;
    text-align: left;
  }

  .preview-title {
    margin: 0 0 0.35rem;
    font-size: clamp(1.2rem, 2.1vw, 1.8rem);
    line-height: 1.12;
  }

  .preview-desc {
    margin: 0;
    opacity: 0.95;
    font-size: clamp(0.95rem, 1.4vw, 1.15rem);
    font-weight: 700;
    letter-spacing: 0.015em;
  }

  .preview-body { margin: 0; }
  .preview-entry.active { opacity: 1; z-index: 10; }
    
  .preview-link-btn {
    @apply btn-accent;
  }

  .preview-link-btn:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--accent-reverse) 75%, transparent);
    outline-offset: 2px;
  }
</style>
