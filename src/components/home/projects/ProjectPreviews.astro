---
import type { Project } from "./projectsData";

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
---

<div class="projects-preview-parent flx-cntr-clmn">
  {projects.map((project) => (
    <div class="preview-entry flx-algncntr-clmn" data-project-id={project.id}>
      <div class="preview-header">
        <h3 class="preview-title">
          {project.title.split("\n").map((line, lineIndex, lines) => (
            <>
              {line}
              {lineIndex < lines.length - 1 && <br />}
            </>
          ))}
        </h3>
        
        {project.descriptorTags && project.descriptorTags.length > 0 && (
          <div class="descriptor-tags-container flx-algncntr-rw">
            {project.descriptorTags.map(tag => (
              <span class="descriptor-tag">{tag}</span>
            ))}
          </div>
        )}

        {project.description && <p class="preview-desc">{project.description}</p>}
      </div>
      <p class="preview-body">{project.preview}</p>
      <a
        class="preview-link-btn"
        href={project.previewButton.href}
        aria-label={project.previewButton.ariaLabel}
      >
        {project.previewButton.text}
      </a>
    </div>
  ))}
</div>
<style is:global>
  @reference "../../../styles/global.css";
  
  .projects-preview-parent {
    position: relative; width: 95%; height: 95%;
    overflow: hidden;
    background: rgba(var(--black), 0.05);
    box-shadow: 0 2px 8px rgba(var(--black), 5%);
    border-radius: 50px;
  }

  .preview-entry {
    justify-content: flex-start;
    position: absolute;
    inset: 1rem;
    padding: 1rem;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.35s ease, visibility 0.35s ease, transform 0.35s ease;
    transform: translateY(10px);
    z-index: 1;
    
    box-sizing: border-box;
  }

  .preview-entry.active { 
    opacity: 1; 
    visibility: visible;
    pointer-events: auto;
    transform: translateY(0);
    z-index: 10; 
  }

  /* Ensure filtered out entries are completely removed from layout */
  .project-entry.is-filtered-out, 
  .preview-entry.is-filtered-out { 
    display: none !important; 
  }

  .preview-header {
    width: 100%;
    margin-bottom: 0.6rem;
    text-align: left;
  }

  .preview-title {
    margin: 0 0 0.35rem;
    font-size: clamp(1.2rem, 2.1vw, 1.8rem);
    line-height: 1.12;
  }

  .preview-desc {
    margin: 0;
    opacity: 0.95;
    font-size: clamp(0.95rem, 1.4vw, 1.15rem);
    font-weight: 700;
    letter-spacing: 0.015em;
  }

  .descriptor-tags-container {
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-bottom: 0.6rem;
  }

  .descriptor-tag {
    background-color: var(--accent-reverse);
    color: var(--bg-color); /* Highly contrasting text color */
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    font-size: clamp(0.75rem, 1vw, 0.85rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    user-select: none;
  }

  .preview-body { margin: 0; }
  .preview-entry.active { opacity: 1; z-index: 10; }
    
  .preview-link-btn {
    @apply btn-accent;
  }

</style>
