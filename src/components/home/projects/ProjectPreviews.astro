---
import type { Project } from "./projectsData";

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
---

<div class="projects-preview-parent flx-cntr-clmn">
  {projects.map((project) => (
    <div class="preview-entry" data-project-id={project.id}>
      <header class="preview-header">
        <h3 class="preview-title">
          {project.title.split("\n").map((line, lineIndex, lines) => (
            <>
              {line}
              {lineIndex < lines.length - 1 && <br />}
            </>
          ))}
        </h3>
      </header>

      {project.descriptorTags && project.descriptorTags.length > 0 && (
        <div class="descriptor-tags-container flx-algncntr-rw">
          {project.descriptorTags.map(tag => (
            <span class="descriptor-tag">{tag}</span>
          ))}
        </div>
      )}

      <div class="preview-media">
        {project.previewVideo ? (
          <video 
            src={project.previewVideo} 
            autoplay 
            muted 
            loop 
            playsinline 
            poster={project.previewImage}
            class="media-content"
          />
        ) : (
          <img 
            src={project.previewImage} 
            alt={project.thumbnailAlt} 
            class="media-content"
          />
        )}
      </div>

      <div class="preview-body-text">
        <p class="body-full">{project.body}</p>
        <p class="body-condensed">{project.condensedBody}</p>
      </div>
      
      <footer class="preview-footer">
        <a
          class="preview-link-btn"
          href={project.previewButton.href}
          aria-label={project.previewButton.ariaLabel}
        >
          {project.previewButton.text}
        </a>
      </footer>
    </div>
  ))}
</div>

<style is:global>
  @reference "../../../styles/global.css";
  
  .projects-preview-parent {
    position: relative; 
    width: 96%; height: 96%; /* Increased real estate */
    overflow: hidden;
    background: rgba(var(--black), 0.05);
    box-shadow: 0 4px 20px rgba(var(--black), 8%);
    border-radius: 40px; /* Slightly tighter radius for better content fit */
  }

  .preview-entry {
    display: grid;
    /* Mobile Layout: Vertical Stack */
    grid-template-areas: 
      "header"
      "tags"
      "media"
      "body"
      "footer";
    grid-template-columns: 1fr;
    grid-template-rows: auto auto minmax(140px, 30vh) 1fr auto;
    gap: 0.6rem;
    
    position: absolute;
    inset: 1.2rem; /* Halfway between original 1.5rem and tighter 0.8rem */
    padding: 0rem;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.4s ease, visibility 0.4s ease, transform 0.4s cubic-bezier(0.2, 0, 0.2, 1);
    transform: translateY(20px);
    z-index: 1;
    box-sizing: border-box;
  }

  /* Desktop Layout: Custom Multi-Area Grid */
  @media (min-width: 1024px) {
    .preview-entry {
      grid-template-areas: 
        "header body"
        "tags   body"
        "media  body"
        "footer footer";
      grid-template-columns: 2fr 3fr; /* 2:3 Ratio */
      grid-template-rows: auto auto 1fr auto;
      row-gap: 0.8rem;
      column-gap: 1.2rem;
      inset: 1.2rem;
      padding: 0;
    }
  }

  .preview-entry.active { 
    opacity: 1; 
    visibility: visible;
    pointer-events: auto;
    transform: translateY(0);
    z-index: 10; 
  }

  /* Assign Areas */
  .preview-header { 
    grid-area: header; 
    container-type: inline-size; /* Enable container query units for title scaling */
    width: 100%;
    min-width: 0; /* Prevents flex/grid blowout */
  }
  .descriptor-tags-container { grid-area: tags; }
  .preview-media  { grid-area: media; }
  .preview-body-text { grid-area: body; }
  .preview-footer { grid-area: footer; }

  /* Media Container */
  .preview-media {
    width: 100%;
    height: 100%;
    /* Let the grid control the height, don't force a min-height */
    min-height: 0;
    background: rgba(var(--black), 0.08);
    border-radius: 24px;
    overflow: hidden;
    box-shadow: var(--box-shadow-small);
  }

  .media-content {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }

  .preview-entry.active .media-content {
    transform: scale(1.02);
  }

  /* Typography Refinement & Scale-to-Fit Title */
  .preview-title {
    margin: 0;
    line-height: 1.2;
    font-weight: 900;
    letter-spacing: -0.02em;
    
    /* SCALE-TO-FIT LOGIC: */
    white-space: nowrap; /* Force one line */
    overflow: hidden;
    text-overflow: ellipsis; /* Will show "..." if it absolutely can't fit */
    
    /* 
       Dynamic to Viewport Height.
       Lowered the max to 2rem and ideal height to 3.5vh so it isn't massive.
    */
    font-size: clamp(1rem, 3vh, 2.0rem); 
    display: block;
    width: 100%;
  }

  .descriptor-tags-container {
    gap: 0.5rem;
    margin-top: 0.2rem;
    margin-bottom: 0.5rem;
    display: none !important; /* Hidden on mobile */
  }

  @media (min-width: 720px) {
    .descriptor-tags-container {
      display: flex !important;
    }
  }


  .descriptor-tag {
    background-color: var(--accent-reverse);
    color: var(--bg-color);
    /* Fluid padding and font size for desktop vs laptop sizes (Relative to height) */
    padding: clamp(0.15rem, 0.4vh, 0.25rem) clamp(0.5rem, 1vh, 0.75rem);
    border-radius: 8px;
    font-size: clamp(0.6rem, 1.2vh, 0.7rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .preview-body-text {
    font-size: clamp(1rem, 1.8vh, 1.25rem);
    line-height: 1.6;
    opacity: 0.85;
    text-align: left;
  }

  .body-full { display: none; margin: 0; }
  .body-condensed { display: block; margin: 0; }

  @media (min-width: 1024px) {
    .body-full { display: block; }
    .body-condensed { display: none; }
  }

  /* Footer & Button Positioning */
  .preview-footer {
    display: flex;
    justify-content: flex-end; /* Mobile default */
    align-items: flex-end;
  }

  @media (min-width: 1024px) {
    .preview-footer {
      justify-self: end; /* Desktop pin to bottom-right */
    }
  }

  .preview-link-btn {
    @apply btn-accent;
    min-width: 140px;
    padding-top: clamp(0.8rem, 2vh, 1.2rem); 
    padding-bottom: clamp(0.8rem, 2vh, 1.2rem);
  }

  /* Ensure filtered out entries are completely removed from layout */
  .project-entry.is-filtered-out, 
  .preview-entry.is-filtered-out { 
    display: none !important; 
  }
</style>
