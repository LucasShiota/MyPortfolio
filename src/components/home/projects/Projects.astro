---
import ProjectList from "./ProjectList.astro";
import ProjectPreviews from "./ProjectPreviews.astro";
import { projects, filterTags } from "./projectsData";
---
<div class="panel projects-panel">
  <div class="projects-preview-wrap">
    <ProjectPreviews projects={projects} />
  </div>
  <div class="projects-filter-parent"> 
    <div class="project-filters" role="group" aria-label="Filter projects">
      <button type="button" class="project-filter-btn is-active" data-filter="all" aria-pressed="true">All</button>
      {filterTags.map((tag) => (
        <button type="button" class="project-filter-btn" data-filter={tag} aria-pressed="false">
          {tag}
        </button>
      ))}
    </div>
  </div>
  <div class="projects-list-parent">
    <ProjectList projects={projects} />
  </div>
</div>

<script>
  import { initProjectsPanel } from "../../../scripts/projects/initProjectsPanel";

  if (document.readyState === "loading") {
    window.addEventListener("DOMContentLoaded", initProjectsPanel, { once: true });
  } else {
    initProjectsPanel();
  }
</script>

<style>
  .projects-panel {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    gap: 0;
  }

  .projects-preview-wrap {
    width: 100%;
    flex: 1;
    min-height: 0;
    display: flex;
    justify-content: center; align-items: center;
  }
</style>
