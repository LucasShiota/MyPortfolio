---
import BaseLayout from '@layouts/HomePageLayout.astro';
import ProjectIntro from '@components/projectPage/SectionIntro.astro';
import ProjectOverview from '@components/projectPage/SectionOverview.astro';
import SectionCardList from '@components/projectPage/SectionCardList.astro';
import SectionList from '@components/projectPage/SectionList.astro';
import ComingSoon from '@components/projectPage/SectionComingSoon.astro';
import TextSection from '@components/projectPage/SectionText.astro';
import TagSection from '@components/projectPage/SectionTags.astro';
import SectionTitle from '@components/projectPage/SectionTitle.astro';
import SectionButton from '@components/projectPage/SectionButton.astro';
import JumpToNav from '@components/projectPage/SectionNav.astro';
import { SITE_TITLE } from '@/config/site';

interface Props {
  data: any;
}

const { data } = Astro.props;

// Components Map
const COMPONENT_MAP: Record<string, any> = {
  Overview: ProjectOverview,
  CardList: SectionCardList,
  List: SectionList,
  ComingSoon: ComingSoon,
  Text: TextSection,
  Tags: TagSection,
  Title: SectionTitle,
  Button: SectionButton,
  TextCompact: TextSection,
};

const project = {
  title: data.title,
  subtitle: data.subtitle || "",
  tags: data.descriptorTags || [],
  tagColors: data.descriptorTagColors || {},
  heroImage: data.heroImage || data.previewImage,
  logo: data.logo || "",
  description: data.summary,
};

// Use the structure defined in Markdown
const sections = data.sections || [];
---

<BaseLayout title={`${project.title} | ${SITE_TITLE}`} description={project.description}>
  <main class="project-page">
    <JumpToNav sections={sections} title={project.title} />

    <ProjectIntro 
      id="intro"
      title={project.title}
      subtitle={project.subtitle}
      heroImage={project.heroImage}
      logo={project.logo}
    />

    <div class="content-wrapper">
      {(() => {
        let sectionCounter = 0;
        return sections.map((section: any) => {
          // Smart Exclusion: If no label is provided, it's treated as excluded from order automatically
          const isExcluded = section.options?.excludeFromOrder || !section.label;
          if (!isExcluded) sectionCounter++;
          const currentSectionOrder = isExcluded ? 0 : sectionCounter;

          return (
            <div class="section-group">
              {(() => {
                const Component = COMPONENT_MAP[section.component];
                if (!Component) return null;

                return (
                  <Component 
                    id={section.id || `${section.component}-${sectionCounter}`} 
                    {...section.props} 
                    order={currentSectionOrder} 
                    options={section.options}
                  />
                );
              })()}
              
              {section.subsections && section.subsections.length > 0 && (
                <div class="subsections-group">
                  {(() => {
                    let subCounter = 0;
                    return section.subsections.map((sub: any) => {
                      const SubComponent = COMPONENT_MAP[sub.component];
                      if (!SubComponent) return null;
                      
                      // Smart Exclusion for subsections
                      const isSubExcluded = sub.options?.excludeFromOrder || !sub.label;
                      if (!isSubExcluded) subCounter++;
                      const currentSubOrder = isSubExcluded ? 0 : subCounter;

                      return (
                        <SubComponent 
                          id={sub.id || `${sub.component}-${subCounter}`} 
                          {...sub.props}
                          isSubsection={true}
                          parentOrder={currentSectionOrder}
                          order={currentSubOrder}
                          options={{...sub.options, excludeFromOrder: isSubExcluded }}
                        />
                      );
                    });
                  })()}
                </div>
              )}
            </div>
          );
        });
      })()}
      <div class="page-bottom-buffer"></div>
    </div>
  </main>
</BaseLayout>

<style>
  @reference "../styles/global.css";

  .project-page {
    margin-top: var(--header-height);
    padding: 2rem;
    max-width: 1400px;
    margin-left: auto;
    margin-right: auto;
    min-height: calc(100vh - var(--header-height));
    display: flex;
    flex-direction: column;
    gap: 2rem;
    color: var(--text-color);
  }

  .content-wrapper {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    max-width: 1000px;
    margin: 0 auto;
    width: 100%;
  }

  .section-group {
    @apply surface-panel;
    background: var(--bg-color);
    display: flex;
    flex-direction: column;
    overflow: hidden; /* Ensure shared radius clips children */
  }

  /* Remove individual panel styles when inside a group to make them feel joined */
  .section-group :global(.panel-card) {
    background: transparent !important;
    border-color: transparent !important; /* Only hide the standard border */
    box-shadow: none !important;
    border-radius: 0 !important;
  }

  /* Specifically preserve the pseudo-element hierarchy bar defined in the component */
  .section-group :global(.project-section.subsection .panel-card::before) {
    display: block !important;
  }

  /* Differentiate subsections group with a tinted background */
  .subsections-group {
    background: var(--bg-color-tinted);
    display: flex;
    flex-direction: column;
    padding: 1rem 0;
  }

  /* Add back horizontal separators between sections in the group */
  .section-group > :global(.project-section:not(:last-child)) {
    border-bottom: var(--border);
  }

  /* Specific: If there are subsections, make sure the main section above it has a border */
  .section-group > :global(.project-section):has(+ .subsections-group) {
    border-bottom: var(--border);
  }

  /* Mobile Overrides */
  @media (min-width: 1024px) {
    .project-page {
      padding-left: clamp(200px, 20vw, 280px); /* Dedicated column for left tracking nav */
      padding-right: clamp(2rem, 5vw, 6rem);
    }
  }

  @media (max-width: 768px) {
    .project-page {
      padding: 1.5rem;
      gap: 3rem;
    }
  }

  /* Buffer to allow the last section to scroll into the active navigation zone */
  .page-bottom-buffer {
    height: 25vh;
    pointer-events: none;
  }
</style>
