---
import BaseHead from "@components/site/BaseHead.astro";
import Header from "@components/site/header/Header.astro";
import VantaFogBG from "@components/features/vantajs/VantaFogBG.astro";
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<html lang="en">
  <head>
    <script is:inline>
      if ("scrollRestoration" in history) {
        history.scrollRestoration = "manual";
      }

      // Extremely aggressive scroll lock for initial load with hash
      const initialHash = window.location.hash;
      if (initialHash && initialHash.length > 1) {
        // 1. Instantly nuke the hash from the URL
        history.replaceState(null, "", window.location.pathname + window.location.search);

        // 2. Fallback: override hash routing mechanisms
        window.location.hash = "";

        // 3. Brute-force scroll to top during the critical rendering path
        window.scrollTo(0, 0);

        const forceTop = () => window.scrollTo(0, 0);

        // Lock scroll via events
        window.addEventListener("scroll", forceTop, { passive: false });

        // Tick lock every 10ms for the first 300ms to fight Chrome's native engine
        let ticks = 0;
        const tickInterval = setInterval(() => {
          forceTop();
          ticks++;
          if (ticks > 30) clearInterval(tickInterval);
        }, 10);

        // Release event lock on DOMContentLoaded
        window.addEventListener("DOMContentLoaded", () => {
          setTimeout(() => window.removeEventListener("scroll", forceTop), 50);
        });
      } else {
        window.scrollTo(0, 0);
      }
    </script>
    <script is:inline src="https://kit.fontawesome.com/575b9c1578.js" crossorigin="anonymous"
    ></script>
    <BaseHead title={title} description={description} />
    <script is:inline>
      const savedTheme = localStorage.getItem("theme");
      if (savedTheme) {
        document.documentElement.setAttribute("data-theme", savedTheme === "dark" ? "dark" : "");
      } else {
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        if (prefersDark) {
          document.documentElement.setAttribute("data-theme", "dark");
        }
      }

      // Performance Mode Mobile Force (Only targets actual mobile hardware)
      const isMobileDevice = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(
        navigator.userAgent
      );
      if (isMobileDevice) {
        localStorage.setItem("performance-mode", "on");
        document.documentElement.classList.add("performance-mode", "mobile-device");
      }
    </script>
  </head>
  <body>
    <div id="startup-gate" aria-hidden="false">
      <div class="startup-gate__label">Loading</div>
    </div>
    <Header />
    <slot />
    <VantaFogBG />
    <script>
      import { initStartupController } from "@components/features/startup/startupController";
      initStartupController();
    </script>
  </body>
</html>

<style is:global>
  #startup-gate {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: grid;
    place-items: center;
    background: color-mix(in oklab, var(--bg-color) 82%, black 18%);
    backdrop-filter: blur(8px);
    transition: opacity 0.38s ease;
    opacity: 1;
    pointer-events: none;
  }

  .startup-gate__label {
    font-family: var(--font-display);
    letter-spacing: 0.08em;
    font-size: clamp(0.9rem, 1.2vw, 1.1rem);
    opacity: 0.75;
  }

  .startup-ready #startup-gate {
    opacity: 0;
  }
</style>
