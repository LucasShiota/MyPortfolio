---
import BaseHead from "@components/site/BaseHead.astro";
import Header from "@components/site/header/Header.astro";
import ShaderFogBG from "@components/features/vantajs/ShaderFogBG.astro";
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<html lang="en">
  <head>
    <script is:inline>
      if ("scrollRestoration" in history) history.scrollRestoration = "manual";
      window.scrollTo(0, 0);

      const initialHash = window.location.hash;
      if (initialHash && initialHash.length > 1) {
        history.replaceState(null, "", window.location.pathname + window.location.search);
        const forceTop = () => window.scrollTo(0, 0);
        window.addEventListener("scroll", forceTop, { passive: false });
        let ticks = 0;
        const tickInterval = setInterval(() => {
          forceTop();
          if (++ticks > 30) clearInterval(tickInterval);
        }, 10);
        window.addEventListener(
          "DOMContentLoaded",
          () => {
            setTimeout(() => window.removeEventListener("scroll", forceTop), 50);
          },
          { once: true }
        );
      }
    </script>
    <BaseHead title={title} description={description} />
    <script is:inline>
      (function () {
        const theme =
          localStorage.getItem("theme") ||
          (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "");
        if (theme === "dark") document.documentElement.setAttribute("data-theme", "dark");

        const isMobile = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(
          navigator.userAgent
        );
        if (isMobile) {
          localStorage.setItem("performance-mode-v2", "low");
          document.documentElement.classList.add("perf-low", "mobile-device");
        }
      })();
    </script>
  </head>
  <body>
    <div id="startup-gate" aria-hidden="false">
      <div class="startup-gate__label">Loading</div>
    </div>
    <Header />
    <slot />
    <ShaderFogBG />
    <script>
      import { initStartupController } from "@components/features/startup/startupController";
      initStartupController();
    </script>
  </body>
</html>

<style is:global>
  #startup-gate {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: grid;
    place-items: center;
    background: color-mix(in oklab, var(--bg-base) 82%, black 18%);
    backdrop-filter: blur(8px);
    transition: opacity 0.38s ease;
    opacity: 1;
    pointer-events: none;
  }

  .startup-gate__label {
    font-family: var(--font-display);
    letter-spacing: 0.08em;
    font-size: clamp(0.9rem, 1.2vw, 1.1rem);
    opacity: 0.75;
  }

  .startup-ready #startup-gate {
    opacity: 0;
  }
</style>
