---
import { getEntry } from 'astro:content';
import BaseLayout from '../components/layouts/BaseLayout.astro';
import ProjectIntro from '../components/project/ProjectIntro.astro';
import ProjectOverview from '../components/project/ProjectOverview.astro';
import CoreDesignGoals from '../components/project/CoreDesignGoals.astro';
import ComingSoon from '../components/project/ComingSoon.astro';
import TextSection from '../components/project/TextSection.astro';
import JumpToNav from '../components/project/JumpToNav.astro';
import { SITE_TITLE } from '../consts';

// Fetch the project data from Content collections
const entry = await getEntry('projects', 'baraliot');
if (!entry) {
  return Astro.redirect('/404');
}

const { data } = entry;

// Components Map
const COMPONENT_MAP: Record<string, any> = {
  Overview: ProjectOverview,
  Goals: CoreDesignGoals,
  ComingSoon: ComingSoon,
  Text: TextSection,
};

const project = {
  title: data.title,
  subtitle: data.subtitle || "",
  tags: data.descriptorTags || [],
  tagColors: data.descriptorTagColors || {},
  heroImage: data.heroImage || data.previewImage,
  logo: data.logo || "",
  description: data.summary,
};

// Use the structure defined in Markdown
const sections = data.sections || [];
---

<BaseLayout title={`${project.title} | ${SITE_TITLE}`} description={project.description}>
  <main class="project-page">
    <JumpToNav sections={sections} />

    <ProjectIntro 
      id="intro"
      title={project.title}
      subtitle={project.subtitle}
      tags={project.tags}
      tagColors={project.tagColors}
      heroImage={project.heroImage}
      logo={project.logo}
    />

    <div class="content-wrapper">
      {sections.map((section, index) => (
        <div class="section-group">
          {(() => {
            const Component = COMPONENT_MAP[section.component];
            if (!Component) return null;

            return (
              <Component 
                id={section.id} 
                {...section.props} 
                order={index + 1} 
              />
            );
          })()}
          
          {section.subsections && section.subsections.map((sub, subIndex) => {
            const SubComponent = COMPONENT_MAP[sub.component];
            if (!SubComponent) return null;
            
            return (
              <SubComponent 
                id={sub.id} 
                {...sub.props}
                isSubsection={true}
                parentOrder={index + 1}
                order={subIndex + 1}
              />
            );
          })}
        </div>
      ))}
    </div>
  </main>
</BaseLayout>

<style>
  @reference "../styles/global.css";

  .project-page {
    margin-top: var(--header-height);
    padding: 2rem;
    max-width: 1400px;
    margin-left: auto;
    margin-right: auto;
    min-height: calc(100vh - var(--header-height));
    display: flex;
    flex-direction: column;
    gap: 4rem;
    color: var(--text-color);
  }

  .content-wrapper {
    display: flex;
    flex-direction: column;
    gap: 4rem;
    max-width: 1000px;
    margin: 0 auto;
    width: 100%;
  }

  .section-group {
    @apply surface-panel;
    background: var(--bg-color);
    display: flex;
    flex-direction: column;
    overflow: hidden; /* Ensure shared radius clips children */
  }

  /* Remove individual panel styles when inside a group to make them feel joined */
  .section-group :global(.panel-card) {
    background: transparent !important;
    border-color: transparent !important; /* Only hide the standard border */
    box-shadow: none !important;
    border-radius: 0 !important;
  }

  /* Specifically preserve the pseudo-element hierarchy bar defined in the component */
  .section-group :global(.project-section.subsection .panel-card::before) {
    display: block !important;
  }

  /* Add back horizontal separators between sections in the group */
  .section-group > :global(.project-section:not(:last-child)) {
    border-bottom: var(--border);
  }

  /* But if a subsection is followed by another subsection, remove the border to join them */
  .section-group > :global(.project-section.subsection:has(+ .project-section.subsection)) {
    border-bottom: none;
  }

  /* Subtly differentiate subsections with the tinted background */
  .section-group :global(.project-section.subsection) {
    background: var(--bg-color-tinted);
  }

  /* Mobile Overrides */
  @media (min-width: 1024px) {
    .project-page {
      padding-left: clamp(200px, 20vw, 280px); /* Dedicated column for left tracking nav */
      padding-right: clamp(2rem, 5vw, 6rem);
    }
  }

  @media (max-width: 768px) {
    .project-page {
      padding: 1.5rem;
      gap: 3rem;
    }
  }
</style>
