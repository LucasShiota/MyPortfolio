---
import { getEntry } from 'astro:content';
import BaseLayout from '../components/layouts/BaseLayout.astro';
import ProjectIntro from '../components/project/ProjectIntro.astro';
import ProjectOverview from '../components/project/ProjectOverview.astro';
import CoreDesignGoals from '../components/project/CoreDesignGoals.astro';
import ComingSoon from '../components/project/ComingSoon.astro';
import JumpToNav from '../components/project/JumpToNav.astro';
import { SITE_TITLE } from '../consts';

// Fetch the project data from Content collections
const entry = await getEntry('projects', 'baraliot');
if (!entry) {
  return Astro.redirect('/404');
}

const { data } = entry;

// Map the data to the format the page components expect
const project = {
  title: data.title,
  subtitle: data.subtitle || "",
  tags: data.descriptorTags || [],
  tagColors: data.descriptorTagColors || {},
  heroImage: data.heroImage || data.previewImage,
  logo: data.logo || "",
  description: data.summary,
  goals: data.goals || []
};

const navSections = [
  { id: "intro", label: "Top" },
  { id: "overview", label: "Overview" },
  { id: "goals", label: "Design Goals" },
  { id: "coming-soon", label: "More Details" },
];
---

<BaseLayout title={`${project.title} | ${SITE_TITLE}`} description={project.description}>
  <main class="project-page">
    <JumpToNav sections={navSections} />

    <ProjectIntro 
      id="intro"
      title={project.title}
      subtitle={project.subtitle}
      tags={project.tags}
      tagColors={project.tagColors}
      heroImage={project.heroImage}
      logo={project.logo}
    />

    <div class="content-wrapper">
      <ProjectOverview 
        id="overview" 
        description={project.description} 
        order={1} 
        total={navSections.length - 1} 
      />

      {project.goals.length > 0 && (
        <CoreDesignGoals 
          id="goals" 
          goals={project.goals} 
          order={2} 
          total={navSections.length - 1} 
        />
      )}

      <ComingSoon 
        id="coming-soon" 
        projectTitle={project.title} 
        order={3} 
        total={navSections.length - 1} 
      />
    </div>
  </main>
</BaseLayout>

<style>
  @reference "../styles/global.css";

  .project-page {
    margin-top: var(--header-height);
    padding: 2rem;
    max-width: 1400px;
    margin-left: auto;
    margin-right: auto;
    min-height: calc(100vh - var(--header-height));
    display: flex;
    flex-direction: column;
    gap: 4rem;
    color: var(--text-color);
  }

  .content-wrapper {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    max-width: 1000px;
    margin: 0 auto;
    width: 100%;
  }

  /* Mobile Overrides */
  @media (min-width: 1024px) {
    .project-page {
      padding-left: clamp(200px, 20vw, 280px); /* Dedicated column for left tracking nav */
      padding-right: clamp(2rem, 5vw, 6rem);
    }
  }

  @media (max-width: 768px) {
    .project-page {
      padding: 1.5rem;
      gap: 3rem;
    }
  }
</style>
