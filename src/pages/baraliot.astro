---
import BaseLayout from '../components/layouts/BaseLayout.astro';
import ProjectIntro from '../components/project/ProjectIntro.astro';
import ProjectOverview from '../components/project/ProjectOverview.astro';
import CoreDesignGoals from '../components/project/CoreDesignGoals.astro';
import ComingSoon from '../components/project/ComingSoon.astro';
import JumpToNav from '../components/project/JumpToNav.astro';
import { SITE_TITLE } from '../consts';

// Project specific data (can be moved to a separate file later if needed)
const project = {
  title: "Baraliot Fantasia",
  subtitle: "A New Style Deckbuilding TRPG",
  tags: ["Game System", "Typography", "Layout", "Writing"],
  heroImage: "/images/baraliot.webp",
  logo: "",
  description: "An NSR TRPG blending deckbuilding gameplay and deep character fantasy. Embracing improv, mixing, and synergy. A high-variety system players can easily jump into and get lost in.",
  goals: [
    "Use the gameplay potential of card and deckbuilding mechanics to their fullest",
    "Evoke a sense of satisfaction in players realizing their character fantasy",
    "Streamline rules and rulebook to lower the barrier of entry and the cost of play",
    "Excite players with many choices and freedom without overwhelming them",
    "A high-density, low-complexity approach to the overarching rules package"
  ]
};

const navSections = [
  { id: "intro", label: "Intro" },
  { id: "overview", label: "Overview" },
  { id: "goals", label: "Design Goals" },
  { id: "coming-soon", label: "More Details" },
];
---

<BaseLayout title={`${project.title} | ${SITE_TITLE}`} description={project.description}>
  <main class="project-page">
    <JumpToNav sections={navSections} />

    <ProjectIntro 
      id="intro"
      title={project.title}
      subtitle={project.subtitle}
      tags={project.tags}
      heroImage={project.heroImage}
      logo={project.logo}
    />

    <div class="content-wrapper">
      <ProjectOverview id="overview" description={project.description} />

      <CoreDesignGoals id="goals" goals={project.goals} />

      <ComingSoon id="coming-soon" projectTitle={project.title} />
    </div>
  </main>
</BaseLayout>

<style>
  @reference "../styles/global.css";

  .project-page {
    margin-top: var(--header-height);
    padding: 2rem;
    max-width: 1400px;
    margin-left: auto;
    margin-right: auto;
    min-height: calc(100vh - var(--header-height));
    display: flex;
    flex-direction: column;
    gap: 4rem;
    color: var(--text-color);
  }

  .content-wrapper {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    max-width: 1000px;
    margin: 0 auto;
    width: 100%;
  }

  /* Mobile Overrides */
  @media (min-width: 1024px) {
    .project-page {
      padding-left: clamp(200px, 20vw, 280px); /* Dedicated column for left tracking nav */
      padding-right: clamp(2rem, 5vw, 6rem);
    }
  }

  @media (max-width: 768px) {
    .project-page {
      padding: 1.5rem;
      gap: 3rem;
    }
  }
</style>
