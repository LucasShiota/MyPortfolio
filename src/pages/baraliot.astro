---
import { getEntry } from 'astro:content';
import BaseLayout from '../components/layouts/BaseLayout.astro';
import ProjectIntro from '../components/projectPage/SectionIntro.astro';
import ProjectOverview from '../components/projectPage/SectionOverview.astro';
import CoreDesignGoals from '../components/projectPage/SectionGoals.astro';
import ComingSoon from '../components/projectPage/SectionComingSoon.astro';
import TextSection from '../components/projectPage/SectionText.astro';
import TagSection from '../components/projectPage/SectionTags.astro';
import JumpToNav from '../components/projectPage/SectionNav.astro';
import { SITE_TITLE } from '../consts';

// Fetch the project data from Content collections
const entry = await getEntry('projects', 'baraliot');
if (!entry) {
  return Astro.redirect('/404');
}

const { data } = entry;

// Components Map
const COMPONENT_MAP: Record<string, any> = {
  Overview: ProjectOverview,
  Goals: CoreDesignGoals,
  ComingSoon: ComingSoon,
  Text: TextSection,
  Tags: TagSection,
};

const project = {
  title: data.title,
  subtitle: data.subtitle || "",
  tags: data.descriptorTags || [],
  tagColors: data.descriptorTagColors || {},
  heroImage: data.heroImage || data.previewImage,
  logo: data.logo || "",
  description: data.summary,
};

// Use the structure defined in Markdown
const sections = data.sections || [];
---

<BaseLayout title={`${project.title} | ${SITE_TITLE}`} description={project.description}>
  <main class="project-page">
    <JumpToNav sections={sections} />

    <ProjectIntro 
      id="intro"
      title={project.title}
      subtitle={project.subtitle}
      tags={project.tags}
      tagColors={project.tagColors}
      heroImage={project.heroImage}
      logo={project.logo}
    />

    <div class="content-wrapper">
      {(() => {
        let sectionCounter = 0;
        return sections.map((section) => {
          const isExcluded = section.options?.excludeFromOrder;
          if (!isExcluded) sectionCounter++;
          const currentSectionOrder = sectionCounter;

          return (
            <div class="section-group">
              {(() => {
                const Component = COMPONENT_MAP[section.component];
                if (!Component) return null;

                return (
                  <Component 
                    id={section.id} 
                    {...section.props} 
                    order={currentSectionOrder} 
                    options={section.options}
                  />
                );
              })()}
              
              {(() => {
                let subCounter = 0;
                return section.subsections && section.subsections.map((sub) => {
                  const SubComponent = COMPONENT_MAP[sub.component];
                  if (!SubComponent) return null;
                  
                  const isSubExcluded = sub.options?.excludeFromOrder;
                  if (!isSubExcluded) subCounter++;

                  return (
                    <SubComponent 
                      id={sub.id} 
                      {...sub.props}
                      isSubsection={true}
                      parentOrder={currentSectionOrder}
                      order={subCounter}
                      options={sub.options}
                    />
                  );
                });
              })()}
            </div>
          );
        });
      })()}
    </div>
  </main>
</BaseLayout>

<style>
  @reference "../styles/global.css";

  .project-page {
    margin-top: var(--header-height);
    padding: 2rem;
    max-width: 1400px;
    margin-left: auto;
    margin-right: auto;
    min-height: calc(100vh - var(--header-height));
    display: flex;
    flex-direction: column;
    gap: 4rem;
    color: var(--text-color);
  }

  .content-wrapper {
    display: flex;
    flex-direction: column;
    gap: 4rem;
    max-width: 1000px;
    margin: 0 auto;
    width: 100%;
  }

  .section-group {
    @apply surface-panel;
    background: var(--bg-color);
    display: flex;
    flex-direction: column;
    overflow: hidden; /* Ensure shared radius clips children */
  }

  /* Remove individual panel styles when inside a group to make them feel joined */
  .section-group :global(.panel-card) {
    background: transparent !important;
    border-color: transparent !important; /* Only hide the standard border */
    box-shadow: none !important;
    border-radius: 0 !important;
  }

  /* Specifically preserve the pseudo-element hierarchy bar defined in the component */
  .section-group :global(.project-section.subsection .panel-card::before) {
    display: block !important;
  }

  /* Add back horizontal separators between sections in the group */
  .section-group > :global(.project-section:not(:last-child)) {
    border-bottom: var(--border);
  }

  /* But if a subsection is followed by another subsection, remove the border to join them */
  .section-group > :global(.project-section.subsection:has(+ .project-section.subsection)) {
    border-bottom: none;
  }

  /* Subtly differentiate subsections with the tinted background */
  .section-group :global(.project-section.subsection) {
    background: var(--bg-color-tinted);
  }

  /* Mobile Overrides */
  @media (min-width: 1024px) {
    .project-page {
      padding-left: clamp(200px, 20vw, 280px); /* Dedicated column for left tracking nav */
      padding-right: clamp(2rem, 5vw, 6rem);
    }
  }

  @media (max-width: 768px) {
    .project-page {
      padding: 1.5rem;
      gap: 3rem;
    }
  }
</style>
