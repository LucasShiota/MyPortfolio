---
import { getEntry } from 'astro:content';
import ProjectPageLayout from '../../components/projectPage/ProjectPageLayout.astro';

// Fetch the project data from Content collections
const entry = await getEntry('projects', 'baraliot');
if (!entry) {
  return Astro.redirect('/404');
}

const { data } = entry;
---

<ProjectPageLayout data={data} />
