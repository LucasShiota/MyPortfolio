---
import BaseLayout from '../components/layouts/BaseLayout.astro';

import SideBar from '../components/home/SideBar.astro';

import Hero from '../components/home/panels/Hero.astro';
import Contacts from '../components/home/panels/Contacts.astro';
import About from '../components/home/panels/About.astro';
import Projects from '../components/home/projectsPanel/Projects.astro';

import { SITE_TITLE, SITE_DESCRIPTION } from '../config/site';
---
<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <div class="master-layout">
    <main class="main-content">
      <Hero />
      <Projects />
      <About />
      <Contacts />
    </main>
    <aside class="sidebar-area">
      <SideBar />
    </aside>
  </div>
</BaseLayout>

<style is:global>
  .panel { 
    height: var(--panel-height); 
    width: 100%; 
    padding-top: var(--header-height); 
    scroll-margin-top: var(--header-height);
    display: flex; /* Ensure it stays a flex container if it isn't already */
    flex-direction: column;
  }

  @media (max-width: 768px) {
    .panel {
      min-height: auto;
      padding-top: 2rem;
    }
  }
</style>
