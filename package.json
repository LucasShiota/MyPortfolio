{
  "name": "c-users-lshio-desktop-lucas-shiota-github-repo-newastro",
  "type": "module",
  "version": "0.0.2",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest run --config .config/vitest.config.ts",
    "test:watch": "vitest --config .config/vitest.config.ts",
    "prepare": "husky",
    "release": "standard-version",
    "a11y": "pa11y http://localhost:4321",
    "visual-check": "playwright test --config .config/playwright.config.ts",
    "archive-changelog": "node .agent/scripts/archive-changelog.mjs"
  },
  "standard-version": {
    "infile": ".docs/CHANGELOG.md",
    "packageFiles": [
      "package.json"
    ],
    "bumpFiles": [
      "package.json"
    ]
  },
  "prettier": {
    "semi": true,
    "singleQuote": false,
    "tabWidth": 2,
    "trailingComma": "es5",
    "printWidth": 100,
    "plugins": [
      "prettier-plugin-astro",
      "prettier-plugin-tailwindcss"
    ],
    "overrides": [
      {
        "files": "*.astro",
        "options": {
          "parser": "astro"
        }
      }
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/rss": "^4.0.15",
    "@astrojs/sitemap": "^3.7.0",
    "@tailwindcss/vite": "^4.2.1",
    "astro": "^5.17.1",
    "gsap": "^3.14.2",
    "matter-js": "^0.20.0",
    "sharp": "^0.34.3",
    "tailwindcss": "^4.2.1",
    "three": "^0.182.0",
    "vanta": "^0.5.24"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@playwright/test": "^1.58.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "pa11y": "^9.1.1",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "standard-version": "^9.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{js,ts,astro,json,md,css}": [
      "prettier --write"
    ],
    "*.{jpg,png,webp}": [
      "node scripts/image-guard.mjs"
    ]
  }
}
